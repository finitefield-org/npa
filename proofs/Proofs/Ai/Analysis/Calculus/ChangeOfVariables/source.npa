  forall (Domain : Sort v), forall (Codomain : Sort w), forall (map : forall (x : Domain), Codomain), forall (source_region : forall (x : Domain), Prop), forall (target_region : forall (y : Codomain), Prop), forall (OrientationLaw : Prop), forall (BoundaryCompatibilityLaw : Prop), forall (orientation_law : OrientationLaw), forall (boundary_compatibility_law : BoundaryCompatibilityLaw), @OrientedChangeOfVariablesBoundaryData.{v,w} Domain Codomain map source_region target_region OrientationLaw BoundaryCompatibilityLaw :=

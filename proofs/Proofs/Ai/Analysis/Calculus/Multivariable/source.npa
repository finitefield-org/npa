theorem multivariable_mean_value_theorem.{u,v,w} :
  forall (Scalar : Sort u), forall (X : Sort v), forall (Y : Sort w), forall (f : forall (x : X), Y), forall (start : X), forall (finish : X), forall (SmoothnessLaw : Prop), forall (SegmentLaw : Prop), forall (DerivativeBoundLaw : Prop), forall (MeanValueConclusion : Prop), forall (evidence : @MultivariableMeanValueEvidence.{u,v,w} Scalar X Y f start finish SmoothnessLaw SegmentLaw DerivativeBoundLaw MeanValueConclusion), MeanValueConclusion :=
  fun Scalar => fun X => fun Y => fun f => fun start => fun finish => fun SmoothnessLaw => fun SegmentLaw => fun DerivativeBoundLaw => fun MeanValueConclusion => fun evidence => evidence MeanValueConclusion (fun (smoothness_law : SmoothnessLaw) => fun (segment_law : SegmentLaw) => fun (derivative_bound_law : DerivativeBoundLaw) => fun (mean_value_route : SmoothnessLaw -> SegmentLaw -> DerivativeBoundLaw -> MeanValueConclusion) => mean_value_route smoothness_law segment_law derivative_bound_law)

theorem multivariable_taylor_theorem.{u,v,w} :
  forall (Scalar : Sort u), forall (X : Sort v), forall (Y : Sort w), forall (f : forall (x : X), Y), forall (center : X), forall (point : X), forall (SmoothnessLaw : Prop), forall (TaylorPolynomialLaw : Prop), forall (RemainderLaw : Prop), forall (TaylorConclusion : Prop), forall (evidence : @MultivariableTaylorEvidence.{u,v,w} Scalar X Y f center point SmoothnessLaw TaylorPolynomialLaw RemainderLaw TaylorConclusion), TaylorConclusion :=
  fun Scalar => fun X => fun Y => fun f => fun center => fun point => fun SmoothnessLaw => fun TaylorPolynomialLaw => fun RemainderLaw => fun TaylorConclusion => fun evidence => evidence TaylorConclusion (fun (smoothness_law : SmoothnessLaw) => fun (polynomial_law : TaylorPolynomialLaw) => fun (remainder_law : RemainderLaw) => fun (taylor_route : SmoothnessLaw -> TaylorPolynomialLaw -> RemainderLaw -> TaylorConclusion) => taylor_route smoothness_law polynomial_law remainder_law)

theorem mixed_partial_derivatives_commute.{u,v,w} :
  forall (Scalar : Sort u), forall (Domain : Sort v), forall (Codomain : Sort w), forall (f : forall (x : Domain), Codomain), forall (point : Domain), forall (first_axis : Domain), forall (second_axis : Domain), forall (first_then_second : Codomain), forall (second_then_first : Codomain), forall (SecondOrderSmoothnessLaw : Prop), forall (IteratedPartialConstructionLaw : Prop), forall (MixedPartialSymmetryConclusion : Prop), forall (data : @MixedPartialDerivativeData.{u,v,w} Scalar Domain Codomain f point first_axis second_axis first_then_second second_then_first SecondOrderSmoothnessLaw IteratedPartialConstructionLaw MixedPartialSymmetryConclusion), MixedPartialSymmetryConclusion :=
  fun Scalar => fun Domain => fun Codomain => fun f => fun point => fun first_axis => fun second_axis => fun first_then_second => fun second_then_first => fun SecondOrderSmoothnessLaw => fun IteratedPartialConstructionLaw => fun MixedPartialSymmetryConclusion => fun data => data MixedPartialSymmetryConclusion (fun (second_order_smoothness_law : SecondOrderSmoothnessLaw) => fun (iterated_partial_construction_law : IteratedPartialConstructionLaw) => fun (symmetry_route : SecondOrderSmoothnessLaw -> IteratedPartialConstructionLaw -> MixedPartialSymmetryConclusion) => symmetry_route second_order_smoothness_law iterated_partial_construction_law)

theorem lagrange_multiplier_theorem.{u,v,w} :
  forall (Scalar : Sort u), forall (Domain : Sort v), forall (ConstraintValue : Sort w), forall (objective : forall (x : Domain), Scalar), forall (constraint : forall (x : Domain), ConstraintValue), forall (point : Domain), forall (multiplier : ConstraintValue), forall (SmoothnessLaw : Prop), forall (ConstraintRegularityLaw : Prop), forall (StationarityConclusion : Prop), forall (evidence : @LagrangeMultiplierEvidence.{u,v,w} Scalar Domain ConstraintValue objective constraint point multiplier SmoothnessLaw ConstraintRegularityLaw StationarityConclusion), StationarityConclusion :=
  fun Scalar => fun Domain => fun ConstraintValue => fun objective => fun constraint => fun point => fun multiplier => fun SmoothnessLaw => fun ConstraintRegularityLaw => fun StationarityConclusion => fun evidence => evidence StationarityConclusion (fun (smoothness_law : SmoothnessLaw) => fun (constraint_regularity_law : ConstraintRegularityLaw) => fun (stationarity_route : SmoothnessLaw -> ConstraintRegularityLaw -> StationarityConclusion) => stationarity_route smoothness_law constraint_regularity_law)

def MultivariableMeanValueEvidence.{u,v,w} :
  forall (Scalar : Sort u), forall (X : Sort v), forall (Y : Sort w), forall (f : forall (x : X), Y), forall (start : X), forall (finish : X), forall (SmoothnessLaw : Prop), forall (SegmentLaw : Prop), forall (DerivativeBoundLaw : Prop), forall (MeanValueConclusion : Prop), Prop :=
  fun Scalar => fun X => fun Y => fun f => fun start => fun finish => fun SmoothnessLaw => fun SegmentLaw => fun DerivativeBoundLaw => fun MeanValueConclusion => forall (P : Prop), forall (mk : forall (smoothness_law : SmoothnessLaw), forall (segment_law : SegmentLaw), forall (derivative_bound_law : DerivativeBoundLaw), forall (mean_value_route : SmoothnessLaw -> SegmentLaw -> DerivativeBoundLaw -> MeanValueConclusion), P), P

def MultivariableTaylorEvidence.{u,v,w} :
  forall (Scalar : Sort u), forall (X : Sort v), forall (Y : Sort w), forall (f : forall (x : X), Y), forall (center : X), forall (point : X), forall (SmoothnessLaw : Prop), forall (TaylorPolynomialLaw : Prop), forall (RemainderLaw : Prop), forall (TaylorConclusion : Prop), Prop :=
  fun Scalar => fun X => fun Y => fun f => fun center => fun point => fun SmoothnessLaw => fun TaylorPolynomialLaw => fun RemainderLaw => fun TaylorConclusion => forall (P : Prop), forall (mk : forall (smoothness_law : SmoothnessLaw), forall (polynomial_law : TaylorPolynomialLaw), forall (remainder_law : RemainderLaw), forall (taylor_route : SmoothnessLaw -> TaylorPolynomialLaw -> RemainderLaw -> TaylorConclusion), P), P

def MixedPartialDerivativeData.{u,v,w} :
  forall (Scalar : Sort u), forall (Domain : Sort v), forall (Codomain : Sort w), forall (f : forall (x : Domain), Codomain), forall (point : Domain), forall (first_axis : Domain), forall (second_axis : Domain), forall (first_then_second : Codomain), forall (second_then_first : Codomain), forall (SecondOrderSmoothnessLaw : Prop), forall (IteratedPartialConstructionLaw : Prop), forall (MixedPartialSymmetryConclusion : Prop), Prop :=
  fun Scalar => fun Domain => fun Codomain => fun f => fun point => fun first_axis => fun second_axis => fun first_then_second => fun second_then_first => fun SecondOrderSmoothnessLaw => fun IteratedPartialConstructionLaw => fun MixedPartialSymmetryConclusion => forall (P : Prop), forall (mk : forall (second_order_smoothness_law : SecondOrderSmoothnessLaw), forall (iterated_partial_construction_law : IteratedPartialConstructionLaw), forall (symmetry_route : SecondOrderSmoothnessLaw -> IteratedPartialConstructionLaw -> MixedPartialSymmetryConclusion), P), P

def LagrangeMultiplierEvidence.{u,v,w} :
  forall (Scalar : Sort u), forall (Domain : Sort v), forall (ConstraintValue : Sort w), forall (objective : forall (x : Domain), Scalar), forall (constraint : forall (x : Domain), ConstraintValue), forall (point : Domain), forall (multiplier : ConstraintValue), forall (SmoothnessLaw : Prop), forall (ConstraintRegularityLaw : Prop), forall (StationarityConclusion : Prop), Prop :=
  fun Scalar => fun Domain => fun ConstraintValue => fun objective => fun constraint => fun point => fun multiplier => fun SmoothnessLaw => fun ConstraintRegularityLaw => fun StationarityConclusion => forall (P : Prop), forall (mk : forall (smoothness_law : SmoothnessLaw), forall (constraint_regularity_law : ConstraintRegularityLaw), forall (stationarity_route : SmoothnessLaw -> ConstraintRegularityLaw -> StationarityConclusion), P), P


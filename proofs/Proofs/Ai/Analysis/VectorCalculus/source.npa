def VectorCalculusBoundaryData.{u,v,w} :
  forall (Scalar : Sort u), forall (Domain : Sort v), forall (Boundary : Sort w), forall (boundary_point : forall (b : Boundary), Domain), forall (BoundaryRegularityLaw : Prop), forall (OrientationCompatibilityLaw : Prop), Prop :=
  fun Scalar => fun Domain => fun Boundary => fun boundary_point => fun BoundaryRegularityLaw => fun OrientationCompatibilityLaw => forall (P : Prop), forall (mk : forall (boundary_regularity_law : BoundaryRegularityLaw), forall (orientation_compatibility_law : OrientationCompatibilityLaw), P), P

def GreenTheoremEvidence.{u,v,w} :
  forall (Scalar : Sort u), forall (add : forall (a : Scalar), forall (b : Scalar), Scalar), forall (Domain : Sort v), forall (Boundary : Sort w), forall (boundary_point : forall (b : Boundary), Domain), forall (VectorField : Sort v), forall (circulation_integral : Scalar), forall (curl_integral : Scalar), forall (BoundaryRegularityLaw : Prop), forall (OrientationCompatibilityLaw : Prop), forall (PlanarRegionLaw : Prop), forall (FieldSmoothnessLaw : Prop), forall (GreenConclusion : Prop), Prop :=
  fun Scalar => fun add => fun Domain => fun Boundary => fun boundary_point => fun VectorField => fun circulation_integral => fun curl_integral => fun BoundaryRegularityLaw => fun OrientationCompatibilityLaw => fun PlanarRegionLaw => fun FieldSmoothnessLaw => fun GreenConclusion => forall (P : Prop), forall (mk : forall (boundary_data : @VectorCalculusBoundaryData.{u,v,w} Scalar Domain Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw), forall (planar_region_law : PlanarRegionLaw), forall (field_smoothness_law : FieldSmoothnessLaw), forall (green_route : @VectorCalculusBoundaryData.{u,v,w} Scalar Domain Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw -> PlanarRegionLaw -> FieldSmoothnessLaw -> GreenConclusion), P), P

def DivergenceTheoremEvidence.{u,v,w} :
  forall (Scalar : Sort u), forall (Domain : Sort v), forall (Boundary : Sort w), forall (boundary_point : forall (b : Boundary), Domain), forall (VectorField : Sort v), forall (flux_integral : Scalar), forall (divergence_integral : Scalar), forall (BoundaryRegularityLaw : Prop), forall (OrientationCompatibilityLaw : Prop), forall (VolumeRegionLaw : Prop), forall (FieldSmoothnessLaw : Prop), forall (DivergenceConclusion : Prop), Prop :=
  fun Scalar => fun Domain => fun Boundary => fun boundary_point => fun VectorField => fun flux_integral => fun divergence_integral => fun BoundaryRegularityLaw => fun OrientationCompatibilityLaw => fun VolumeRegionLaw => fun FieldSmoothnessLaw => fun DivergenceConclusion => forall (P : Prop), forall (mk : forall (boundary_data : @VectorCalculusBoundaryData.{u,v,w} Scalar Domain Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw), forall (volume_region_law : VolumeRegionLaw), forall (field_smoothness_law : FieldSmoothnessLaw), forall (divergence_route : @VectorCalculusBoundaryData.{u,v,w} Scalar Domain Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw -> VolumeRegionLaw -> FieldSmoothnessLaw -> DivergenceConclusion), P), P


  forall (Scalar : Sort u), forall (add : forall (a : Scalar), forall (b : Scalar), Scalar), forall (Domain : Sort v), forall (Boundary : Sort w), forall (boundary_point : forall (b : Boundary), Domain), forall (VectorField : Sort v), forall (circulation_integral : Scalar), forall (curl_integral : Scalar), forall (BoundaryRegularityLaw : Prop), forall (OrientationCompatibilityLaw : Prop), forall (PlanarRegionLaw : Prop), forall (FieldSmoothnessLaw : Prop), forall (GreenConclusion : Prop), forall (evidence : @GreenTheoremEvidence.{u,v,w} Scalar add Domain Boundary boundary_point VectorField circulation_integral curl_integral BoundaryRegularityLaw OrientationCompatibilityLaw PlanarRegionLaw FieldSmoothnessLaw GreenConclusion), GreenConclusion :=
  fun Scalar => fun add => fun Domain => fun Boundary => fun boundary_point => fun VectorField => fun circulation_integral => fun curl_integral => fun BoundaryRegularityLaw => fun OrientationCompatibilityLaw => fun PlanarRegionLaw => fun FieldSmoothnessLaw => fun GreenConclusion => fun evidence => evidence GreenConclusion (fun (boundary_data : @VectorCalculusBoundaryData.{u,v,w} Scalar Domain Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw) => fun (planar_region_law : PlanarRegionLaw) => fun (field_smoothness_law : FieldSmoothnessLaw) => fun (green_route : @VectorCalculusBoundaryData.{u,v,w} Scalar Domain Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw -> PlanarRegionLaw -> FieldSmoothnessLaw -> GreenConclusion) => green_route boundary_data planar_region_law field_smoothness_law)


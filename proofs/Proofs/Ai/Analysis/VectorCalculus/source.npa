  forall (Scalar : Sort u), forall (Manifold : Sort v), forall (Boundary : Sort w), forall (boundary_point : forall (b : Boundary), Manifold), forall (DifferentialForm : Sort v), forall (boundary_integral : Scalar), forall (interior_integral : Scalar), forall (BoundaryRegularityLaw : Prop), forall (OrientationCompatibilityLaw : Prop), forall (SmoothFormLaw : Prop), forall (ExteriorDerivativeLaw : Prop), forall (StokesConclusion : Prop), Prop :=
  fun Scalar => fun Manifold => fun Boundary => fun boundary_point => fun DifferentialForm => fun boundary_integral => fun interior_integral => fun BoundaryRegularityLaw => fun OrientationCompatibilityLaw => fun SmoothFormLaw => fun ExteriorDerivativeLaw => fun StokesConclusion => forall (P : Prop), forall (mk : forall (boundary_data : @VectorCalculusBoundaryData.{u,v,w} Scalar Manifold Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw), forall (smooth_form_law : SmoothFormLaw), forall (exterior_derivative_law : ExteriorDerivativeLaw), forall (stokes_route : @VectorCalculusBoundaryData.{u,v,w} Scalar Manifold Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw -> SmoothFormLaw -> ExteriorDerivativeLaw -> StokesConclusion), P), P

theorem vector_calculus_boundary_data_intro.{u,v,w} :
  forall (Scalar : Sort u), forall (Domain : Sort v), forall (Boundary : Sort w), forall (boundary_point : forall (b : Boundary), Domain), forall (BoundaryRegularityLaw : Prop), forall (OrientationCompatibilityLaw : Prop), forall (boundary_regularity_law : BoundaryRegularityLaw), forall (orientation_compatibility_law : OrientationCompatibilityLaw), @VectorCalculusBoundaryData.{u,v,w} Scalar Domain Boundary boundary_point BoundaryRegularityLaw OrientationCompatibilityLaw :=
  fun Scalar => fun Domain => fun Boundary => fun boundary_point => fun BoundaryRegularityLaw => fun OrientationCompatibilityLaw => fun boundary_regularity_law => fun orientation_compatibility_law => fun (P : Prop) => fun (mk : forall (boundary_regularity_law : BoundaryRegularityLaw), forall (orientation_compatibility_law : OrientationCompatibilityLaw), P) => mk boundary_regularity_law orientation_compatibility_law


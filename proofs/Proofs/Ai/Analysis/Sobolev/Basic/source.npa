theorem weak_derivative_data_intro :
  forall (DistributionTestFunctionLaw : Prop), forall (IntegrationByPartsLaw : Prop), forall (MeasureFoundationLaw : Prop), forall (DerivativeCompatibilityLaw : Prop), forall (WeakDerivativeEvidence : Prop), forall (route : DistributionTestFunctionLaw -> IntegrationByPartsLaw -> MeasureFoundationLaw -> DerivativeCompatibilityLaw -> WeakDerivativeEvidence), forall (ha : DistributionTestFunctionLaw), forall (hb : IntegrationByPartsLaw), forall (hc : MeasureFoundationLaw), forall (hd : DerivativeCompatibilityLaw), WeakDerivativeEvidence :=
  fun A => fun B => fun C => fun D => fun Conclusion => fun route => fun ha => fun hb => fun hc => fun hd => route ha hb hc hd


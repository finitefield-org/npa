  forall (SobolevSpaceEvidence : Prop), forall (DomainBoundednessLaw : Prop), forall (BoundaryTraceOrZeroMeanLaw : Prop), forall (CompactnessOrPathLaw : Prop), forall (PoincareInequalityConclusion : Prop), forall (route : SobolevSpaceEvidence -> DomainBoundednessLaw -> BoundaryTraceOrZeroMeanLaw -> CompactnessOrPathLaw -> PoincareInequalityConclusion), forall (ha : SobolevSpaceEvidence), forall (hb : DomainBoundednessLaw), forall (hc : BoundaryTraceOrZeroMeanLaw), forall (hd : CompactnessOrPathLaw), PoincareInequalityConclusion :=
  fun A => fun B => fun C => fun D => fun Conclusion => fun route => fun ha => fun hb => fun hc => fun hd => route ha hb hc hd


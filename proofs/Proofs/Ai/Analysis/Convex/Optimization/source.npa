theorem convex_set_data_intro :
  forall (AffineCombinationLaw : Prop), forall (ConvexityClosureLaw : Prop), forall (TopologyCompatibilityLaw : Prop), forall (TangentConeVocabularyLaw : Prop), forall (ConvexSetEvidence : Prop), forall (route : AffineCombinationLaw -> ConvexityClosureLaw -> TopologyCompatibilityLaw -> TangentConeVocabularyLaw -> ConvexSetEvidence), forall (ha : AffineCombinationLaw), forall (hb : ConvexityClosureLaw), forall (hc : TopologyCompatibilityLaw), forall (hd : TangentConeVocabularyLaw), ConvexSetEvidence :=
  fun A => fun B => fun C => fun D => fun Conclusion => fun route => fun ha => fun hb => fun hc => fun hd => route ha hb hc hd


theorem mountain_pass_late_batch_plan :
  forall (CriticalPointVocabularyLaw : Prop), forall (PalaisSmalePrerequisiteLaw : Prop), forall (FunctionSpaceTopologyLaw : Prop), forall (NoPrematureMountainPassCertificateLaw : Prop), forall (MountainPassLateBatchPlanConclusion : Prop), forall (route : CriticalPointVocabularyLaw -> PalaisSmalePrerequisiteLaw -> FunctionSpaceTopologyLaw -> NoPrematureMountainPassCertificateLaw -> MountainPassLateBatchPlanConclusion), forall (ha : CriticalPointVocabularyLaw), forall (hb : PalaisSmalePrerequisiteLaw), forall (hc : FunctionSpaceTopologyLaw), forall (hd : NoPrematureMountainPassCertificateLaw), MountainPassLateBatchPlanConclusion :=
  fun A => fun B => fun C => fun D => fun Conclusion => fun route => fun ha => fun hb => fun hc => fun hd => route ha hb hc hd

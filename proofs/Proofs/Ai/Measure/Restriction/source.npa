def MeasureRestrictionInterface.{i,u,v} :
  forall (X : Sort u), forall (isMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (restrictedMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (Value : Sort v), forall (zero : Value), forall (add : forall (left : Value), forall (right : Value), Value), forall (subtract : forall (left : Value), forall (right : Value), Value), forall (countableSum : forall (Index : Sort i), forall (values : forall (idx : Index), Value), Value), forall (leq : forall (left : Value), forall (right : Value), Prop), forall (valueEq : forall (left : Value), forall (right : Value), Prop), forall (FiniteValue : forall (value : Value), Prop), forall (measure : forall (subset : forall (x : X), Prop), Value), forall (restrictedMeasure : forall (subset : forall (x : X), Prop), Value), Prop :=
  fun X => fun isMeasurable => fun restrictedMeasurable => fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq => fun valueEq => fun FiniteValue => fun measure => fun restrictedMeasure => forall (P : Prop), forall (mk : forall (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure), forall (restricted_measure_space_law : @MeasureSpace.{i,u,v} X restrictedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue restrictedMeasure), forall (restricted_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), isMeasurable subset), forall (restricted_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), valueEq (restrictedMeasure subset) (measure subset)), P), P

theorem measure_restriction_interface_intro.{i,u,v} :
  forall (X : Sort u), forall (isMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (restrictedMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (Value : Sort v), forall (zero : Value), forall (add : forall (left : Value), forall (right : Value), Value), forall (subtract : forall (left : Value), forall (right : Value), Value), forall (countableSum : forall (Index : Sort i), forall (values : forall (idx : Index), Value), Value), forall (leq : forall (left : Value), forall (right : Value), Prop), forall (valueEq : forall (left : Value), forall (right : Value), Prop), forall (FiniteValue : forall (value : Value), Prop), forall (measure : forall (subset : forall (x : X), Prop), Value), forall (restrictedMeasure : forall (subset : forall (x : X), Prop), Value), forall (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure), forall (restricted_measure_space_law : @MeasureSpace.{i,u,v} X restrictedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue restrictedMeasure), forall (restricted_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), isMeasurable subset), forall (restricted_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), valueEq (restrictedMeasure subset) (measure subset)), @MeasureRestrictionInterface.{i,u,v} X isMeasurable restrictedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure restrictedMeasure :=
  fun X => fun isMeasurable => fun restrictedMeasurable => fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq => fun valueEq => fun FiniteValue => fun measure => fun restrictedMeasure => fun base_measure_law => fun restricted_measure_space_law => fun restricted_sets_measurable_law => fun restricted_measure_agrees_law => fun (P : Prop) => fun (mk : forall (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure), forall (restricted_measure_space_law : @MeasureSpace.{i,u,v} X restrictedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue restrictedMeasure), forall (restricted_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), isMeasurable subset), forall (restricted_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), valueEq (restrictedMeasure subset) (measure subset)), P) => mk base_measure_law restricted_measure_space_law restricted_sets_measurable_law restricted_measure_agrees_law

theorem measure_restriction_agrees_on_restricted_sets.{i,u,v} :
  forall (X : Sort u), forall (isMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (restrictedMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (Value : Sort v), forall (zero : Value), forall (add : forall (left : Value), forall (right : Value), Value), forall (subtract : forall (left : Value), forall (right : Value), Value), forall (countableSum : forall (Index : Sort i), forall (values : forall (idx : Index), Value), Value), forall (leq : forall (left : Value), forall (right : Value), Prop), forall (valueEq : forall (left : Value), forall (right : Value), Prop), forall (FiniteValue : forall (value : Value), Prop), forall (measure : forall (subset : forall (x : X), Prop), Value), forall (restrictedMeasure : forall (subset : forall (x : X), Prop), Value), forall (restriction : @MeasureRestrictionInterface.{i,u,v} X isMeasurable restrictedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure restrictedMeasure), forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), valueEq (restrictedMeasure subset) (measure subset) :=
  fun X => fun isMeasurable => fun restrictedMeasurable => fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq => fun valueEq => fun FiniteValue => fun measure => fun restrictedMeasure => fun restriction => fun subset => fun restricted_subset_measurable => restriction (valueEq (restrictedMeasure subset) (measure subset)) (fun (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure) => fun (restricted_measure_space_law : @MeasureSpace.{i,u,v} X restrictedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue restrictedMeasure) => fun (restricted_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), isMeasurable subset) => fun (restricted_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (restricted_subset_measurable : restrictedMeasurable subset), valueEq (restrictedMeasure subset) (measure subset)) => restricted_measure_agrees_law subset restricted_subset_measurable)

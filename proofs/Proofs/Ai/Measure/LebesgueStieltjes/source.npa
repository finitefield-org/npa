forall (distributionFunction : forall (x : RealLine), Value),
forall (stieltjesMeasure : forall (subset : forall (x : RealLine), Prop), Value),
forall (construction : @LebesgueStieltjesConstruction.{i,r,v} RealLine Value zero add subtract countableSum leqValue valueEq FiniteValue leqReal stieltjesMeasurable intervalSeed distributionFunction stieltjesMeasure),
@MeasureSpace.{i,r,v} RealLine stieltjesMeasurable Value zero add subtract countableSum leqValue valueEq FiniteValue stieltjesMeasure :=
  fun RealLine => fun Value => fun zero => fun add => fun subtract => fun countableSum =>
fun leqValue => fun valueEq => fun FiniteValue => fun leqReal => fun stieltjesMeasurable =>
fun intervalSeed => fun distributionFunction => fun stieltjesMeasure => fun construction =>
construction (@MeasureSpace.{i,r,v} RealLine stieltjesMeasurable Value zero add subtract countableSum leqValue valueEq FiniteValue stieltjesMeasure)
(fun (distribution_function_law : @DistributionFunctionInterface.{r,v} RealLine Value leqReal leqValue valueEq distributionFunction) =>
fun (generated_stieltjes_sigma_law : @GeneratedSigmaAlgebra.{i,r} RealLine intervalSeed stieltjesMeasurable) =>
fun (measure_space_law : @MeasureSpace.{i,r,v} RealLine stieltjesMeasurable Value zero add subtract countableSum leqValue valueEq FiniteValue stieltjesMeasure) =>
fun (interval_measure_increment_law : forall (left : RealLine), forall (right : RealLine), forall (order_law : leqReal left right), Prop) =>
fun (uniqueness_law : @SigmaFiniteExtensionUniqueness.{i,r,v} RealLine intervalSeed stieltjesMeasurable Value zero add subtract countableSum leqValue valueEq FiniteValue stieltjesMeasure stieltjesMeasure) =>
fun (atom_jump_law : forall (point : RealLine), Prop) =>

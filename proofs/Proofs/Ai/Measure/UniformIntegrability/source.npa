def UniformIntegrability.{n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (family : forall (idx : Index), forall (x : Domain), Value), Prop :=
  fun Domain => fun Value => fun Index => fun family => forall (P : Prop), forall (mk : forall (uniform_tail_small_law : Prop), forall (de_la_vallee_poussin_route_law : Prop), P), P

def DeLaValleePoussinCriterion.{n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (family : forall (idx : Index), forall (x : Domain), Value), Prop :=
  fun Domain => fun Value => fun Index => fun family => forall (P : Prop), forall (mk : forall (convex_growth_function_law : Prop), forall (uniform_orlicz_bound_law : Prop), forall (criterion_implies_uniform_integrability_law : @UniformIntegrability.{n,u,v} Domain Value Index family), P), P

def EgorovLusinPrerequisites.{i,n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (valueMeasurable : forall (subset : forall (value : Value), Prop), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), Prop :=
  fun Domain => fun Value => fun Index => fun domainMeasurable => fun valueMeasurable => fun sequence => fun target => forall (P : Prop), forall (mk : forall (finite_measure_law : Prop), forall (target_topology_law : Prop), forall (regularity_or_lusin_topology_law : Prop), forall (target_measurable_law : @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable target), forall (sequence_measurable_law : forall (idx : Index), @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable (sequence idx)), P), P

theorem uniform_integrability_from_de_la_vallee_poussin.{n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (family : forall (idx : Index), forall (x : Domain), Value), forall (criterion : @DeLaValleePoussinCriterion.{n,u,v} Domain Value Index family), @UniformIntegrability.{n,u,v} Domain Value Index family :=
  fun Domain => fun Value => fun Index => fun family => fun criterion => criterion (@UniformIntegrability.{n,u,v} Domain Value Index family) (fun (convex_growth_function_law : Prop) => fun (uniform_orlicz_bound_law : Prop) => fun (criterion_implies_uniform_integrability_law : @UniformIntegrability.{n,u,v} Domain Value Index family) => criterion_implies_uniform_integrability_law)

theorem vitali_convergence_from_uniform_integrability_and_measure_convergence.{m,n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (MeasureValue : Sort m), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (measureOf : forall (subset : forall (x : Domain), Prop), MeasureValue), forall (TendsToZero : forall (measure_sequence : forall (idx : Index), MeasureValue), Prop), forall (distanceGreaterThan : forall (epsilon : Value), forall (candidate : forall (x : Domain), Value), forall (target : forall (x : Domain), Value), forall (x : Domain), Prop), forall (family : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), forall (uniform_integrability : @UniformIntegrability.{n,u,v} Domain Value Index family), forall (convergence_in_measure : @ConvergenceInMeasure.{m,n,u,v} Domain Value Index MeasureValue domainMeasurable measureOf TendsToZero distanceGreaterThan family target), forall (VitaliConclusion : Prop), forall (vitali_route : @UniformIntegrability.{n,u,v} Domain Value Index family -> @ConvergenceInMeasure.{m,n,u,v} Domain Value Index MeasureValue domainMeasurable measureOf TendsToZero distanceGreaterThan family target -> VitaliConclusion), VitaliConclusion :=
  fun Domain => fun Value => fun Index => fun MeasureValue => fun domainMeasurable => fun measureOf => fun TendsToZero => fun distanceGreaterThan => fun family => fun target => fun uniform_integrability => fun convergence_in_measure => fun VitaliConclusion => fun vitali_route => vitali_route uniform_integrability convergence_in_measure

theorem scheffe_from_dominated_convergence :
  forall (DominatedConvergenceConclusion : Prop), forall (mass_convergence_law : Prop), forall (ScheffeConclusion : Prop), forall (scheffe_route : forall (dominated_convergence : DominatedConvergenceConclusion), forall (mass_convergence_law : Prop), ScheffeConclusion), forall (dominated_convergence : DominatedConvergenceConclusion), ScheffeConclusion :=
  fun DominatedConvergenceConclusion => fun mass_convergence_law => fun ScheffeConclusion => fun scheffe_route => fun dominated_convergence => scheffe_route dominated_convergence mass_convergence_law

theorem egorov_lusin_from_finite_measure_topology.{i,n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (valueMeasurable : forall (subset : forall (value : Value), Prop), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), forall (prerequisites : @EgorovLusinPrerequisites.{i,n,u,v} Domain Value Index domainMeasurable valueMeasurable sequence target), forall (EgorovLusinConclusion : Prop), forall (route : forall (finite_measure_law : Prop), forall (target_topology_law : Prop), forall (regularity_or_lusin_topology_law : Prop), forall (target_measurable_law : @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable target), forall (sequence_measurable_law : forall (idx : Index), @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable (sequence idx)), EgorovLusinConclusion), EgorovLusinConclusion :=
  fun Domain => fun Value => fun Index => fun domainMeasurable => fun valueMeasurable => fun sequence => fun target => fun prerequisites => fun EgorovLusinConclusion => fun route => prerequisites EgorovLusinConclusion (fun (finite_measure_law : Prop) => fun (target_topology_law : Prop) => fun (regularity_or_lusin_topology_law : Prop) => fun (target_measurable_law : @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable target) => fun (sequence_measurable_law : forall (idx : Index), @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable (sequence idx)) => route finite_measure_law target_topology_law regularity_or_lusin_topology_law target_measurable_law sequence_measurable_law)

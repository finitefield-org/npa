fun (fourier_and_sobolev_not_derived_before_prerequisites_law : Prop) => route riesz_thorin_interpolation_law marcinkiewicz_interpolation_law hausdorff_young_interface_law plancherel_interface_law sobolev_interface_law rellich_kondrachov_interface_law fourier_and_sobolev_not_derived_before_prerequisites_law)

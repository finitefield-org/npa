forall (NonnegativeValue : forall (value : Value), Prop),
forall (simpleIntegral : forall (map : forall (point : Product), Value), IntegralValue),
forall (nonnegativeIntegral : forall (map : forall (point : Product), Value), IntegralValue),
forall (leftIteratedIntegral : forall (map : forall (point : Product), Value), IntegralValue),
forall (rightIteratedIntegral : forall (map : forall (point : Product), Value), IntegralValue),
forall (map : forall (point : Product), Value),

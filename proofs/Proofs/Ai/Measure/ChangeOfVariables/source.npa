theorem measure_preserving_pushforward_formula.{i,m,u,v} :
  forall (Source : Sort u), forall (Target : Sort v),
forall (sourceMeasurable : forall (subset : forall (x : Source), Prop), Prop),
forall (targetMeasurable : forall (subset : forall (y : Target), Prop), Prop),
forall (Value : Sort m), forall (zero : Value),
forall (add : forall (left : Value), forall (right : Value), Value),
forall (subtract : forall (left : Value), forall (right : Value), Value),
forall (countableSum : forall (Index : Sort i), forall (values : forall (idx : Index), Value), Value),
forall (leq : forall (left : Value), forall (right : Value), Prop),
forall (valueEq : forall (left : Value), forall (right : Value), Prop),
forall (FiniteValue : forall (value : Value), Prop),
forall (sourceMeasure : forall (subset : forall (x : Source), Prop), Value),
forall (targetMeasure : forall (subset : forall (y : Target), Prop), Value),
forall (map : forall (x : Source), Target),
forall (preserving : @MeasurePreservingMapPackage.{i,m,u,v} Source Target sourceMeasurable targetMeasurable Value zero add subtract countableSum leq valueEq FiniteValue sourceMeasure targetMeasure map),
forall (targetSet : forall (y : Target), Prop), forall (target_set_measurable : targetMeasurable targetSet),
valueEq (targetMeasure targetSet) (sourceMeasure (@MapPreimage.{u,v} Source Target map targetSet)) :=
  fun Source => fun Target => fun sourceMeasurable => fun targetMeasurable =>
fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq =>
fun valueEq => fun FiniteValue => fun sourceMeasure => fun targetMeasure => fun map =>
fun preserving => fun targetSet => fun target_set_measurable =>
preserving (valueEq (targetMeasure targetSet) (sourceMeasure (@MapPreimage.{u,v} Source Target map targetSet)))
(fun (source_measure_space_law : @MeasureSpace.{i,u,m} Source sourceMeasurable Value zero add subtract countableSum leq valueEq FiniteValue sourceMeasure) =>
fun (target_measure_space_law : @MeasureSpace.{i,v,m} Target targetMeasurable Value zero add subtract countableSum leq valueEq FiniteValue targetMeasure) =>
fun (measurable_map_law : @MeasurableFunction.{i,u,v} Source Target sourceMeasurable targetMeasurable map) =>
fun (measure_preserving_law : forall (targetSet : forall (y : Target), Prop), forall (target_set_measurable : targetMeasurable targetSet), valueEq (targetMeasure targetSet) (sourceMeasure (@MapPreimage.{u,v} Source Target map targetSet))) =>
fun (pushforward_identity_law : @PushforwardMeasurePackage.{i,m,u,v} Source Target sourceMeasurable targetMeasurable Value zero add subtract countableSum leq valueEq FiniteValue sourceMeasure targetMeasure map) =>

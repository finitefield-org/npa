  fun Source => fun Target => fun sourceMeasurable => fun targetMeasurable =>
fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq =>
fun valueEq => fun FiniteValue => fun sourceMeasure => fun targetMeasure => fun map =>

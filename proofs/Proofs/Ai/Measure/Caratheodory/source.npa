def CaratheodorySplitCriterion.{u,v} :
  forall (X : Sort u), forall (Value : Sort v), forall (add : forall (left : Value), forall (right : Value), Value), forall (valueEq : forall (left : Value), forall (right : Value), Prop), forall (outerMeasure : forall (subset : forall (x : X), Prop), Value), forall (subset : forall (x : X), Prop), Prop :=
  fun X => fun Value => fun add => fun valueEq => fun outerMeasure => fun subset => forall (testSet : forall (x : X), Prop), valueEq (outerMeasure testSet) (add (outerMeasure (@SetIntersection.{u} X testSet subset)) (outerMeasure (@SetDifference.{u} X testSet subset)))


def MeasureCompletionL1.{i,u,v} :
  forall (X : Sort u), forall (isMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (completedMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (Value : Sort v), forall (zero : Value), forall (add : forall (left : Value), forall (right : Value), Value), forall (subtract : forall (left : Value), forall (right : Value), Value), forall (countableSum : forall (Index : Sort i), forall (values : forall (idx : Index), Value), Value), forall (leq : forall (left : Value), forall (right : Value), Prop), forall (valueEq : forall (left : Value), forall (right : Value), Prop), forall (FiniteValue : forall (value : Value), Prop), forall (measure : forall (subset : forall (x : X), Prop), Value), forall (completedMeasure : forall (subset : forall (x : X), Prop), Value), Prop :=
  fun X => fun isMeasurable => fun completedMeasurable => fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq => fun valueEq => fun FiniteValue => fun measure => fun completedMeasure => forall (P : Prop), forall (mk : forall (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure), forall (completed_measurable_space_law : @MeasurableSpace.{i,u} X completedMeasurable), forall (original_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), completedMeasurable subset), forall (null_subset_measurable_hook : forall (nullSet : forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (null_measurable : isMeasurable nullSet), forall (null_measure_law : valueEq (measure nullSet) zero), forall (subset_in_null : @SetInclusion.{u} X subset nullSet), completedMeasurable subset), forall (completed_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), valueEq (completedMeasure subset) (measure subset)), forall (completion_l1_boundary_law : Prop), P), P

theorem measure_completion_l1_intro.{i,u,v} :
  forall (X : Sort u), forall (isMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (completedMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (Value : Sort v), forall (zero : Value), forall (add : forall (left : Value), forall (right : Value), Value), forall (subtract : forall (left : Value), forall (right : Value), Value), forall (countableSum : forall (Index : Sort i), forall (values : forall (idx : Index), Value), Value), forall (leq : forall (left : Value), forall (right : Value), Prop), forall (valueEq : forall (left : Value), forall (right : Value), Prop), forall (FiniteValue : forall (value : Value), Prop), forall (measure : forall (subset : forall (x : X), Prop), Value), forall (completedMeasure : forall (subset : forall (x : X), Prop), Value), forall (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure), forall (completed_measurable_space_law : @MeasurableSpace.{i,u} X completedMeasurable), forall (original_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), completedMeasurable subset), forall (null_subset_measurable_hook : forall (nullSet : forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (null_measurable : isMeasurable nullSet), forall (null_measure_law : valueEq (measure nullSet) zero), forall (subset_in_null : @SetInclusion.{u} X subset nullSet), completedMeasurable subset), forall (completed_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), valueEq (completedMeasure subset) (measure subset)), forall (completion_l1_boundary_law : Prop), @MeasureCompletionL1.{i,u,v} X isMeasurable completedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure completedMeasure :=
  fun X => fun isMeasurable => fun completedMeasurable => fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq => fun valueEq => fun FiniteValue => fun measure => fun completedMeasure => fun base_measure_law => fun completed_measurable_space_law => fun original_sets_measurable_law => fun null_subset_measurable_hook => fun completed_measure_agrees_law => fun completion_l1_boundary_law => fun (P : Prop) => fun (mk : forall (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure), forall (completed_measurable_space_law : @MeasurableSpace.{i,u} X completedMeasurable), forall (original_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), completedMeasurable subset), forall (null_subset_measurable_hook : forall (nullSet : forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (null_measurable : isMeasurable nullSet), forall (null_measure_law : valueEq (measure nullSet) zero), forall (subset_in_null : @SetInclusion.{u} X subset nullSet), completedMeasurable subset), forall (completed_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), valueEq (completedMeasure subset) (measure subset)), forall (completion_l1_boundary_law : Prop), P) => mk base_measure_law completed_measurable_space_law original_sets_measurable_law null_subset_measurable_hook completed_measure_agrees_law completion_l1_boundary_law

theorem measure_completion_null_subset_measurable_l1_hook.{i,u,v} :
  forall (X : Sort u), forall (isMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (completedMeasurable : forall (subset : forall (x : X), Prop), Prop), forall (Value : Sort v), forall (zero : Value), forall (add : forall (left : Value), forall (right : Value), Value), forall (subtract : forall (left : Value), forall (right : Value), Value), forall (countableSum : forall (Index : Sort i), forall (values : forall (idx : Index), Value), Value), forall (leq : forall (left : Value), forall (right : Value), Prop), forall (valueEq : forall (left : Value), forall (right : Value), Prop), forall (FiniteValue : forall (value : Value), Prop), forall (measure : forall (subset : forall (x : X), Prop), Value), forall (completedMeasure : forall (subset : forall (x : X), Prop), Value), forall (completion : @MeasureCompletionL1.{i,u,v} X isMeasurable completedMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure completedMeasure), forall (nullSet : forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (null_measurable : isMeasurable nullSet), forall (null_measure_law : valueEq (measure nullSet) zero), forall (subset_in_null : @SetInclusion.{u} X subset nullSet), completedMeasurable subset :=
  fun X => fun isMeasurable => fun completedMeasurable => fun Value => fun zero => fun add => fun subtract => fun countableSum => fun leq => fun valueEq => fun FiniteValue => fun measure => fun completedMeasure => fun completion => fun nullSet => fun subset => fun null_measurable => fun null_measure_law => fun subset_in_null => completion (completedMeasurable subset) (fun (base_measure_law : @MeasureSpace.{i,u,v} X isMeasurable Value zero add subtract countableSum leq valueEq FiniteValue measure) => fun (completed_measurable_space_law : @MeasurableSpace.{i,u} X completedMeasurable) => fun (original_sets_measurable_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), completedMeasurable subset) => fun (null_subset_measurable_hook : forall (nullSet : forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (null_measurable : isMeasurable nullSet), forall (null_measure_law : valueEq (measure nullSet) zero), forall (subset_in_null : @SetInclusion.{u} X subset nullSet), completedMeasurable subset) => fun (completed_measure_agrees_law : forall (subset : forall (x : X), Prop), forall (subset_measurable : isMeasurable subset), valueEq (completedMeasure subset) (measure subset)) => fun (completion_l1_boundary_law : Prop) => null_subset_measurable_hook nullSet subset null_measurable null_measure_law subset_in_null)

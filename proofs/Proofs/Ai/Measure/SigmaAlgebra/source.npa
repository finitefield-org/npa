  forall (RealLine : Sort u), forall (isOpen : forall (subset : forall (x : RealLine), Prop), Prop), forall (borel : forall (subset : forall (x : RealLine), Prop), Prop), forall (IntervalSeed : forall (subset : forall (x : RealLine), Prop), Prop), forall (borel_law : @BorelSigmaAlgebra.{i,u} RealLine isOpen borel), forall (interval_seed_law : forall (subset : forall (x : RealLine), Prop), forall (interval_seed_member : IntervalSeed subset), borel subset), forall (topology_dependency_law : @TopologicalSpaceLawPackage.{i,u} RealLine isOpen), forall (no_lebesgue_measure_dependency : Prop), @RealLineBorelGeneratorHook.{i,u} RealLine isOpen borel IntervalSeed :=
  fun RealLine => fun isOpen => fun borel => fun IntervalSeed => fun borel_law => fun interval_seed_law => fun topology_dependency_law => fun no_lebesgue_measure_dependency => fun (P : Prop) => fun (mk : forall (borel_law : @BorelSigmaAlgebra.{i,u} RealLine isOpen borel), forall (interval_seed_law : forall (subset : forall (x : RealLine), Prop), forall (interval_seed_member : IntervalSeed subset), borel subset), forall (topology_dependency_law : @TopologicalSpaceLawPackage.{i,u} RealLine isOpen), forall (no_lebesgue_measure_dependency : Prop), P) => mk borel_law interval_seed_law topology_dependency_law no_lebesgue_measure_dependency


  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (borel : forall (subset : forall (x : X), Prop), Prop), forall (law : @BorelSigmaAlgebra.{i,u} X isOpen borel), forall (subset : forall (x : X), Prop), forall (open_member : isOpen subset), borel subset :=

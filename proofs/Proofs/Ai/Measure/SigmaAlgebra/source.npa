theorem generated_sigma_algebra_core.{i,u} :
  forall (X : Sort u), forall (SeedFamily : forall (subset : forall (x : X), Prop), Prop), forall (generated : forall (subset : forall (x : X), Prop), Prop), forall (law : @GeneratedSigmaAlgebra.{i,u} X SeedFamily generated), @SigmaAlgebraCore.{i,u} X generated :=
  fun X => fun SeedFamily => fun generated => fun law => law (@SigmaAlgebraCore.{i,u} X generated) (fun (generated_core_law : @SigmaAlgebraCore.{i,u} X generated) => fun (seed_inclusion_law : forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), generated subset) => fun (minimality_law : forall (other : forall (subset : forall (x : X), Prop), Prop), forall (other_core_law : @SigmaAlgebraCore.{i,u} X other), forall (other_contains_seed : forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), other subset), forall (subset : forall (x : X), Prop), forall (generated_member : generated subset), other subset) => generated_core_law)

theorem generated_sigma_algebra_seed_subset.{i,u} :
  forall (X : Sort u), forall (SeedFamily : forall (subset : forall (x : X), Prop), Prop), forall (generated : forall (subset : forall (x : X), Prop), Prop), forall (law : @GeneratedSigmaAlgebra.{i,u} X SeedFamily generated), forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), generated subset :=
  fun X => fun SeedFamily => fun generated => fun law => fun subset => fun seed_member => law (generated subset) (fun (generated_core_law : @SigmaAlgebraCore.{i,u} X generated) => fun (seed_inclusion_law : forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), generated subset) => fun (minimality_law : forall (other : forall (subset : forall (x : X), Prop), Prop), forall (other_core_law : @SigmaAlgebraCore.{i,u} X other), forall (other_contains_seed : forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), other subset), forall (subset : forall (x : X), Prop), forall (generated_member : generated subset), other subset) => seed_inclusion_law subset seed_member)

theorem generated_sigma_algebra_minimal.{i,u} :
  forall (X : Sort u), forall (SeedFamily : forall (subset : forall (x : X), Prop), Prop), forall (generated : forall (subset : forall (x : X), Prop), Prop), forall (law : @GeneratedSigmaAlgebra.{i,u} X SeedFamily generated), forall (other : forall (subset : forall (x : X), Prop), Prop), forall (other_core_law : @SigmaAlgebraCore.{i,u} X other), forall (other_contains_seed : forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), other subset), forall (subset : forall (x : X), Prop), forall (generated_member : generated subset), other subset :=
  fun X => fun SeedFamily => fun generated => fun law => fun other => fun other_core_law => fun other_contains_seed => fun subset => fun generated_member => law (other subset) (fun (generated_core_law : @SigmaAlgebraCore.{i,u} X generated) => fun (seed_inclusion_law : forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), generated subset) => fun (minimality_law : forall (other : forall (subset : forall (x : X), Prop), Prop), forall (other_core_law : @SigmaAlgebraCore.{i,u} X other), forall (other_contains_seed : forall (subset : forall (x : X), Prop), forall (seed_member : SeedFamily subset), other subset), forall (subset : forall (x : X), Prop), forall (generated_member : generated subset), other subset) => minimality_law other other_core_law other_contains_seed subset generated_member)

theorem borel_sigma_algebra_intro.{i,u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (borel : forall (subset : forall (x : X), Prop), Prop), forall (topology_law : @TopologicalSpaceLawPackage.{i,u} X isOpen), forall (borel_core_law : @SigmaAlgebraCore.{i,u} X borel), forall (open_seed_law : forall (subset : forall (x : X), Prop), forall (open_member : isOpen subset), borel subset), forall (borel_minimality_law : forall (other : forall (subset : forall (x : X), Prop), Prop), forall (other_core_law : @SigmaAlgebraCore.{i,u} X other), forall (other_contains_open : forall (subset : forall (x : X), Prop), forall (open_member : isOpen subset), other subset), forall (subset : forall (x : X), Prop), forall (borel_member : borel subset), other subset), @BorelSigmaAlgebra.{i,u} X isOpen borel :=
  fun X => fun isOpen => fun borel => fun topology_law => fun borel_core_law => fun open_seed_law => fun borel_minimality_law => fun (P : Prop) => fun (mk : forall (topology_law : @TopologicalSpaceLawPackage.{i,u} X isOpen), forall (borel_core_law : @SigmaAlgebraCore.{i,u} X borel), forall (open_seed_law : forall (subset : forall (x : X), Prop), forall (open_member : isOpen subset), borel subset), forall (borel_minimality_law : forall (other : forall (subset : forall (x : X), Prop), Prop), forall (other_core_law : @SigmaAlgebraCore.{i,u} X other), forall (other_contains_open : forall (subset : forall (x : X), Prop), forall (open_member : isOpen subset), other subset), forall (subset : forall (x : X), Prop), forall (borel_member : borel subset), other subset), P) => mk topology_law borel_core_law open_seed_law borel_minimality_law

theorem borel_sigma_algebra_topology.{i,u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (borel : forall (subset : forall (x : X), Prop), Prop), forall (law : @BorelSigmaAlgebra.{i,u} X isOpen borel), @TopologicalSpaceLawPackage.{i,u} X isOpen :=

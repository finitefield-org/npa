def CountableIntersection.{i,u} :
  forall (X : Sort u), forall (Index : Sort i), forall (family : forall (idx : Index), forall (x : X), Prop), forall (x : X), Prop :=
  fun X => fun Index => fun family => @SetComplement.{u} X (@IndexedUnion.{i,u} X Index (fun (idx : Index) => @SetComplement.{u} X (family idx)))

def SetDifference.{u} :

  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (borel : forall (subset : forall (x : X), Prop), Prop), forall (law : @BorelSigmaAlgebra.{i,u} X isOpen borel), forall (other : forall (subset : forall (x : X), Prop), Prop), forall (other_core_law : @SigmaAlgebraCore.{i,u} X other), forall (other_contains_open : forall (subset : forall (x : X), Prop), forall (open_member : isOpen subset), other subset), forall (subset : forall (x : X), Prop), forall (borel_member : borel subset), other subset :=

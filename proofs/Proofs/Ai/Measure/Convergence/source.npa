def MeasureConvergenceSubsequencePackage.{m,n,s,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (SubIndex : Sort s), forall (MeasureValue : Sort m), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (measureZero : forall (subset : forall (x : Domain), Prop), Prop), forall (measureOf : forall (subset : forall (x : Domain), Prop), MeasureValue), forall (TendsToZero : forall (measure_sequence : forall (idx : Index), MeasureValue), Prop), forall (ConvergesPointwise : forall (sequence : forall (idx : SubIndex), Value), forall (limit : Value), Prop), forall (distanceGreaterThan : forall (epsilon : Value), forall (candidate : forall (x : Domain), Value), forall (target : forall (x : Domain), Value), forall (x : Domain), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), Prop :=

  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (MeasureValue : Sort m), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (measureOf : forall (subset : forall (x : Domain), Prop), MeasureValue), forall (TendsToZero : forall (measure_sequence : forall (idx : Index), MeasureValue), Prop), forall (distanceGreaterThan : forall (epsilon : Value), forall (candidate : forall (x : Domain), Value), forall (target : forall (x : Domain), Value), forall (x : Domain), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), Prop :=
  fun Domain => fun Value => fun Index => fun MeasureValue => fun domainMeasurable => fun measureOf => fun TendsToZero => fun distanceGreaterThan => fun sequence => fun target => forall (P : Prop), forall (mk : forall (measure_space_named_law : Prop), forall (epsilon_set_measurable_law : forall (epsilon : Value), forall (idx : Index), domainMeasurable (distanceGreaterThan epsilon (sequence idx) target)), forall (measure_small_law : forall (epsilon : Value), TendsToZero (fun (idx : Index) => measureOf (distanceGreaterThan epsilon (sequence idx) target))), P), P

def L1Convergence.{m,n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (IntegralValue : Sort m), forall (integralOfDifference : forall (candidate : forall (x : Domain), Value), forall (target : forall (x : Domain), Value), IntegralValue), forall (TendsToZeroIntegral : forall (values : forall (idx : Index), IntegralValue), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), Prop :=

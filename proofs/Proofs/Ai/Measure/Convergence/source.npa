def LpConvergence.{m,n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (IntegralValue : Sort m), forall (Exponent : Sort v), forall (lpDistanceIntegral : forall (exponent : Exponent), forall (candidate : forall (x : Domain), Value), forall (target : forall (x : Domain), Value), IntegralValue), forall (TendsToZeroIntegral : forall (values : forall (idx : Index), IntegralValue), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), forall (exponent : Exponent), Prop :=

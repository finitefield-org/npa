def AlmostEverywhereConvergence.{n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (Index : Sort n), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (measureZero : forall (subset : forall (x : Domain), Prop), Prop), forall (ConvergesPointwise : forall (sequence : forall (idx : Index), Value), forall (limit : Value), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (target : forall (x : Domain), Value), Prop :=
  fun Domain => fun Value => fun Index => fun domainMeasurable => fun measureZero => fun ConvergesPointwise => fun sequence => fun target => forall (P : Prop), forall (mk : forall (null_exception_set : forall (x : Domain), Prop), forall (null_exception_measurable : domainMeasurable null_exception_set), forall (null_measure_law : measureZero null_exception_set), forall (outside_null_pointwise_law : forall (x : Domain), forall (outside : @SetComplement.{u} Domain null_exception_set x), ConvergesPointwise (fun (idx : Index) => sequence idx x) (target x)), P), P


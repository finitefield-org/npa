def GeneralIntegralValue.{m,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (positivePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (negativePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (subtract : forall (left : IntegralValue), forall (right : IntegralValue), IntegralValue), forall (map : forall (x : Domain), Value), IntegralValue :=
  fun Domain => fun Value => fun IntegralValue => fun positivePart => fun negativePart => fun nonnegativeIntegral => fun subtract => fun map => subtract (nonnegativeIntegral (positivePart map)) (nonnegativeIntegral (negativePart map))

def IntegrableFunction.{i,m,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (valueMeasurable : forall (subset : forall (value : Value), Prop), Prop), forall (positivePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (negativePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (FiniteIntegralValue : forall (value : IntegralValue), Prop), forall (map : forall (x : Domain), Value), Prop :=
  fun Domain => fun Value => fun IntegralValue => fun domainMeasurable => fun valueMeasurable => fun positivePart => fun negativePart => fun nonnegativeIntegral => fun FiniteIntegralValue => fun map => forall (P : Prop), forall (mk : forall (measurable_law : @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable map), forall (positive_part_measurable_law : @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable (positivePart map)), forall (negative_part_measurable_law : @MeasurableFunction.{i,u,v} Domain Value domainMeasurable valueMeasurable (negativePart map)), forall (finite_positive_integral_law : FiniteIntegralValue (nonnegativeIntegral (positivePart map))), forall (finite_negative_integral_law : FiniteIntegralValue (nonnegativeIntegral (negativePart map))), P), P

def GeneralIntegralLawPackage.{i,m,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (valueMeasurable : forall (subset : forall (value : Value), Prop), Prop), forall (positivePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (negativePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (subtract : forall (left : IntegralValue), forall (right : IntegralValue), IntegralValue), forall (integralEq : forall (left : IntegralValue), forall (right : IntegralValue), Prop), forall (leqIntegral : forall (left : IntegralValue), forall (right : IntegralValue), Prop), forall (measureZero : forall (subset : forall (x : Domain), Prop), Prop), Prop :=
  fun Domain => fun Value => fun IntegralValue => fun domainMeasurable => fun valueMeasurable => fun positivePart => fun negativePart => fun nonnegativeIntegral => fun subtract => fun integralEq => fun leqIntegral => fun measureZero => forall (P : Prop), forall (mk : forall (positivity_law : forall (map : forall (x : Domain), Value), Prop), forall (monotonicity_law : forall (f : forall (x : Domain), Value), forall (g : forall (x : Domain), Value), Prop), forall (linearity_law : forall (f : forall (x : Domain), Value), forall (g : forall (x : Domain), Value), Prop), forall (triangle_inequality_law : forall (map : forall (x : Domain), Value), Prop), forall (ae_equal_invariance_law : forall (f : forall (x : Domain), Value), forall (g : forall (x : Domain), Value), forall (null_exception_set : forall (x : Domain), Prop), forall (null_exception_measurable : domainMeasurable null_exception_set), forall (null_measure_law : measureZero null_exception_set), forall (outside_null_pointwise_law : forall (x : Domain), forall (outside : @SetComplement.{u} Domain null_exception_set x), @Eq.{v} Value (f x) (g x)), forall (monotonicity_route_law : Prop), integralEq (@GeneralIntegralValue.{m,u,v} Domain Value IntegralValue positivePart negativePart nonnegativeIntegral subtract f) (@GeneralIntegralValue.{m,u,v} Domain Value IntegralValue positivePart negativePart nonnegativeIntegral subtract g)), forall (restriction_measure_formula_law : Prop), forall (truncation_approximation_law : Prop), P), P

theorem general_integral_value_unfold.{m,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (positivePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (negativePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (subtract : forall (left : IntegralValue), forall (right : IntegralValue), IntegralValue), forall (map : forall (x : Domain), Value), @Eq.{m} IntegralValue (@GeneralIntegralValue.{m,u,v} Domain Value IntegralValue positivePart negativePart nonnegativeIntegral subtract map) (subtract (nonnegativeIntegral (positivePart map)) (nonnegativeIntegral (negativePart map))) :=
  fun Domain => fun Value => fun IntegralValue => fun positivePart => fun negativePart => fun nonnegativeIntegral => fun subtract => fun map => @Eq.refl.{m} IntegralValue (subtract (nonnegativeIntegral (positivePart map)) (nonnegativeIntegral (negativePart map)))

theorem general_integral_eq_from_part_integral_eqs.{m,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (positivePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (negativePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (subtract : forall (left : IntegralValue), forall (right : IntegralValue), IntegralValue), forall (subtract_congruence : forall (leftA : IntegralValue), forall (rightA : IntegralValue), forall (leftB : IntegralValue), forall (rightB : IntegralValue), forall (left_eq : @Eq.{m} IntegralValue leftA leftB), forall (right_eq : @Eq.{m} IntegralValue rightA rightB), @Eq.{m} IntegralValue (subtract leftA rightA) (subtract leftB rightB)), forall (f : forall (x : Domain), Value), forall (g : forall (x : Domain), Value), forall (positive_integral_eq : @Eq.{m} IntegralValue (nonnegativeIntegral (positivePart f)) (nonnegativeIntegral (positivePart g))), forall (negative_integral_eq : @Eq.{m} IntegralValue (nonnegativeIntegral (negativePart f)) (nonnegativeIntegral (negativePart g))), @Eq.{m} IntegralValue (@GeneralIntegralValue.{m,u,v} Domain Value IntegralValue positivePart negativePart nonnegativeIntegral subtract f) (@GeneralIntegralValue.{m,u,v} Domain Value IntegralValue positivePart negativePart nonnegativeIntegral subtract g) :=
  fun Domain => fun Value => fun IntegralValue => fun positivePart => fun negativePart => fun nonnegativeIntegral => fun subtract => fun subtract_congruence => fun f => fun g => fun positive_integral_eq => fun negative_integral_eq => subtract_congruence (nonnegativeIntegral (positivePart f)) (nonnegativeIntegral (negativePart f)) (nonnegativeIntegral (positivePart g)) (nonnegativeIntegral (negativePart g)) positive_integral_eq negative_integral_eq

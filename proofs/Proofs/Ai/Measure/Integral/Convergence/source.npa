  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (Index : Sort n), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (valueMeasurable : forall (subset : forall (value : Value), Prop), Prop), forall (leqValue : forall (left : Value), forall (right : Value), Prop), forall (positivePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (negativePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (FiniteIntegralValue : forall (value : IntegralValue), Prop), forall (absValue : forall (value : Value), Value), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (dominatingFunction : forall (x : Domain), Value), forall (dominating_integrable : @IntegrableFunction.{i,m,u,v} Domain Value IntegralValue domainMeasurable valueMeasurable positivePart negativePart nonnegativeIntegral FiniteIntegralValue dominatingFunction), forall (domination_law : forall (idx : Index), forall (x : Domain), leqValue (absValue (sequence idx x)) (dominatingFunction x)), forall (LowerFatouConclusion : Prop), forall (UpperFatouConclusion : Prop), forall (lower_fatou : LowerFatouConclusion), forall (upper_fatou : UpperFatouConclusion), forall (DominatedConvergenceConclusion : Prop), forall (dominated_route : @IntegrableFunction.{i,m,u,v} Domain Value IntegralValue domainMeasurable valueMeasurable positivePart negativePart nonnegativeIntegral FiniteIntegralValue dominatingFunction -> (forall (idx : Index), forall (x : Domain), leqValue (absValue (sequence idx x)) (dominatingFunction x)) -> LowerFatouConclusion -> UpperFatouConclusion -> DominatedConvergenceConclusion), DominatedConvergenceConclusion :=
  fun Domain => fun Value => fun IntegralValue => fun Index => fun domainMeasurable => fun valueMeasurable => fun leqValue => fun positivePart => fun negativePart => fun nonnegativeIntegral => fun FiniteIntegralValue => fun absValue => fun sequence => fun dominatingFunction => fun dominating_integrable => fun domination_law => fun LowerFatouConclusion => fun UpperFatouConclusion => fun lower_fatou => fun upper_fatou => fun DominatedConvergenceConclusion => fun dominated_route => dominated_route dominating_integrable domination_law lower_fatou upper_fatou


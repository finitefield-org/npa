def MonotoneConvergenceData.{i,m,n,u,v} :
  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (Index : Sort n), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (valueMeasurable : forall (subset : forall (value : Value), Prop), Prop), forall (leqValue : forall (left : Value), forall (right : Value), Prop), forall (leqIntegral : forall (left : IntegralValue), forall (right : IntegralValue), Prop), forall (simpleIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (NonnegativeValue : forall (value : Value), Prop), forall (IndexLe : forall (left : Index), forall (right : Index), Prop), forall (sequence : forall (idx : Index), forall (x : Domain), Value), Prop :=

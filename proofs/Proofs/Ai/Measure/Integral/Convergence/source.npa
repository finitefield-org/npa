  forall (Domain : Sort u), forall (Value : Sort v), forall (IntegralValue : Sort m), forall (Index : Sort n), forall (domainMeasurable : forall (subset : forall (x : Domain), Prop), Prop), forall (valueMeasurable : forall (subset : forall (value : Value), Prop), Prop), forall (leqValue : forall (left : Value), forall (right : Value), Prop), forall (positivePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (negativePart : forall (map : forall (x : Domain), Value), forall (x : Domain), Value), forall (nonnegativeIntegral : forall (map : forall (x : Domain), Value), IntegralValue), forall (FiniteIntegralValue : forall (value : IntegralValue), Prop), forall (absValue : forall (value : Value), Value), forall (sequence : forall (idx : Index), forall (x : Domain), Value), forall (constantDominatingFunction : forall (x : Domain), Value), forall (constant_dominating_integrable : @IntegrableFunction.{i,m,u,v} Domain Value IntegralValue domainMeasurable valueMeasurable positivePart negativePart nonnegativeIntegral FiniteIntegralValue constantDominatingFunction), forall (finite_measure_law : Prop), forall (uniform_bound_law : Prop), forall (bound_to_domination_route : forall (finite_measure_law : Prop), forall (uniform_bound_law : Prop), forall (idx : Index), forall (x : Domain), leqValue (absValue (sequence idx x)) (constantDominatingFunction x)), forall (LowerFatouConclusion : Prop), forall (UpperFatouConclusion : Prop), forall (lower_fatou : LowerFatouConclusion), forall (upper_fatou : UpperFatouConclusion), forall (DominatedConvergenceConclusion : Prop), forall (dominated_route : @IntegrableFunction.{i,m,u,v} Domain Value IntegralValue domainMeasurable valueMeasurable positivePart negativePart nonnegativeIntegral FiniteIntegralValue constantDominatingFunction -> (forall (idx : Index), forall (x : Domain), leqValue (absValue (sequence idx x)) (constantDominatingFunction x)) -> LowerFatouConclusion -> UpperFatouConclusion -> DominatedConvergenceConclusion), forall (BoundedConvergenceConclusion : Prop), forall (bounded_route : forall (dominated_convergence : DominatedConvergenceConclusion), forall (finite_measure_law : Prop), forall (uniform_bound_law : Prop), BoundedConvergenceConclusion), BoundedConvergenceConclusion :=

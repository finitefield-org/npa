  forall (Int : Type), forall (AlgorithmName : Type), forall (QuadraticSieveToken : AlgorithmName), forall (SmoothRelationSet : forall (n : Int), Prop), forall (LinearDependencyCertificate : forall (n : Int), Prop), forall (CongruenceOfSquares : forall (n : Int), Prop), forall (NontrivialFactorFound : forall (n : Int), Prop), forall (FactorAlgorithmCorrect : AlgorithmName -> Int -> Prop), forall (relation_law : forall (n : Int), forall (relations : SmoothRelationSet n), forall (dependency : LinearDependencyCertificate n), CongruenceOfSquares n), forall (factor_law : forall (n : Int), forall (congruence : CongruenceOfSquares n), NontrivialFactorFound n), forall (correctness_law : forall (n : Int), forall (factor : NontrivialFactorFound n), FactorAlgorithmCorrect QuadraticSieveToken n), forall (n : Int), forall (relations : SmoothRelationSet n), forall (dependency : LinearDependencyCertificate n), FactorAlgorithmCorrect QuadraticSieveToken n :=

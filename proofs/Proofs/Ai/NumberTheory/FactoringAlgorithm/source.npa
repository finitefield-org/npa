  forall (Int : Type), forall (AlgorithmName : Type), forall (HardnessAssumption : Type), forall (NumberFieldSieveToken : AlgorithmName), forall (FactorEvidence : forall (n : Int), Prop), forall (FactorAlgorithmCorrect : AlgorithmName -> Int -> Prop), forall (HardnessAssumptionNotDerived : AlgorithmName -> Int -> HardnessAssumption -> Prop), forall (correctness_law : forall (n : Int), forall (evidence : FactorEvidence n), FactorAlgorithmCorrect NumberFieldSieveToken n), forall (hardness_boundary_law : forall (algorithm : AlgorithmName), forall (n : Int), forall (hardness : HardnessAssumption), forall (correctness : FactorAlgorithmCorrect algorithm n), HardnessAssumptionNotDerived algorithm n hardness), forall (n : Int), forall (hardness : HardnessAssumption), forall (evidence : FactorEvidence n), HardnessAssumptionNotDerived NumberFieldSieveToken n hardness :=

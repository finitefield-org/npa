theorem pollard_rho_correctness_from_cycle_gcd_chain :
  forall (Int : Type), forall (AlgorithmName : Type), forall (PollardRhoToken : AlgorithmName), forall (CompositeModulus : forall (n : Int), Prop), forall (PollardRhoCycleEvidence : forall (n : Int), forall (seed : Int), Prop), forall (GcdNontrivialDivisorEvidence : forall (n : Int), forall (seed : Int), Prop), forall (NontrivialFactorFound : forall (n : Int), Prop), forall (FactorAlgorithmCorrect : AlgorithmName -> Int -> Prop), forall (cycle_gcd_law : forall (n : Int), forall (seed : Int), forall (composite_n : CompositeModulus n), forall (cycle : PollardRhoCycleEvidence n seed), GcdNontrivialDivisorEvidence n seed), forall (factor_law : forall (n : Int), forall (seed : Int), forall (gcd_divisor : GcdNontrivialDivisorEvidence n seed), NontrivialFactorFound n), forall (correctness_law : forall (n : Int), forall (factor : NontrivialFactorFound n), FactorAlgorithmCorrect PollardRhoToken n), forall (n : Int), forall (seed : Int), forall (composite_n : CompositeModulus n), forall (cycle : PollardRhoCycleEvidence n seed), FactorAlgorithmCorrect PollardRhoToken n :=
  fun Int => fun AlgorithmName => fun PollardRhoToken => fun CompositeModulus => fun PollardRhoCycleEvidence => fun GcdNontrivialDivisorEvidence => fun NontrivialFactorFound => fun FactorAlgorithmCorrect => fun cycle_gcd_law => fun factor_law => fun correctness_law => fun n => fun seed => fun composite_n => fun cycle => correctness_law n (factor_law n seed (cycle_gcd_law n seed composite_n cycle))


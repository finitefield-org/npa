theorem pollard_rho_probability_requires_randomness_assumption :
  forall (Int : Type), forall (AlgorithmName : Type), forall (RandomnessSource : Type), forall (ProbabilityBound : Type), forall (PollardRhoToken : AlgorithmName), forall (RandomnessAssumption : RandomnessSource -> Prop), forall (FailureProbabilityClaim : AlgorithmName -> RandomnessSource -> ProbabilityBound -> Prop), forall (PollardRhoAttemptEvidence : forall (n : Int), forall (seed : Int), forall (randomness : RandomnessSource), Prop), forall (PollardRhoProbabilityBoundary : AlgorithmName -> Int -> Int -> RandomnessSource -> ProbabilityBound -> Prop), forall (attempt_law : forall (n : Int), forall (seed : Int), forall (randomness : RandomnessSource), forall (randomness_assumption : RandomnessAssumption randomness), PollardRhoAttemptEvidence n seed randomness), forall (probability_law : forall (n : Int), forall (seed : Int), forall (randomness : RandomnessSource), forall (bound : ProbabilityBound), forall (attempt : PollardRhoAttemptEvidence n seed randomness), forall (failure_claim : FailureProbabilityClaim PollardRhoToken randomness bound), PollardRhoProbabilityBoundary PollardRhoToken n seed randomness bound), forall (n : Int), forall (seed : Int), forall (randomness : RandomnessSource), forall (bound : ProbabilityBound), forall (randomness_assumption : RandomnessAssumption randomness), forall (failure_claim : FailureProbabilityClaim PollardRhoToken randomness bound), PollardRhoProbabilityBoundary PollardRhoToken n seed randomness bound :=
  fun Int => fun AlgorithmName => fun RandomnessSource => fun ProbabilityBound => fun PollardRhoToken => fun RandomnessAssumption => fun FailureProbabilityClaim => fun PollardRhoAttemptEvidence => fun PollardRhoProbabilityBoundary => fun attempt_law => fun probability_law => fun n => fun seed => fun randomness => fun bound => fun randomness_assumption => fun failure_claim => probability_law n seed randomness bound (attempt_law n seed randomness randomness_assumption) failure_claim

theorem factoring_complexity_interface_requires_cost_model :
  forall (Int : Type), forall (AlgorithmName : Type), forall (CostModel : Type), forall (QuadraticSieveToken : AlgorithmName), forall (FactorEvidence : forall (n : Int), Prop), forall (FactorAlgorithmCorrect : AlgorithmName -> Int -> Prop), forall (ComplexityInterface : AlgorithmName -> CostModel -> Prop), forall (CostModelAvailable : CostModel -> Prop), forall (CorrectnessSeparateFromComplexity : AlgorithmName -> Int -> CostModel -> Prop), forall (correctness_law : forall (n : Int), forall (evidence : FactorEvidence n), FactorAlgorithmCorrect QuadraticSieveToken n), forall (complexity_law : forall (cost_model : CostModel), forall (available : CostModelAvailable cost_model), ComplexityInterface QuadraticSieveToken cost_model), forall (separation_law : forall (n : Int), forall (cost_model : CostModel), forall (correctness : FactorAlgorithmCorrect QuadraticSieveToken n), forall (complexity : ComplexityInterface QuadraticSieveToken cost_model), CorrectnessSeparateFromComplexity QuadraticSieveToken n cost_model), forall (n : Int), forall (cost_model : CostModel), forall (evidence : FactorEvidence n), forall (available : CostModelAvailable cost_model), CorrectnessSeparateFromComplexity QuadraticSieveToken n cost_model :=
  fun Int => fun AlgorithmName => fun CostModel => fun QuadraticSieveToken => fun FactorEvidence => fun FactorAlgorithmCorrect => fun ComplexityInterface => fun CostModelAvailable => fun CorrectnessSeparateFromComplexity => fun correctness_law => fun complexity_law => fun separation_law => fun n => fun cost_model => fun evidence => fun available => separation_law n cost_model (correctness_law n evidence) (complexity_law cost_model available)


theorem erdos_ginzburg_ziv_interface :
  forall (Group : Type), forall (Nat : Type), forall (Sequence : Type), forall (Length : Sequence -> Nat), forall (SumsetZero : Sequence -> Prop), forall (Add : Nat -> Nat -> Nat), forall (Sub : Nat -> Nat -> Nat), forall (Mul : Nat -> Nat -> Nat), forall (Two : Nat), forall (One : Nat), forall (erdos_ginzburg_ziv_law : forall (n : Nat), forall (seq : Sequence), forall (eq_len : @Eq.{1} Nat (Length seq) (Sub (Mul Two n) One)), SumsetZero seq), forall (n : Nat), forall (seq : Sequence), forall (eq_len : @Eq.{1} Nat (Length seq) (Sub (Mul Two n) One)), SumsetZero seq :=

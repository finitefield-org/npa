  fun Group => fun Nat => fun Subset => fun Subgroup => fun CardSubset => fun CardSubgroup => fun Stabilizer => fun Sumset => fun AddHelper => fun Add => fun Sub => fun Le => fun kneser_law => fun A => fun B => fun H => fun eq_stab => kneser_law A B H eq_stab


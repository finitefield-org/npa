import Std.Logic.Eq
import Proofs.Ai.NumberTheory.LocalField

theorem artin_map_local_interface :
  forall (K : Type), forall (G : Type), forall (ArtinMap : K -> G), forall (artin_law : forall (x : K), @Eq.{1} G (ArtinMap x) (ArtinMap x)), forall (x : K), @Eq.{1} G (ArtinMap x) (ArtinMap x) :=
  fun K => fun G => fun ArtinMap => fun artin_law => fun x => artin_law x

theorem local_reciprocity_theorem_interface :
  forall (K : Type), forall (L : Type), forall (G : Type), forall (Isomorphism : Prop), forall (recip_law : Isomorphism -> Isomorphism), Isomorphism -> Isomorphism :=
  fun K => fun L => fun G => fun Isomorphism => fun recip_law => recip_law

theorem kronecker_weber_theorem_interface :
  forall (K : Type), forall (IsAbelianExtension : Prop), forall (IsCyclotomicExtension : Prop), forall (kw_law : IsAbelianExtension -> IsCyclotomicExtension), IsAbelianExtension -> IsCyclotomicExtension :=
  fun K => fun IsAbelianExtension => fun IsCyclotomicExtension => fun kw_law => kw_law

theorem local_reciprocity_map_domain_codomain_normalization_functoriality_surface :
  forall (LocalDomain : Type), forall (LocalCodomain : Type), forall (ReciprocityMap : LocalDomain -> LocalCodomain), forall (Normalization : Prop), forall (Functoriality : Prop), forall (LocalReciprocityData : (LocalDomain -> LocalCodomain) -> Prop), forall (data_law : Normalization -> Functoriality -> LocalReciprocityData ReciprocityMap), Normalization -> Functoriality -> LocalReciprocityData ReciprocityMap :=
  fun LocalDomain => fun LocalCodomain => fun ReciprocityMap => fun Normalization => fun Functoriality => fun LocalReciprocityData => fun data_law => data_law

theorem explicit_class_field_bridge_name_surface :
  forall (BridgeName : Type), forall (ClassFieldBridgeAssumption : BridgeName -> Prop), forall (ExplicitBridgeName : BridgeName -> Prop), forall (bridge_law : forall (name : BridgeName), ClassFieldBridgeAssumption name -> ExplicitBridgeName name), forall (name : BridgeName), ClassFieldBridgeAssumption name -> ExplicitBridgeName name :=
  fun BridgeName => fun ClassFieldBridgeAssumption => fun ExplicitBridgeName => fun bridge_law => fun name => bridge_law name


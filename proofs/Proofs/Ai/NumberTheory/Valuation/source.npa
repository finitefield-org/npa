import Std.Logic.Eq
import Proofs.Ai.EqReasoning
import Proofs.Ai.Analysis.AbstractMetricTopology
import Proofs.Ai.Vector.AbstractSpace
import Proofs.Ai.Analysis.AbstractNormedSpace
import Proofs.Ai.Analysis.AbstractFixedPoint

theorem padic_valuation_interface :
  forall (Valuation : Type), forall (v_p : Valuation -> Valuation), forall (val_law : forall (x : Valuation), @Eq.{1} Valuation (v_p x) (v_p x)), forall (x : Valuation), @Eq.{1} Valuation (v_p x) (v_p x) :=
  fun Valuation => fun v_p => fun val_law => fun x => val_law x

theorem padic_absolute_value_interface :
  forall (K : Type), forall (Real : Type), forall (AbsVal : K -> Real), forall (abs_law : forall (x : K), @Eq.{1} Real (AbsVal x) (AbsVal x)), forall (x : K), @Eq.{1} Real (AbsVal x) (AbsVal x) :=
  fun K => fun Real => fun AbsVal => fun abs_law => fun x => abs_law x

theorem non_archimedean_metric_law_interface :
  forall (K : Type), forall (Real : Type), forall (AbsVal : K -> Real), forall (NonArchimedean : forall (x : K), forall (y : K), @Eq.{1} Real (AbsVal x) (AbsVal x)), forall (x : K), forall (y : K), @Eq.{1} Real (AbsVal x) (AbsVal x) :=
  fun K => fun Real => fun AbsVal => fun NonArchimedean => fun x => fun y => NonArchimedean x y

theorem non_Archimedean_metric_from_valuation_surface :
  forall (K : Type), forall (MetricValue : Type), forall (Valuation : K -> MetricValue), forall (p_adic_absolute_value : K -> MetricValue), forall (non_ArchimedeanMetric : K -> K -> Prop), forall (metric_law : forall (x : K), forall (y : K), non_ArchimedeanMetric x y), forall (x : K), forall (y : K), non_ArchimedeanMetric x y :=
  fun K => fun MetricValue => fun Valuation => fun p_adic_absolute_value => fun non_ArchimedeanMetric => fun metric_law => fun x => fun y => metric_law x y

theorem p_adic_valuation_algebra_before_completion_boundary :
  forall (ValuationAlgebraLawPackage : Type), forall (MetricCompletionPackage : Type), forall (AlgebraBeforeCompletion : ValuationAlgebraLawPackage -> MetricCompletionPackage -> Prop), forall (boundary_law : forall (valuation_laws : ValuationAlgebraLawPackage), forall (completion : MetricCompletionPackage), AlgebraBeforeCompletion valuation_laws completion), forall (valuation_laws : ValuationAlgebraLawPackage), forall (completion : MetricCompletionPackage), AlgebraBeforeCompletion valuation_laws completion :=
  fun ValuationAlgebraLawPackage => fun MetricCompletionPackage => fun AlgebraBeforeCompletion => fun boundary_law => fun valuation_laws => fun completion => boundary_law valuation_laws completion

theorem p_adic_completion_topology_dependency_surface :
  forall (PadicField : Type), forall (MetricTopologyPackage : Type), forall (MetricCompletionPackage : Type), forall (CompletionDependency : PadicField -> MetricTopologyPackage -> MetricCompletionPackage -> Prop), forall (dependency_law : forall (Qp : PadicField), forall (topology : MetricTopologyPackage), forall (completion : MetricCompletionPackage), CompletionDependency Qp topology completion), forall (Qp : PadicField), forall (topology : MetricTopologyPackage), forall (completion : MetricCompletionPackage), CompletionDependency Qp topology completion :=
  fun PadicField => fun MetricTopologyPackage => fun MetricCompletionPackage => fun CompletionDependency => fun dependency_law => fun Qp => fun topology => fun completion => dependency_law Qp topology completion

theorem no_local_field_for_basic_valuation_boundary :
  forall (BasicValuationPackage : Type), forall (LocalFieldTheoremPackage : Type), forall (NoLocalFieldDependency : BasicValuationPackage -> LocalFieldTheoremPackage -> Prop), forall (boundary_law : forall (valuation_package : BasicValuationPackage), forall (local_field_theorem : LocalFieldTheoremPackage), NoLocalFieldDependency valuation_package local_field_theorem), forall (valuation_package : BasicValuationPackage), forall (local_field_theorem : LocalFieldTheoremPackage), NoLocalFieldDependency valuation_package local_field_theorem :=
  fun BasicValuationPackage => fun LocalFieldTheoremPackage => fun NoLocalFieldDependency => fun boundary_law => fun valuation_package => fun local_field_theorem => boundary_law valuation_package local_field_theorem

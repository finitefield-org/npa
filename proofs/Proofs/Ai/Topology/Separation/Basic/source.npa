theorem hausdorff_diagonal_criterion_intro.{p,u} :
  forall (X : Sort u), forall (Product : Sort p), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (diagonal : forall (point : Product), Prop), forall (forward : @HausdorffSpace.{u} X isOpen -> @ClosedSet.{p} Product productOpen diagonal), forall (backward : @ClosedSet.{p} Product productOpen diagonal -> @HausdorffSpace.{u} X isOpen), @HausdorffDiagonalCriterion.{p,u} X Product isOpen productOpen diagonal :=
  fun X => fun Product => fun isOpen => fun productOpen => fun diagonal => fun forward => fun backward => fun (P : Prop) => fun (mk : forall (forward : @HausdorffSpace.{u} X isOpen -> @ClosedSet.{p} Product productOpen diagonal), forall (backward : @ClosedSet.{p} Product productOpen diagonal -> @HausdorffSpace.{u} X isOpen), P) => mk forward backward

theorem hausdorff_diagonal_forward.{p,u} :
  forall (X : Sort u), forall (Product : Sort p), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (diagonal : forall (point : Product), Prop), forall (criterion : @HausdorffDiagonalCriterion.{p,u} X Product isOpen productOpen diagonal), forall (hausdorff : @HausdorffSpace.{u} X isOpen), @ClosedSet.{p} Product productOpen diagonal :=
  fun X => fun Product => fun isOpen => fun productOpen => fun diagonal => fun criterion => fun hausdorff => criterion (@ClosedSet.{p} Product productOpen diagonal) (fun (forward : @HausdorffSpace.{u} X isOpen -> @ClosedSet.{p} Product productOpen diagonal) => fun (backward : @ClosedSet.{p} Product productOpen diagonal -> @HausdorffSpace.{u} X isOpen) => forward hausdorff)

theorem hausdorff_diagonal_backward.{p,u} :
  forall (X : Sort u), forall (Product : Sort p), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (diagonal : forall (point : Product), Prop), forall (criterion : @HausdorffDiagonalCriterion.{p,u} X Product isOpen productOpen diagonal), forall (diagonal_closed : @ClosedSet.{p} Product productOpen diagonal), @HausdorffSpace.{u} X isOpen :=
  fun X => fun Product => fun isOpen => fun productOpen => fun diagonal => fun criterion => fun diagonal_closed => criterion (@HausdorffSpace.{u} X isOpen) (fun (forward : @HausdorffSpace.{u} X isOpen -> @ClosedSet.{p} Product productOpen diagonal) => fun (backward : @ClosedSet.{p} Product productOpen diagonal -> @HausdorffSpace.{u} X isOpen) => backward diagonal_closed)

theorem compact_subset_closed_in_hausdorff.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (route : @CompactHausdorffClosedRoute.{u} X isOpen), forall (subset : forall (x : X), Prop), forall (CompactSubset : Prop), forall (compact_law : CompactSubset), forall (hausdorff_law : @HausdorffSpace.{u} X isOpen), @ClosedSet.{u} X isOpen subset :=
  fun X => fun isOpen => fun route => fun subset => fun CompactSubset => fun compact_law => fun hausdorff_law => route subset CompactSubset compact_law hausdorff_law

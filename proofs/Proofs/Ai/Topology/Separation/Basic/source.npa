  forall (X : Sort u), forall (Product : Sort p), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (diagonal : forall (point : Product), Prop), Prop :=

def DistinctPoints.{u} :
  forall (X : Sort u), forall (left : X), forall (right : X), Prop :=
  fun X => fun left => fun right => forall (same : @Eq.{u} X left right), @EmptySet.{u} X left

def PointOpenExclusion.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (center : X), forall (excluded : X), Prop :=
  fun X => fun isOpen => fun center => fun excluded => forall (P : Prop), forall (mk : forall (open_set : forall (x : X), Prop), forall (open_law : isOpen open_set), forall (center_mem : open_set center), forall (excluded_not_mem : @SetComplement.{u} X open_set excluded), P), P

def DisjointOpenNeighborhoods.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (left : X), forall (right : X), Prop :=
  fun X => fun isOpen => fun left => fun right => forall (P : Prop), forall (mk : forall (left_open_set : forall (x : X), Prop), forall (right_open_set : forall (x : X), Prop), forall (left_open_law : isOpen left_open_set), forall (right_open_law : isOpen right_open_set), forall (left_mem : left_open_set left), forall (right_mem : right_open_set right), forall (disjoint_law : forall (z : X), forall (left_z : left_open_set z), forall (right_z : right_open_set z), @EmptySet.{u} X z), P), P

def T0Space.{u} :

  forall (Index : Sort i), forall (X : Sort u), forall (Y : Sort v), forall (global : forall (x : X), Y), forall (local : forall (idx : Index), forall (x : X), Y), forall (family : forall (idx : Index), forall (x : X), Prop), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (cover : @PastingCover.{i,u} Index X family sourceOpen), forall (compatibility : @PastingCompatibility.{i,u,v} Index X Y local family), forall (local_continuous : forall (idx : Index), @ContinuousMap.{u,v} X Y (local idx) sourceOpen targetOpen), forall (global_law : @ContinuousMap.{u,v} X Y global sourceOpen targetOpen), @PastingContinuousRoute.{i,u,v} Index X Y global local family sourceOpen targetOpen :=

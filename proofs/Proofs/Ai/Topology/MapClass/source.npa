  forall (Index : Sort i), forall (X : Sort u), forall (family : forall (idx : Index), forall (x : X), Prop), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (cover : @PastingCover.{i,u} Index X family isOpen), forall (idx : Index), isOpen (family idx) :=
  fun Index => fun X => fun family => fun isOpen => fun cover => cover (forall (idx : Index), isOpen (family idx)) (fun (cover_law : forall (x : X), @IndexedUnion.{i,u} X Index family x) => fun (all_open : forall (idx : Index), isOpen (family idx)) => fun (all_closed : forall (idx : Index), @ClosedSet.{u} X isOpen (family idx)) => all_open)


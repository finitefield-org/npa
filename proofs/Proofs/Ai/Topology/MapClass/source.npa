  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun hook => hook (@ContinuousMap.{v,u} Y X backward targetOpen sourceOpen) (fun (forward_continuous : @ContinuousMap.{u,v} X Y forward sourceOpen targetOpen) => fun (backward_continuous : @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen) => fun (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))) => fun (left_from : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset (backward (forward x))), subset x) => fun (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))) => fun (right_from : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset (forward (backward y))), subset y) => backward_continuous)


theorem pasting_cover_intro.{i,u} :
  forall (Index : Sort i), forall (X : Sort u), forall (family : forall (idx : Index), forall (x : X), Prop), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (cover : forall (x : X), @IndexedUnion.{i,u} X Index family x), forall (all_open : forall (idx : Index), isOpen (family idx)), forall (all_closed : forall (idx : Index), @ClosedSet.{u} X isOpen (family idx)), @PastingCover.{i,u} Index X family isOpen :=
  fun Index => fun X => fun family => fun isOpen => fun cover => fun all_open => fun all_closed => fun (P : Prop) => fun (mk : forall (cover : forall (x : X), @IndexedUnion.{i,u} X Index family x), forall (all_open : forall (idx : Index), isOpen (family idx)), forall (all_closed : forall (idx : Index), @ClosedSet.{u} X isOpen (family idx)), P) => mk cover all_open all_closed


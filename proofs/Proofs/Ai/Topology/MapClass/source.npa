  forall (Index : Sort i), forall (X : Sort u), forall (Y : Sort v), forall (local : forall (idx : Index), forall (x : X), Y), forall (family : forall (idx : Index), forall (x : X), Prop), forall (compatibility : @PastingCompatibility.{i,u,v} Index X Y local family), forall (left : Index), forall (right : Index), forall (x : X), forall (left_mem : family left x), forall (right_mem : family right x), @Eq.{v} Y (local left x) (local right x) :=

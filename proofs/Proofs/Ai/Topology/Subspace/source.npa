def MapPreimage.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (subset : forall (y : Y), Prop), forall (x : X), Prop :=
  fun X => fun Y => fun f => fun subset => fun x => subset (f x)


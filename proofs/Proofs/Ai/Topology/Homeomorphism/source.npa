def Homeomorphism.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => @HomeomorphismHook.{u,v} X Y forward backward sourceOpen targetOpen

def Homeomorphic.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun sourceOpen => fun targetOpen => forall (P : Prop), forall (mk : forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), P), P

def HomeomorphismOpenCorrespondence.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => forall (P : Prop), forall (mk : forall (forward_open : @OpenMap.{u,v} X Y forward sourceOpen targetOpen), forall (backward_open : @OpenMap.{v,u} Y X backward targetOpen sourceOpen), P), P

def HomeomorphismClosedCorrespondence.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => forall (P : Prop), forall (mk : forall (forward_closed : @ClosedMap.{u,v} X Y forward sourceOpen targetOpen), forall (backward_closed : @ClosedMap.{v,u} Y X backward targetOpen sourceOpen), P), P

def InverseContinuityCriterion.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => forall (P : Prop), forall (mk : forall (forward_continuous : @ContinuousMap.{u,v} X Y forward sourceOpen targetOpen), forall (forward_open : @OpenMap.{u,v} X Y forward sourceOpen targetOpen), forall (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))), forall (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))), forall (backward_continuous : @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen), P), P

theorem homeomorphism_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (forward_continuous : @ContinuousMap.{u,v} X Y forward sourceOpen targetOpen), forall (backward_continuous : @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen), forall (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))), forall (left_from : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset (backward (forward x))), subset x), forall (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))), forall (right_from : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset (forward (backward y))), subset y), @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun forward_continuous => fun backward_continuous => fun left_to => fun left_from => fun right_to => fun right_from => @homeomorphism_hook_intro.{u,v} X Y forward backward sourceOpen targetOpen forward_continuous backward_continuous left_to left_from right_to right_from

theorem homeomorphism_forward_continuous.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), @ContinuousMap.{u,v} X Y forward sourceOpen targetOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => @homeomorphism_hook_forward_continuous.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism

theorem homeomorphism_backward_continuous.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => @homeomorphism_hook_backward_continuous.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism

theorem homeomorphism_left_to.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x)) :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => @homeomorphism_hook_left_to.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism

theorem homeomorphism_right_to.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y)) :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => @homeomorphism_hook_right_to.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism

theorem homeomorphism_refl.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), @Homeomorphism.{u,u} X X (fun (x : X) => x) (fun (x : X) => x) isOpen isOpen :=
  fun X => fun isOpen => @homeomorphism_intro.{u,u} X X (fun (x : X) => x) (fun (x : X) => x) isOpen isOpen (@continuous_id.{u} X isOpen) (@continuous_id.{u} X isOpen) (fun (subset : forall (x : X), Prop) => fun (x : X) => fun (member : subset x) => member) (fun (subset : forall (x : X), Prop) => fun (x : X) => fun (member : subset x) => member) (fun (subset : forall (x : X), Prop) => fun (x : X) => fun (member : subset x) => member) (fun (subset : forall (x : X), Prop) => fun (x : X) => fun (member : subset x) => member)

theorem homeomorphism_symm.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), @Homeomorphism.{v,u} Y X backward forward targetOpen sourceOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => @homeomorphism_intro.{v,u} Y X backward forward targetOpen sourceOpen (@homeomorphism_backward_continuous.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism) (@homeomorphism_forward_continuous.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism) (fun (subset : forall (y : Y), Prop) => fun (y : Y) => fun (member : subset y) => @homeomorphism_right_to.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism subset y member) (fun (subset : forall (y : Y), Prop) => fun (y : Y) => fun (member : subset (forward (backward y))) => @homeomorphism_hook_right_from.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism subset y member) (fun (subset : forall (x : X), Prop) => fun (x : X) => fun (member : subset x) => @homeomorphism_left_to.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism subset x member) (fun (subset : forall (x : X), Prop) => fun (x : X) => fun (member : subset (backward (forward x))) => @homeomorphism_hook_left_from.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism subset x member)

theorem homeomorphism_forward_open_map.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), @OpenMap.{u,v} X Y forward sourceOpen targetOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => @open_map_intro.{u,v} X Y forward sourceOpen targetOpen (fun (source_subset : forall (x : X), Prop) => fun (source_open : sourceOpen source_subset) => @continuous_open_preimage_witness.{v,u} Y X backward targetOpen sourceOpen (@homeomorphism_backward_continuous.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism) source_subset source_open (@OpenMapWitness.{u,v} X Y forward sourceOpen targetOpen source_subset) (fun (target_image : forall (y : Y), Prop) => fun (target_image_open : targetOpen target_image) => fun (to_source : forall (y : Y), forall (member : target_image y), source_subset (backward y)) => fun (from_source : forall (y : Y), forall (member : source_subset (backward y)), target_image y) => @open_map_witness_intro.{u,v} X Y forward sourceOpen targetOpen source_subset target_image target_image_open (fun (x : X) => fun (member : source_subset x) => from_source (forward x) (@homeomorphism_left_to.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism source_subset x member))))

theorem homeomorphism_backward_open_map.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), @OpenMap.{v,u} Y X backward targetOpen sourceOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => @open_map_intro.{v,u} Y X backward targetOpen sourceOpen (fun (source_subset : forall (y : Y), Prop) => fun (source_open : targetOpen source_subset) => @continuous_open_preimage_witness.{u,v} X Y forward sourceOpen targetOpen (@homeomorphism_forward_continuous.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism) source_subset source_open (@OpenMapWitness.{v,u} Y X backward targetOpen sourceOpen source_subset) (fun (target_image : forall (x : X), Prop) => fun (target_image_open : sourceOpen target_image) => fun (to_source : forall (x : X), forall (member : target_image x), source_subset (forward x)) => fun (from_source : forall (x : X), forall (member : source_subset (forward x)), target_image x) => @open_map_witness_intro.{v,u} Y X backward targetOpen sourceOpen source_subset target_image target_image_open (fun (y : Y) => fun (member : source_subset y) => from_source (backward y) (@homeomorphism_right_to.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism source_subset y member))))

theorem homeomorphism_open_correspondence_from_homeomorphism.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), @HomeomorphismOpenCorrespondence.{u,v} X Y forward backward sourceOpen targetOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun homeomorphism => fun (P : Prop) => fun (mk : forall (forward_open : @OpenMap.{u,v} X Y forward sourceOpen targetOpen), forall (backward_open : @OpenMap.{v,u} Y X backward targetOpen sourceOpen), P) => mk (@homeomorphism_forward_open_map.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism) (@homeomorphism_backward_open_map.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism)

theorem homeomorphic_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), @Homeomorphic.{u,v} X Y sourceOpen targetOpen :=
  fun X => fun Y => fun sourceOpen => fun targetOpen => fun forward => fun backward => fun homeomorphism => fun (P : Prop) => fun (mk : forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen), P) => mk forward backward homeomorphism

theorem homeomorphic_symm.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (homeomorphic : @Homeomorphic.{u,v} X Y sourceOpen targetOpen), @Homeomorphic.{v,u} Y X targetOpen sourceOpen :=
  fun X => fun Y => fun sourceOpen => fun targetOpen => fun homeomorphic => homeomorphic (@Homeomorphic.{v,u} Y X targetOpen sourceOpen) (fun (forward : forall (x : X), Y) => fun (backward : forall (y : Y), X) => fun (homeomorphism : @Homeomorphism.{u,v} X Y forward backward sourceOpen targetOpen) => @homeomorphic_intro.{v,u} Y X targetOpen sourceOpen backward forward (@homeomorphism_symm.{u,v} X Y forward backward sourceOpen targetOpen homeomorphism))

theorem homeomorphism_closed_correspondence_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (forward_closed : @ClosedMap.{u,v} X Y forward sourceOpen targetOpen), forall (backward_closed : @ClosedMap.{v,u} Y X backward targetOpen sourceOpen), @HomeomorphismClosedCorrespondence.{u,v} X Y forward backward sourceOpen targetOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun forward_closed => fun backward_closed => fun (P : Prop) => fun (mk : forall (forward_closed : @ClosedMap.{u,v} X Y forward sourceOpen targetOpen), forall (backward_closed : @ClosedMap.{v,u} Y X backward targetOpen sourceOpen), P) => mk forward_closed backward_closed

theorem inverse_continuity_criterion_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (forward_continuous : @ContinuousMap.{u,v} X Y forward sourceOpen targetOpen), forall (forward_open : @OpenMap.{u,v} X Y forward sourceOpen targetOpen), forall (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))), forall (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))), forall (backward_continuous : @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen), @InverseContinuityCriterion.{u,v} X Y forward backward sourceOpen targetOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun forward_continuous => fun forward_open => fun left_to => fun right_to => fun backward_continuous => fun (P : Prop) => fun (mk : forall (forward_continuous : @ContinuousMap.{u,v} X Y forward sourceOpen targetOpen), forall (forward_open : @OpenMap.{u,v} X Y forward sourceOpen targetOpen), forall (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))), forall (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))), forall (backward_continuous : @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen), P) => mk forward_continuous forward_open left_to right_to backward_continuous

theorem inverse_criterion_backward_continuous.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (criterion : @InverseContinuityCriterion.{u,v} X Y forward backward sourceOpen targetOpen), @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen :=
  fun X => fun Y => fun forward => fun backward => fun sourceOpen => fun targetOpen => fun criterion => criterion (@ContinuousMap.{v,u} Y X backward targetOpen sourceOpen) (fun (forward_continuous : @ContinuousMap.{u,v} X Y forward sourceOpen targetOpen) => fun (forward_open : @OpenMap.{u,v} X Y forward sourceOpen targetOpen) => fun (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))) => fun (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))) => fun (backward_continuous : @ContinuousMap.{v,u} Y X backward targetOpen sourceOpen) => backward_continuous)

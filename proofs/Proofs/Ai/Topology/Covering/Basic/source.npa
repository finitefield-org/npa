def EvenlyCoveredNeighborhood.{s,u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (base_subset : forall (point : Base), Prop), forall (SheetIndex : Sort s), forall (sheet : forall (idx : SheetIndex), forall (point : Total), Prop), forall (LocalTrivializationEvidence : Prop), Prop :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun base_subset => fun SheetIndex => fun sheet => fun LocalTrivializationEvidence => forall (P : Prop), forall (mk : forall (base_open : baseOpen base_subset), forall (sheet_open : forall (idx : SheetIndex), totalOpen (sheet idx)), forall (local_trivialization : LocalTrivializationEvidence), P), P

def CoveringMap.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), Prop :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun EvenCoverEvidence => forall (P : Prop), forall (mk : forall (projection_continuous : @ContinuousMap.{u,v} Total Base projection totalOpen baseOpen), forall (even_cover : forall (basepoint : Base), EvenCoverEvidence basepoint), P), P

def CoveringFiber.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (basepoint : Base), forall (point : Total), Prop :=
  fun Total => fun Base => fun projection => fun basepoint => fun point => @Eq.{v} Base (projection point) basepoint

def PointedCoveringMap.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (total_base : Total), forall (basepoint : Base), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), Prop :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun total_base => fun basepoint => fun EvenCoverEvidence => forall (P : Prop), forall (mk : forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (basepoint_law : @Eq.{v} Base (projection total_base) basepoint), P), P

theorem evenly_covered_neighborhood_intro.{s,u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (base_subset : forall (point : Base), Prop), forall (SheetIndex : Sort s), forall (sheet : forall (idx : SheetIndex), forall (point : Total), Prop), forall (LocalTrivializationEvidence : Prop), forall (base_open : baseOpen base_subset), forall (sheet_open : forall (idx : SheetIndex), totalOpen (sheet idx)), forall (local_trivialization : LocalTrivializationEvidence), @EvenlyCoveredNeighborhood.{s,u,v} Total Base projection totalOpen baseOpen base_subset SheetIndex sheet LocalTrivializationEvidence :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun base_subset => fun SheetIndex => fun sheet => fun LocalTrivializationEvidence => fun base_open => fun sheet_open => fun local_trivialization => fun (P : Prop) => fun (mk : forall (base_open : baseOpen base_subset), forall (sheet_open : forall (idx : SheetIndex), totalOpen (sheet idx)), forall (local_trivialization : LocalTrivializationEvidence), P) => mk base_open sheet_open local_trivialization

theorem evenly_covered_base_open.{s,u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (base_subset : forall (point : Base), Prop), forall (SheetIndex : Sort s), forall (sheet : forall (idx : SheetIndex), forall (point : Total), Prop), forall (LocalTrivializationEvidence : Prop), forall (evenly : @EvenlyCoveredNeighborhood.{s,u,v} Total Base projection totalOpen baseOpen base_subset SheetIndex sheet LocalTrivializationEvidence), baseOpen base_subset :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun base_subset => fun SheetIndex => fun sheet => fun LocalTrivializationEvidence => fun evenly => evenly (baseOpen base_subset) (fun (base_open : baseOpen base_subset) => fun (sheet_open : forall (idx : SheetIndex), totalOpen (sheet idx)) => fun (local_trivialization : LocalTrivializationEvidence) => base_open)

theorem evenly_covered_local_trivialization.{s,u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (base_subset : forall (point : Base), Prop), forall (SheetIndex : Sort s), forall (sheet : forall (idx : SheetIndex), forall (point : Total), Prop), forall (LocalTrivializationEvidence : Prop), forall (evenly : @EvenlyCoveredNeighborhood.{s,u,v} Total Base projection totalOpen baseOpen base_subset SheetIndex sheet LocalTrivializationEvidence), LocalTrivializationEvidence :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun base_subset => fun SheetIndex => fun sheet => fun LocalTrivializationEvidence => fun evenly => evenly LocalTrivializationEvidence (fun (base_open : baseOpen base_subset) => fun (sheet_open : forall (idx : SheetIndex), totalOpen (sheet idx)) => fun (local_trivialization : LocalTrivializationEvidence) => local_trivialization)

theorem covering_map_intro.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (projection_continuous : @ContinuousMap.{u,v} Total Base projection totalOpen baseOpen), forall (even_cover : forall (basepoint : Base), EvenCoverEvidence basepoint), @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun EvenCoverEvidence => fun projection_continuous => fun even_cover => fun (P : Prop) => fun (mk : forall (projection_continuous : @ContinuousMap.{u,v} Total Base projection totalOpen baseOpen), forall (even_cover : forall (basepoint : Base), EvenCoverEvidence basepoint), P) => mk projection_continuous even_cover

theorem covering_map_projection_continuous.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), @ContinuousMap.{u,v} Total Base projection totalOpen baseOpen :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun EvenCoverEvidence => fun covering => covering (@ContinuousMap.{u,v} Total Base projection totalOpen baseOpen) (fun (projection_continuous : @ContinuousMap.{u,v} Total Base projection totalOpen baseOpen) => fun (even_cover : forall (basepoint : Base), EvenCoverEvidence basepoint) => projection_continuous)

theorem covering_map_even_cover.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (basepoint : Base), EvenCoverEvidence basepoint :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun EvenCoverEvidence => fun covering => fun basepoint => covering (EvenCoverEvidence basepoint) (fun (projection_continuous : @ContinuousMap.{u,v} Total Base projection totalOpen baseOpen) => fun (even_cover : forall (basepoint : Base), EvenCoverEvidence basepoint) => even_cover basepoint)

theorem covering_fiber_intro.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (basepoint : Base), forall (point : Total), forall (projection_law : @Eq.{v} Base (projection point) basepoint), @CoveringFiber.{u,v} Total Base projection basepoint point :=
  fun Total => fun Base => fun projection => fun basepoint => fun point => fun projection_law => projection_law

theorem covering_fiber_projection_eq.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (basepoint : Base), forall (point : Total), forall (fiber_member : @CoveringFiber.{u,v} Total Base projection basepoint point), @Eq.{v} Base (projection point) basepoint :=
  fun Total => fun Base => fun projection => fun basepoint => fun point => fun fiber_member => fiber_member

theorem pointed_covering_map_intro.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (total_base : Total), forall (basepoint : Base), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (basepoint_law : @Eq.{v} Base (projection total_base) basepoint), @PointedCoveringMap.{u,v} Total Base projection totalOpen baseOpen total_base basepoint EvenCoverEvidence :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun total_base => fun basepoint => fun EvenCoverEvidence => fun covering => fun basepoint_law => fun (P : Prop) => fun (mk : forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (basepoint_law : @Eq.{v} Base (projection total_base) basepoint), P) => mk covering basepoint_law

theorem pointed_covering_map_covering.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (total_base : Total), forall (basepoint : Base), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (pointed : @PointedCoveringMap.{u,v} Total Base projection totalOpen baseOpen total_base basepoint EvenCoverEvidence), @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun total_base => fun basepoint => fun EvenCoverEvidence => fun pointed => pointed (@CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) (fun (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) => fun (basepoint_law : @Eq.{v} Base (projection total_base) basepoint) => covering)

theorem pointed_covering_map_basepoint.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (total_base : Total), forall (basepoint : Base), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (pointed : @PointedCoveringMap.{u,v} Total Base projection totalOpen baseOpen total_base basepoint EvenCoverEvidence), @Eq.{v} Base (projection total_base) basepoint :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun total_base => fun basepoint => fun EvenCoverEvidence => fun pointed => pointed (@Eq.{v} Base (projection total_base) basepoint) (fun (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) => fun (basepoint_law : @Eq.{v} Base (projection total_base) basepoint) => basepoint_law)

theorem covering_local_homeomorphism_route.{u,v} :
  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (LocalHomeomorphismEvidence : forall (basepoint : Base), Prop), forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (local_law : forall (basepoint : Base), EvenCoverEvidence basepoint -> LocalHomeomorphismEvidence basepoint), forall (basepoint : Base), LocalHomeomorphismEvidence basepoint :=
  fun Total => fun Base => fun projection => fun totalOpen => fun baseOpen => fun EvenCoverEvidence => fun LocalHomeomorphismEvidence => fun covering => fun local_law => fun basepoint => local_law basepoint (@covering_map_even_cover.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence covering basepoint)

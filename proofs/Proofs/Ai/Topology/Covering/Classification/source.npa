  fun Universal => fun Base => fun projection => fun universalOpen => fun baseOpen => fun universal_base => fun basepoint => fun EvenCoverEvidence => fun UniversalLoopClass => fun universal_one => fun universal_mul => fun universal_inv => fun BaseLoopClass => fun base_one => fun base_mul => fun base_inv => fun UniversalPathConnectedEvidence => fun UniversalLoopClassEvidence => fun BasePathConnectedEvidence => fun BaseLoopClassEvidence => fun UniversalSimplyConnectedEvidence => fun UniversalCoverExistenceEvidence => fun UniversalCoverUniquenessEvidence => fun route => route UniversalCoverExistenceEvidence (fun (pointed_covering : @PointedCoveringMap.{u,v} Universal Base projection universalOpen baseOpen universal_base basepoint EvenCoverEvidence) => fun (universal_fundamental_group : @FundamentalGroupCore.{g,u} Universal universal_base universalOpen UniversalLoopClass universal_one universal_mul universal_inv UniversalPathConnectedEvidence UniversalLoopClassEvidence) => fun (base_fundamental_group : @FundamentalGroupCore.{h,v} Base basepoint baseOpen BaseLoopClass base_one base_mul base_inv BasePathConnectedEvidence BaseLoopClassEvidence) => fun (simply_connected : UniversalSimplyConnectedEvidence) => fun (existence_law : UniversalCoverExistenceEvidence) => fun (uniqueness_law : UniversalSimplyConnectedEvidence -> UniversalCoverExistenceEvidence -> UniversalCoverUniquenessEvidence) => existence_law)


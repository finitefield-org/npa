  forall (Total : Sort u), forall (Base : Sort v), forall (projection : forall (point : Total), Base), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (Deck : Sort d), forall (deck_one : Deck), forall (deck_mul : forall (left : Deck), forall (right : Deck), Deck), forall (deck_inv : forall (deck : Deck), Deck), forall (deck_apply : forall (deck : Deck), forall (point : Total), Total), forall (DeckActionEvidence : Prop), forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (deck_group : @GroupLawArgs.{d} Deck deck_one deck_mul deck_inv), forall (deck_preserves_projection : forall (deck : Deck), forall (point : Total), @Eq.{v} Base (projection (deck_apply deck point)) (projection point)), forall (action_law : DeckActionEvidence), @DeckTransformationGroupRoute.{d,u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence Deck deck_one deck_mul deck_inv deck_apply DeckActionEvidence :=

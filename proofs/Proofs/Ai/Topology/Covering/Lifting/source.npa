def CoveringLiftData.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (lift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (LiftingEvidence : Prop), Prop :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun lift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun LiftingEvidence => forall (P : Prop), forall (mk : forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (source_continuous : @ContinuousMap.{w,v} Source Base sourceMap sourceOpen baseOpen), forall (lift_continuous : @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen), forall (lift_commutes : forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point)), forall (lifting_law : LiftingEvidence), P), P

def UniqueCoveringLiftRoute.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (leftLift : forall (point : Source), Total), forall (rightLift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (SourceConnectedEvidence : Prop), forall (AgreementAtBasepointEvidence : Prop), forall (UniqueLiftEvidence : Prop), Prop :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun leftLift => fun rightLift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun SourceConnectedEvidence => fun AgreementAtBasepointEvidence => fun UniqueLiftEvidence => forall (P : Prop), forall (mk : forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (source_connected : SourceConnectedEvidence), forall (agreement_at_basepoint : AgreementAtBasepointEvidence), forall (left_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)), forall (right_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)), forall (unique_lift_law : SourceConnectedEvidence -> AgreementAtBasepointEvidence -> (forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)) -> (forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)) -> UniqueLiftEvidence), P), P

theorem covering_lift_data_intro.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (lift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (LiftingEvidence : Prop), forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (source_continuous : @ContinuousMap.{w,v} Source Base sourceMap sourceOpen baseOpen), forall (lift_continuous : @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen), forall (lift_commutes : forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point)), forall (lifting_law : LiftingEvidence), @CoveringLiftData.{u,v,w} Total Base Source projection sourceMap lift totalOpen baseOpen sourceOpen EvenCoverEvidence LiftingEvidence :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun lift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun LiftingEvidence => fun covering => fun source_continuous => fun lift_continuous => fun lift_commutes => fun lifting_law => fun (P : Prop) => fun (mk : forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (source_continuous : @ContinuousMap.{w,v} Source Base sourceMap sourceOpen baseOpen), forall (lift_continuous : @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen), forall (lift_commutes : forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point)), forall (lifting_law : LiftingEvidence), P) => mk covering source_continuous lift_continuous lift_commutes lifting_law

theorem covering_lift_continuous.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (lift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (LiftingEvidence : Prop), forall (lift_data : @CoveringLiftData.{u,v,w} Total Base Source projection sourceMap lift totalOpen baseOpen sourceOpen EvenCoverEvidence LiftingEvidence), @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun lift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun LiftingEvidence => fun lift_data => lift_data (@ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen) (fun (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) => fun (source_continuous : @ContinuousMap.{w,v} Source Base sourceMap sourceOpen baseOpen) => fun (lift_continuous : @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen) => fun (lift_commutes : forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point)) => fun (lifting_law : LiftingEvidence) => lift_continuous)

theorem covering_lift_commutes.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (lift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (LiftingEvidence : Prop), forall (lift_data : @CoveringLiftData.{u,v,w} Total Base Source projection sourceMap lift totalOpen baseOpen sourceOpen EvenCoverEvidence LiftingEvidence), forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point) :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun lift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun LiftingEvidence => fun lift_data => fun point => lift_data (@Eq.{v} Base (projection (lift point)) (sourceMap point)) (fun (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) => fun (source_continuous : @ContinuousMap.{w,v} Source Base sourceMap sourceOpen baseOpen) => fun (lift_continuous : @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen) => fun (lift_commutes : forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point)) => fun (lifting_law : LiftingEvidence) => lift_commutes point)

theorem covering_lift_law.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (lift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (LiftingEvidence : Prop), forall (lift_data : @CoveringLiftData.{u,v,w} Total Base Source projection sourceMap lift totalOpen baseOpen sourceOpen EvenCoverEvidence LiftingEvidence), LiftingEvidence :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun lift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun LiftingEvidence => fun lift_data => lift_data LiftingEvidence (fun (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) => fun (source_continuous : @ContinuousMap.{w,v} Source Base sourceMap sourceOpen baseOpen) => fun (lift_continuous : @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen) => fun (lift_commutes : forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point)) => fun (lifting_law : LiftingEvidence) => lifting_law)

theorem covering_homotopy_lifting_property.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (lift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (LiftingEvidence : Prop), forall (lift_data : @CoveringLiftData.{u,v,w} Total Base Source projection sourceMap lift totalOpen baseOpen sourceOpen EvenCoverEvidence LiftingEvidence), @HomotopyLiftingProperty.{u,v,w} Total Base Source projection totalOpen baseOpen sourceOpen LiftingEvidence :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun lift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun LiftingEvidence => fun lift_data => @homotopy_lifting_property_intro.{u,v,w} Total Base Source projection totalOpen baseOpen sourceOpen LiftingEvidence (@covering_map_projection_continuous.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence (lift_data (@CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) (fun (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) => fun (source_continuous : @ContinuousMap.{w,v} Source Base sourceMap sourceOpen baseOpen) => fun (lift_continuous : @ContinuousMap.{w,u} Source Total lift sourceOpen totalOpen) => fun (lift_commutes : forall (point : Source), @Eq.{v} Base (projection (lift point)) (sourceMap point)) => fun (lifting_law : LiftingEvidence) => covering))) (@covering_lift_law.{u,v,w} Total Base Source projection sourceMap lift totalOpen baseOpen sourceOpen EvenCoverEvidence LiftingEvidence lift_data)

theorem unique_covering_lift_route_intro.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (leftLift : forall (point : Source), Total), forall (rightLift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (SourceConnectedEvidence : Prop), forall (AgreementAtBasepointEvidence : Prop), forall (UniqueLiftEvidence : Prop), forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (source_connected : SourceConnectedEvidence), forall (agreement_at_basepoint : AgreementAtBasepointEvidence), forall (left_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)), forall (right_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)), forall (unique_lift_law : SourceConnectedEvidence -> AgreementAtBasepointEvidence -> (forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)) -> (forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)) -> UniqueLiftEvidence), @UniqueCoveringLiftRoute.{u,v,w} Total Base Source projection sourceMap leftLift rightLift totalOpen baseOpen sourceOpen EvenCoverEvidence SourceConnectedEvidence AgreementAtBasepointEvidence UniqueLiftEvidence :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun leftLift => fun rightLift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun SourceConnectedEvidence => fun AgreementAtBasepointEvidence => fun UniqueLiftEvidence => fun covering => fun source_connected => fun agreement_at_basepoint => fun left_lift_commutes => fun right_lift_commutes => fun unique_lift_law => fun (P : Prop) => fun (mk : forall (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence), forall (source_connected : SourceConnectedEvidence), forall (agreement_at_basepoint : AgreementAtBasepointEvidence), forall (left_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)), forall (right_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)), forall (unique_lift_law : SourceConnectedEvidence -> AgreementAtBasepointEvidence -> (forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)) -> (forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)) -> UniqueLiftEvidence), P) => mk covering source_connected agreement_at_basepoint left_lift_commutes right_lift_commutes unique_lift_law

theorem unique_covering_lift_evidence.{u,v,w} :
  forall (Total : Sort u), forall (Base : Sort v), forall (Source : Sort w), forall (projection : forall (point : Total), Base), forall (sourceMap : forall (point : Source), Base), forall (leftLift : forall (point : Source), Total), forall (rightLift : forall (point : Source), Total), forall (totalOpen : forall (subset : forall (point : Total), Prop), Prop), forall (baseOpen : forall (subset : forall (point : Base), Prop), Prop), forall (sourceOpen : forall (subset : forall (point : Source), Prop), Prop), forall (EvenCoverEvidence : forall (basepoint : Base), Prop), forall (SourceConnectedEvidence : Prop), forall (AgreementAtBasepointEvidence : Prop), forall (UniqueLiftEvidence : Prop), forall (route : @UniqueCoveringLiftRoute.{u,v,w} Total Base Source projection sourceMap leftLift rightLift totalOpen baseOpen sourceOpen EvenCoverEvidence SourceConnectedEvidence AgreementAtBasepointEvidence UniqueLiftEvidence), UniqueLiftEvidence :=
  fun Total => fun Base => fun Source => fun projection => fun sourceMap => fun leftLift => fun rightLift => fun totalOpen => fun baseOpen => fun sourceOpen => fun EvenCoverEvidence => fun SourceConnectedEvidence => fun AgreementAtBasepointEvidence => fun UniqueLiftEvidence => fun route => route UniqueLiftEvidence (fun (covering : @CoveringMap.{u,v} Total Base projection totalOpen baseOpen EvenCoverEvidence) => fun (source_connected : SourceConnectedEvidence) => fun (agreement_at_basepoint : AgreementAtBasepointEvidence) => fun (left_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)) => fun (right_lift_commutes : forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)) => fun (unique_lift_law : SourceConnectedEvidence -> AgreementAtBasepointEvidence -> (forall (point : Source), @Eq.{v} Base (projection (leftLift point)) (sourceMap point)) -> (forall (point : Source), @Eq.{v} Base (projection (rightLift point)) (sourceMap point)) -> UniqueLiftEvidence) => unique_lift_law source_connected agreement_at_basepoint left_lift_commutes right_lift_commutes)

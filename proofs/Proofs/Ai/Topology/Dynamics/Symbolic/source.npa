  fun Alphabet => fun Index => fun Sequence => fun alphabetOpen => fun sequenceOpen => fun projection => fun shift => fun FiniteIndexEvidence => fun CylinderBasisEvidence => fun SubshiftEvidence => fun ShiftInvariantEvidence => fun ShiftSpacePropertyEvidence => fun SubshiftCompactnessPrerequisiteEvidence => fun SubshiftCompactnessEvidence => fun CylinderSetBasisEvidence => fun SymbolicConjugacyEvidence => fun route => route (CylinderSetBasisEvidence) (fun (shift_space : @SymbolicShiftSpace.{a,f,i,q} Alphabet Index Sequence alphabetOpen sequenceOpen projection shift FiniteIndexEvidence CylinderBasisEvidence SubshiftEvidence ShiftInvariantEvidence) => fun (shift_space_property_law : @SymbolicShiftSpace.{a,f,i,q} Alphabet Index Sequence alphabetOpen sequenceOpen projection shift FiniteIndexEvidence CylinderBasisEvidence SubshiftEvidence ShiftInvariantEvidence -> ShiftSpacePropertyEvidence) => fun (subshift_compactness_law : @SymbolicShiftSpace.{a,f,i,q} Alphabet Index Sequence alphabetOpen sequenceOpen projection shift FiniteIndexEvidence CylinderBasisEvidence SubshiftEvidence ShiftInvariantEvidence -> SubshiftCompactnessPrerequisiteEvidence -> SubshiftCompactnessEvidence) => fun (cylinder_set_basis_law : @SymbolicShiftSpace.{a,f,i,q} Alphabet Index Sequence alphabetOpen sequenceOpen projection shift FiniteIndexEvidence CylinderBasisEvidence SubshiftEvidence ShiftInvariantEvidence -> CylinderSetBasisEvidence) => fun (symbolic_conjugacy_law : @SymbolicShiftSpace.{a,f,i,q} Alphabet Index Sequence alphabetOpen sequenceOpen projection shift FiniteIndexEvidence CylinderBasisEvidence SubshiftEvidence ShiftInvariantEvidence -> SymbolicConjugacyEvidence) => cylinder_set_basis_law shift_space)


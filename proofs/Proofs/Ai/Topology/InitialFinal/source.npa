def OpenPreimageRoute.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => forall (target_subset : forall (y : Y), Prop), forall (target_open : targetOpen target_subset), sourceOpen (@MapPreimage.{u,v} X Y f target_subset)

def InitialTopologyRoute.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => forall (P : Prop), forall (mk : forall (preimage_open_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen), forall (minimal_law : forall (candidateOpen : forall (subset : forall (x : X), Prop), Prop), forall (candidate_preimage_law : @OpenPreimageRoute.{u,v} X Y f candidateOpen targetOpen), @TopologyFinerThan.{u} X candidateOpen sourceOpen), P), P

def FinalTopologyRoute.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), Prop :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => forall (P : Prop), forall (mk : forall (final_open_law : forall (target_subset : forall (y : Y), Prop), forall (preimage_open : sourceOpen (@MapPreimage.{u,v} X Y f target_subset)), targetOpen target_subset), forall (final_preimage_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen), P), P

def EmbeddingInitialHook.{u,v} :
  forall (X : Sort u), forall (Sub : Sort v), forall (embed : forall (point : Sub), X), forall (ambientOpen : forall (subset : forall (x : X), Prop), Prop), forall (subspaceOpen : forall (subset : forall (point : Sub), Prop), Prop), Prop :=
  fun X => fun Sub => fun embed => fun ambientOpen => fun subspaceOpen => @InitialTopologyRoute.{v,u} Sub X embed subspaceOpen ambientOpen

def ProductInitialHook.{l,p,r} :
  forall (Left : Sort l), forall (Right : Sort r), forall (Product : Sort p), forall (fst : forall (point : Product), Left), forall (snd : forall (point : Product), Right), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (leftOpen : forall (subset : forall (left : Left), Prop), Prop), forall (rightOpen : forall (subset : forall (right : Right), Prop), Prop), Prop :=
  fun Left => fun Right => fun Product => fun fst => fun snd => fun productOpen => fun leftOpen => fun rightOpen => forall (P : Prop), forall (mk : forall (left_initial_route : @InitialTopologyRoute.{p,l} Product Left fst productOpen leftOpen), forall (right_initial_route : @InitialTopologyRoute.{p,r} Product Right snd productOpen rightOpen), P), P

def QuotientFinalHook.{u,v} :
  forall (X : Sort u), forall (Quotient : Sort v), forall (quotient : forall (x : X), Quotient), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (quotientOpen : forall (subset : forall (q : Quotient), Prop), Prop), Prop :=
  fun X => fun Quotient => fun quotient => fun sourceOpen => fun quotientOpen => @FinalTopologyRoute.{u,v} X Quotient quotient sourceOpen quotientOpen

theorem open_preimage_route_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (preimage_open_law : forall (target_subset : forall (y : Y), Prop), forall (target_open : targetOpen target_subset), sourceOpen (@MapPreimage.{u,v} X Y f target_subset)), @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun preimage_open_law => preimage_open_law

theorem open_preimage_route_apply.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (route : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen), forall (target_subset : forall (y : Y), Prop), forall (target_open : targetOpen target_subset), sourceOpen (@MapPreimage.{u,v} X Y f target_subset) :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun route => fun target_subset => fun target_open => route target_subset target_open

theorem initial_topology_route_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (preimage_open_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen), forall (minimal_law : forall (candidateOpen : forall (subset : forall (x : X), Prop), Prop), forall (candidate_preimage_law : @OpenPreimageRoute.{u,v} X Y f candidateOpen targetOpen), @TopologyFinerThan.{u} X candidateOpen sourceOpen), @InitialTopologyRoute.{u,v} X Y f sourceOpen targetOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun preimage_open_law => fun minimal_law => fun (P : Prop) => fun (mk : forall (preimage_open_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen), forall (minimal_law : forall (candidateOpen : forall (subset : forall (x : X), Prop), Prop), forall (candidate_preimage_law : @OpenPreimageRoute.{u,v} X Y f candidateOpen targetOpen), @TopologyFinerThan.{u} X candidateOpen sourceOpen), P) => mk preimage_open_law minimal_law

theorem initial_topology_preimage_open.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (route : @InitialTopologyRoute.{u,v} X Y f sourceOpen targetOpen), @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun route => route (@OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen) (fun (preimage_open_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen) => fun (minimal_law : forall (candidateOpen : forall (subset : forall (x : X), Prop), Prop), forall (candidate_preimage_law : @OpenPreimageRoute.{u,v} X Y f candidateOpen targetOpen), @TopologyFinerThan.{u} X candidateOpen sourceOpen) => preimage_open_law)

theorem initial_topology_minimal.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (route : @InitialTopologyRoute.{u,v} X Y f sourceOpen targetOpen), forall (candidateOpen : forall (subset : forall (x : X), Prop), Prop), forall (candidate_preimage_law : @OpenPreimageRoute.{u,v} X Y f candidateOpen targetOpen), @TopologyFinerThan.{u} X candidateOpen sourceOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun route => fun candidateOpen => fun candidate_preimage_law => route (@TopologyFinerThan.{u} X candidateOpen sourceOpen) (fun (preimage_open_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen) => fun (minimal_law : forall (candidateOpen : forall (subset : forall (x : X), Prop), Prop), forall (candidate_preimage_law : @OpenPreimageRoute.{u,v} X Y f candidateOpen targetOpen), @TopologyFinerThan.{u} X candidateOpen sourceOpen) => minimal_law candidateOpen candidate_preimage_law)

theorem final_topology_route_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (final_open_law : forall (target_subset : forall (y : Y), Prop), forall (preimage_open : sourceOpen (@MapPreimage.{u,v} X Y f target_subset)), targetOpen target_subset), forall (final_preimage_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen), @FinalTopologyRoute.{u,v} X Y f sourceOpen targetOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun final_open_law => fun final_preimage_law => fun (P : Prop) => fun (mk : forall (final_open_law : forall (target_subset : forall (y : Y), Prop), forall (preimage_open : sourceOpen (@MapPreimage.{u,v} X Y f target_subset)), targetOpen target_subset), forall (final_preimage_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen), P) => mk final_open_law final_preimage_law

theorem final_topology_open_from_preimage.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (route : @FinalTopologyRoute.{u,v} X Y f sourceOpen targetOpen), forall (target_subset : forall (y : Y), Prop), forall (preimage_open : sourceOpen (@MapPreimage.{u,v} X Y f target_subset)), targetOpen target_subset :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun route => fun target_subset => fun preimage_open => route (targetOpen target_subset) (fun (final_open_law : forall (target_subset : forall (y : Y), Prop), forall (preimage_open : sourceOpen (@MapPreimage.{u,v} X Y f target_subset)), targetOpen target_subset) => fun (final_preimage_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen) => final_open_law target_subset preimage_open)

theorem final_topology_preimage_open.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (route : @FinalTopologyRoute.{u,v} X Y f sourceOpen targetOpen), @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun route => route (@OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen) (fun (final_open_law : forall (target_subset : forall (y : Y), Prop), forall (preimage_open : sourceOpen (@MapPreimage.{u,v} X Y f target_subset)), targetOpen target_subset) => fun (final_preimage_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen targetOpen) => final_preimage_law)

theorem final_topology_maximal.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (route : @FinalTopologyRoute.{u,v} X Y f sourceOpen targetOpen), forall (candidateOpen : forall (subset : forall (y : Y), Prop), Prop), forall (candidate_preimage_law : @OpenPreimageRoute.{u,v} X Y f sourceOpen candidateOpen), @TopologyFinerThan.{v} Y targetOpen candidateOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun route => fun candidateOpen => fun candidate_preimage_law => fun (target_subset : forall (y : Y), Prop) => fun (candidate_open : candidateOpen target_subset) => @final_topology_open_from_preimage.{u,v} X Y f sourceOpen targetOpen route target_subset (candidate_preimage_law target_subset candidate_open)

theorem product_initial_hook_intro.{l,p,r} :
  forall (Left : Sort l), forall (Right : Sort r), forall (Product : Sort p), forall (fst : forall (point : Product), Left), forall (snd : forall (point : Product), Right), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (leftOpen : forall (subset : forall (left : Left), Prop), Prop), forall (rightOpen : forall (subset : forall (right : Right), Prop), Prop), forall (left_initial_route : @InitialTopologyRoute.{p,l} Product Left fst productOpen leftOpen), forall (right_initial_route : @InitialTopologyRoute.{p,r} Product Right snd productOpen rightOpen), @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen :=
  fun Left => fun Right => fun Product => fun fst => fun snd => fun productOpen => fun leftOpen => fun rightOpen => fun left_initial_route => fun right_initial_route => fun (P : Prop) => fun (mk : forall (left_initial_route : @InitialTopologyRoute.{p,l} Product Left fst productOpen leftOpen), forall (right_initial_route : @InitialTopologyRoute.{p,r} Product Right snd productOpen rightOpen), P) => mk left_initial_route right_initial_route

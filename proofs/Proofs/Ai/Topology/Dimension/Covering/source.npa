  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (CoverIndex : Sort c), forall (coverSet : forall (idx : CoverIndex), forall (x : X), Prop), forall (RefinementIndex : Sort r), forall (refinementSet : forall (idx : RefinementIndex), forall (x : X), Prop), forall (DimensionBound : Sort d), forall (bound : DimensionBound), forall (CoveringDimensionEvidence : Prop), forall (FiniteOrderRefinementEvidence : Prop), forall (R : Sort m), forall (dist : forall (a : X), forall (b : X), R), forall (lt : forall (a : R), forall (b : R), Prop), forall (MetricDimensionPrerequisiteEvidence : Prop), forall (CohomologyPrerequisiteEvidence : Prop), forall (LebesgueCoveringDimensionEvidence : Prop), forall (ProductDimensionInequalityEvidence : Prop), forall (CompactMetricDimensionEvidence : Prop), forall (CohomologicalDimensionEvidence : Prop), forall (route : @CoveringDimensionTheoremRoute.{c,d,i,m,r,t,u} X isOpen CoverIndex coverSet RefinementIndex refinementSet DimensionBound bound CoveringDimensionEvidence FiniteOrderRefinementEvidence R dist lt MetricDimensionPrerequisiteEvidence CohomologyPrerequisiteEvidence LebesgueCoveringDimensionEvidence ProductDimensionInequalityEvidence CompactMetricDimensionEvidence CohomologicalDimensionEvidence), CohomologicalDimensionEvidence :=
  fun X => fun isOpen => fun CoverIndex => fun coverSet => fun RefinementIndex => fun refinementSet => fun DimensionBound => fun bound => fun CoveringDimensionEvidence => fun FiniteOrderRefinementEvidence => fun R => fun dist => fun lt => fun MetricDimensionPrerequisiteEvidence => fun CohomologyPrerequisiteEvidence => fun LebesgueCoveringDimensionEvidence => fun ProductDimensionInequalityEvidence => fun CompactMetricDimensionEvidence => fun CohomologicalDimensionEvidence => fun route => route CohomologicalDimensionEvidence (fun (covering_core : @CoveringDimensionCore.{c,d,r,t,u} X isOpen CoverIndex coverSet RefinementIndex refinementSet DimensionBound bound CoveringDimensionEvidence FiniteOrderRefinementEvidence) => fun (cohomology_prerequisite_law : CohomologyPrerequisiteEvidence) => fun (metric_compact : @MetricCompactBridge.{i,t,u,m} X R dist lt isOpen) => fun (metric_dimension_prerequisite_law : MetricDimensionPrerequisiteEvidence) => fun (lebesgue_dimension_law : @CoveringDimensionCore.{c,d,r,t,u} X isOpen CoverIndex coverSet RefinementIndex refinementSet DimensionBound bound CoveringDimensionEvidence FiniteOrderRefinementEvidence -> LebesgueCoveringDimensionEvidence) => fun (product_dimension_law : @CoveringDimensionCore.{c,d,r,t,u} X isOpen CoverIndex coverSet RefinementIndex refinementSet DimensionBound bound CoveringDimensionEvidence FiniteOrderRefinementEvidence -> ProductDimensionInequalityEvidence) => fun (compact_metric_dimension_law : @CoveringDimensionCore.{c,d,r,t,u} X isOpen CoverIndex coverSet RefinementIndex refinementSet DimensionBound bound CoveringDimensionEvidence FiniteOrderRefinementEvidence -> @MetricCompactBridge.{i,t,u,m} X R dist lt isOpen -> MetricDimensionPrerequisiteEvidence -> CompactMetricDimensionEvidence) => fun (cohomological_dimension_law : @CoveringDimensionCore.{c,d,r,t,u} X isOpen CoverIndex coverSet RefinementIndex refinementSet DimensionBound bound CoveringDimensionEvidence FiniteOrderRefinementEvidence -> CohomologyPrerequisiteEvidence -> CohomologicalDimensionEvidence) => cohomological_dimension_law covering_core cohomology_prerequisite_law)

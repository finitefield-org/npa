def TopologicalSimplex.{d,s} :
  forall (Dimension : Sort d), forall (Simplex : forall (n : Dimension), Sort s), forall (Face : forall (n : Dimension), forall (idx : Dimension), forall (point : Simplex n), Simplex n), forall (Degeneracy : forall (n : Dimension), forall (idx : Dimension), forall (point : Simplex n), Simplex n), forall (SimplexLaws : Prop), Prop :=
  fun Dimension => fun Simplex => fun Face => fun Degeneracy => fun SimplexLaws => forall (P : Prop), forall (mk : forall (simplex_laws : SimplexLaws), P), P

def SingularSimplex.{d,s,u} :
  forall (X : Sort u), forall (Dimension : Sort d), forall (Simplex : forall (n : Dimension), Sort s), forall (n : Dimension), forall (simplexOpen : forall (subset : forall (p : Simplex n), Prop), Prop), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (map : forall (p : Simplex n), X), Prop :=
  fun X => fun Dimension => fun Simplex => fun n => fun simplexOpen => fun isOpen => fun map => forall (P : Prop), forall (mk : forall (continuous : @ContinuousMap.{s,u} (Simplex n) X map simplexOpen isOpen), P), P

def SingularChainGroupCore.{c,d,u} :
  forall (X : Sort u), forall (Degree : Sort d), forall (degree : Degree), forall (Chain : Sort c), forall (zero : Chain), forall (add : forall (left : Chain), forall (right : Chain), Chain), forall (neg : forall (chain : Chain), Chain), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (GeneratorEvidence : Prop), Prop :=
  fun X => fun Degree => fun degree => fun Chain => fun zero => fun add => fun neg => fun isOpen => fun GeneratorEvidence => forall (P : Prop), forall (mk : forall (group_law : @GroupLawArgs.{c} Chain zero add neg), forall (generator_law : GeneratorEvidence), P), P

def BoundaryOperator.{c,d} :
  forall (ChainN : Sort c), forall (zeroN : ChainN), forall (addN : forall (a : ChainN), forall (b : ChainN), ChainN), forall (negN : forall (a : ChainN), ChainN), forall (ChainPrev : Sort d), forall (zeroPrev : ChainPrev), forall (addPrev : forall (a : ChainPrev), forall (b : ChainPrev), ChainPrev), forall (negPrev : forall (a : ChainPrev), ChainPrev), forall (boundary : forall (chain : ChainN), ChainPrev), Prop :=

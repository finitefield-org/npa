theorem singular_homology_cycle_law.{a,b,c,h} :
  forall (ChainN : Sort a), forall (ChainPrev : Sort b), forall (ChainPrevPrev : Sort c), forall (boundary_n : forall (chain : ChainN), ChainPrev), forall (boundary_prev : forall (chain : ChainPrev), ChainPrevPrev), forall (zeroPrevPrev : ChainPrevPrev), forall (Homology : Sort h), forall (zeroH : Homology), forall (addH : forall (left : Homology), forall (right : Homology), Homology), forall (negH : forall (homology_class : Homology), Homology), forall (class_of_cycle : forall (cycle : ChainN), Homology), forall (CycleEvidence : forall (chain : ChainN), Prop), forall (BoundaryEvidence : forall (chain : ChainN), Prop), forall (core : @SingularHomologyGroupCore.{a,b,c,h} ChainN ChainPrev ChainPrevPrev boundary_n boundary_prev zeroPrevPrev Homology zeroH addH negH class_of_cycle CycleEvidence BoundaryEvidence), forall (chain : ChainN), CycleEvidence chain :=
  fun ChainN => fun ChainPrev => fun ChainPrevPrev => fun boundary_n => fun boundary_prev => fun zeroPrevPrev => fun Homology => fun zeroH => fun addH => fun negH => fun class_of_cycle => fun CycleEvidence => fun BoundaryEvidence => fun core => fun chain => core (CycleEvidence chain) (fun (boundary_square_zero : @BoundarySquaredZero.{a,b,c} ChainN ChainPrev ChainPrevPrev zeroPrevPrev boundary_n boundary_prev) => fun (homology_group_law : @GroupLawArgs.{h} Homology zeroH addH negH) => fun (cycle_law : forall (chain : ChainN), CycleEvidence chain) => fun (boundary_law : forall (chain : ChainN), BoundaryEvidence chain) => cycle_law chain)

theorem singular_homology_boundary_law.{a,b,c,h} :
  forall (ChainN : Sort a), forall (ChainPrev : Sort b), forall (ChainPrevPrev : Sort c), forall (boundary_n : forall (chain : ChainN), ChainPrev), forall (boundary_prev : forall (chain : ChainPrev), ChainPrevPrev), forall (zeroPrevPrev : ChainPrevPrev), forall (Homology : Sort h), forall (zeroH : Homology), forall (addH : forall (left : Homology), forall (right : Homology), Homology), forall (negH : forall (homology_class : Homology), Homology), forall (class_of_cycle : forall (cycle : ChainN), Homology), forall (CycleEvidence : forall (chain : ChainN), Prop), forall (BoundaryEvidence : forall (chain : ChainN), Prop), forall (core : @SingularHomologyGroupCore.{a,b,c,h} ChainN ChainPrev ChainPrevPrev boundary_n boundary_prev zeroPrevPrev Homology zeroH addH negH class_of_cycle CycleEvidence BoundaryEvidence), forall (chain : ChainN), BoundaryEvidence chain :=
  fun ChainN => fun ChainPrev => fun ChainPrevPrev => fun boundary_n => fun boundary_prev => fun zeroPrevPrev => fun Homology => fun zeroH => fun addH => fun negH => fun class_of_cycle => fun CycleEvidence => fun BoundaryEvidence => fun core => fun chain => core (BoundaryEvidence chain) (fun (boundary_square_zero : @BoundarySquaredZero.{a,b,c} ChainN ChainPrev ChainPrevPrev zeroPrevPrev boundary_n boundary_prev) => fun (homology_group_law : @GroupLawArgs.{h} Homology zeroH addH negH) => fun (cycle_law : forall (chain : ChainN), CycleEvidence chain) => fun (boundary_law : forall (chain : ChainN), BoundaryEvidence chain) => boundary_law chain)

theorem singular_homology_functoriality_intro.{h,k,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (HX : Sort h), forall (zeroX : HX), forall (addX : forall (a : HX), forall (b : HX), HX), forall (negX : forall (a : HX), HX), forall (HY : Sort k), forall (zeroY : HY), forall (addY : forall (a : HY), forall (b : HY), HY), forall (negY : forall (a : HY), HY), forall (induced : forall (homology_class : HX), HY), forall (continuous : @ContinuousMap.{u,v} X Y f sourceOpen targetOpen), forall (source_group : @GroupLawArgs.{h} HX zeroX addX negX), forall (target_group : @GroupLawArgs.{k} HY zeroY addY negY), forall (induced_hom : @GroupHomLawArgs.{h,k} HX zeroX addX negX HY zeroY addY negY induced), @SingularHomologyFunctoriality.{h,k,u,v} X Y f sourceOpen targetOpen HX zeroX addX negX HY zeroY addY negY induced :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun HX => fun zeroX => fun addX => fun negX => fun HY => fun zeroY => fun addY => fun negY => fun induced => fun continuous => fun source_group => fun target_group => fun induced_hom => fun (P : Prop) => fun (mk : forall (continuous : @ContinuousMap.{u,v} X Y f sourceOpen targetOpen), forall (source_group : @GroupLawArgs.{h} HX zeroX addX negX), forall (target_group : @GroupLawArgs.{k} HY zeroY addY negY), forall (induced_hom : @GroupHomLawArgs.{h,k} HX zeroX addX negX HY zeroY addY negY induced), P) => mk continuous source_group target_group induced_hom

theorem singular_homology_functoriality_hom.{h,k,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (HX : Sort h), forall (zeroX : HX), forall (addX : forall (a : HX), forall (b : HX), HX), forall (negX : forall (a : HX), HX), forall (HY : Sort k), forall (zeroY : HY), forall (addY : forall (a : HY), forall (b : HY), HY), forall (negY : forall (a : HY), HY), forall (induced : forall (homology_class : HX), HY), forall (route : @SingularHomologyFunctoriality.{h,k,u,v} X Y f sourceOpen targetOpen HX zeroX addX negX HY zeroY addY negY induced), @GroupHomLawArgs.{h,k} HX zeroX addX negX HY zeroY addY negY induced :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun HX => fun zeroX => fun addX => fun negX => fun HY => fun zeroY => fun addY => fun negY => fun induced => fun route => route (@GroupHomLawArgs.{h,k} HX zeroX addX negX HY zeroY addY negY induced) (fun (continuous : @ContinuousMap.{u,v} X Y f sourceOpen targetOpen) => fun (source_group : @GroupLawArgs.{h} HX zeroX addX negX) => fun (target_group : @GroupLawArgs.{k} HY zeroY addY negY) => fun (induced_hom : @GroupHomLawArgs.{h,k} HX zeroX addX negX HY zeroY addY negY induced) => induced_hom)

theorem singular_homology_functoriality_continuous.{h,k,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (HX : Sort h), forall (zeroX : HX), forall (addX : forall (a : HX), forall (b : HX), HX), forall (negX : forall (a : HX), HX), forall (HY : Sort k), forall (zeroY : HY), forall (addY : forall (a : HY), forall (b : HY), HY), forall (negY : forall (a : HY), HY), forall (induced : forall (homology_class : HX), HY), forall (route : @SingularHomologyFunctoriality.{h,k,u,v} X Y f sourceOpen targetOpen HX zeroX addX negX HY zeroY addY negY induced), @ContinuousMap.{u,v} X Y f sourceOpen targetOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun HX => fun zeroX => fun addX => fun negX => fun HY => fun zeroY => fun addY => fun negY => fun induced => fun route => route (@ContinuousMap.{u,v} X Y f sourceOpen targetOpen) (fun (continuous : @ContinuousMap.{u,v} X Y f sourceOpen targetOpen) => fun (source_group : @GroupLawArgs.{h} HX zeroX addX negX) => fun (target_group : @GroupLawArgs.{k} HY zeroY addY negY) => fun (induced_hom : @GroupHomLawArgs.{h,k} HX zeroX addX negX HY zeroY addY negY induced) => continuous)


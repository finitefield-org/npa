  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (HX : Sort h), forall (zeroX : HX), forall (addX : forall (a : HX), forall (b : HX), HX), forall (negX : forall (a : HX), HX), forall (HY : Sort k), forall (zeroY : HY), forall (addY : forall (a : HY), forall (b : HY), HY), forall (negY : forall (a : HY), HY), forall (induced : forall (homology_class : HX), HY), forall (route : @SingularHomologyFunctoriality.{h,k,u,v} X Y f sourceOpen targetOpen HX zeroX addX negX HY zeroY addY negY induced), @GroupLawArgs.{k} HY zeroY addY negY :=

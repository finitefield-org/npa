def BoundarySquaredZero.{a,b,c} :
  forall (ChainN : Sort a), forall (ChainPrev : Sort b), forall (ChainPrevPrev : Sort c), forall (zeroPrevPrev : ChainPrevPrev), forall (boundary_n : forall (chain : ChainN), ChainPrev), forall (boundary_prev : forall (chain : ChainPrev), ChainPrevPrev), Prop :=

theorem generated_binary_intersection_open.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_intersection_refinement_law : forall (left_idx : BasisIndex), forall (right_idx : BasisIndex), forall (x : X), forall (left_mem : basis left_idx x), forall (right_mem : basis right_idx x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left_idx) (basis right_idx)) x), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), forall (left_open : @GeneratedTopology.{b,u} X BasisIndex basis left), forall (right_open : @GeneratedTopology.{b,u} X BasisIndex basis right), @GeneratedTopology.{b,u} X BasisIndex basis (@SetIntersection.{u} X left right) :=
  fun X => fun BasisIndex => fun basis => fun basis_intersection_refinement_law => fun left => fun right => fun left_open => fun right_open => fun (x : X) => fun (h : @SetIntersection.{u} X left right x) => left_open x (@set_intersection_left.{u} X left right x h) (@BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X left right) x) (fun (left_idx : BasisIndex) => fun (left_member : basis left_idx x) => fun (left_contained : forall (y : X), forall (hy : basis left_idx y), left y) => right_open x (@set_intersection_right.{u} X left right x h) (@BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X left right) x) (fun (right_idx : BasisIndex) => fun (right_member : basis right_idx x) => fun (right_contained : forall (y : X), forall (hy : basis right_idx y), right y) => basis_intersection_refinement_law left_idx right_idx x left_member right_member (@BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X left right) x) (fun (meet_idx : BasisIndex) => fun (meet_member : basis meet_idx x) => fun (meet_contained : forall (y : X), forall (hy : basis meet_idx y), @SetIntersection.{u} X (basis left_idx) (basis right_idx) y) => @basis_refines_intro.{b,u} X BasisIndex basis (@SetIntersection.{u} X left right) x meet_idx meet_member (fun (y : X) => fun (hy : basis meet_idx y) => @set_intersection_intro.{u} X left right y (left_contained y (@set_intersection_left.{u} X (basis left_idx) (basis right_idx) y (meet_contained y hy))) (right_contained y (@set_intersection_right.{u} X (basis left_idx) (basis right_idx) y (meet_contained y hy)))))))

theorem generated_indexed_union_open.{b,j,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (UnionIndex : Sort j), forall (family : forall (idx : UnionIndex), forall (x : X), Prop), forall (all_open : forall (idx : UnionIndex), @GeneratedTopology.{b,u} X BasisIndex basis (family idx)), @GeneratedTopology.{b,u} X BasisIndex basis (@IndexedUnion.{j,u} X UnionIndex family) :=
  fun X => fun BasisIndex => fun basis => fun UnionIndex => fun family => fun all_open => fun (x : X) => fun (union_member : @IndexedUnion.{j,u} X UnionIndex family x) => union_member (@BasisRefinesAt.{b,u} X BasisIndex basis (@IndexedUnion.{j,u} X UnionIndex family) x) (fun (family_idx : UnionIndex) => fun (member : family family_idx x) => all_open family_idx x member (@BasisRefinesAt.{b,u} X BasisIndex basis (@IndexedUnion.{j,u} X UnionIndex family) x) (fun (basis_idx : BasisIndex) => fun (basis_member : basis basis_idx x) => fun (contained : forall (y : X), forall (hy : basis basis_idx y), family family_idx y) => @basis_refines_intro.{b,u} X BasisIndex basis (@IndexedUnion.{j,u} X UnionIndex family) x basis_idx basis_member (fun (y : X) => fun (hy : basis basis_idx y) => @indexed_union_intro.{j,u} X UnionIndex family y family_idx (contained y hy))))

theorem generated_topology_law_package.{b,j,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_args : @TopologicalBasis.{b,u} X (@GeneratedTopology.{b,u} X BasisIndex basis) BasisIndex basis), @TopologicalSpaceLawPackage.{j,u} X (@GeneratedTopology.{b,u} X BasisIndex basis) :=
  fun X => fun BasisIndex => fun basis => fun basis_args => @topological_space_law_intro.{j,u} X (@GeneratedTopology.{b,u} X BasisIndex basis) (@generated_universal_open.{b,u} X BasisIndex basis (@topological_basis_cover.{b,u} X (@GeneratedTopology.{b,u} X BasisIndex basis) BasisIndex basis basis_args)) (@generated_empty_open.{b,u} X BasisIndex basis) (fun (left : forall (x : X), Prop) => fun (right : forall (x : X), Prop) => fun (left_open : @GeneratedTopology.{b,u} X BasisIndex basis left) => fun (right_open : @GeneratedTopology.{b,u} X BasisIndex basis right) => @generated_binary_intersection_open.{b,u} X BasisIndex basis (@topological_basis_intersection_refinement.{b,u} X (@GeneratedTopology.{b,u} X BasisIndex basis) BasisIndex basis basis_args) left right left_open right_open) (fun (UnionIndex : Sort j) => fun (family : forall (idx : UnionIndex), forall (x : X), Prop) => fun (all_open : forall (idx : UnionIndex), @GeneratedTopology.{b,u} X BasisIndex basis (family idx)) => @generated_indexed_union_open.{b,j,u} X BasisIndex basis UnionIndex family all_open)

theorem topology_finer_than_refl.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), @TopologyFinerThan.{u} X isOpen isOpen :=
  fun X => fun isOpen => fun (subset : forall (x : X), Prop) => fun (open_law : isOpen subset) => open_law

theorem topology_finer_than_trans.{u} :
  forall (X : Sort u), forall (strong : forall (subset : forall (x : X), Prop), Prop), forall (middle : forall (subset : forall (x : X), Prop), Prop), forall (weak : forall (subset : forall (x : X), Prop), Prop), forall (left : @TopologyFinerThan.{u} X strong middle), forall (right : @TopologyFinerThan.{u} X middle weak), @TopologyFinerThan.{u} X strong weak :=
  fun X => fun strong => fun middle => fun weak => fun left => fun right => fun (subset : forall (x : X), Prop) => fun (open_law : weak subset) => left subset (right subset open_law)

theorem topology_finer_than_open.{u} :
  forall (X : Sort u), forall (strong : forall (subset : forall (x : X), Prop), Prop), forall (weak : forall (subset : forall (x : X), Prop), Prop), forall (comparison : @TopologyFinerThan.{u} X strong weak), forall (subset : forall (x : X), Prop), forall (open_law : weak subset), strong subset :=
  fun X => fun strong => fun weak => fun comparison => fun (subset : forall (x : X), Prop) => fun (open_law : weak subset) => comparison subset open_law

theorem generated_topology_comparison_from_basis_open.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (basis_generated_open : forall (subset : forall (x : X), Prop), forall (generated_open : @GeneratedTopology.{b,u} X BasisIndex basis subset), isOpen subset), @TopologyFinerThan.{u} X isOpen (@GeneratedTopology.{b,u} X BasisIndex basis) :=
  fun X => fun BasisIndex => fun basis => fun isOpen => fun basis_generated_open => fun (subset : forall (x : X), Prop) => fun (generated_open : @GeneratedTopology.{b,u} X BasisIndex basis subset) => basis_generated_open subset generated_open


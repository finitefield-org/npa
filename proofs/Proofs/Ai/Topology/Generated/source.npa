  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (refines : forall (x : X), forall (member : subset x), @BasisRefinesAt.{b,u} X BasisIndex basis subset x), @GeneratedTopology.{b,u} X BasisIndex basis subset :=

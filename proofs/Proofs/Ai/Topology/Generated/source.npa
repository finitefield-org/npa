  forall (X : Sort u), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (refines : forall (x : X), forall (member : subset x), @SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis subset x), @SubbasisGeneratedOpen.{f,s,u} X SubbasisIndex subbasis subset :=

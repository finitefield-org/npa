theorem generated_empty_open.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), @GeneratedTopology.{b,u} X BasisIndex basis (@EmptySet.{u} X) :=

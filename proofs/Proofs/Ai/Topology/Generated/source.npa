theorem generated_topology_basis_intro.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x), forall (basis_intersection_refinement_law : forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x), @TopologicalBasis.{b,u} X (@GeneratedTopology.{b,u} X BasisIndex basis) BasisIndex basis :=

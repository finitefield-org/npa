theorem generated_universal_open.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x), @GeneratedTopology.{b,u} X BasisIndex basis (@UniversalSet.{u} X) :=

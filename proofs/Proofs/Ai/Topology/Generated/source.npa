  forall (X : Sort u), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (x : X), forall (FiniteIndex : Sort f), forall (select : forall (k : FiniteIndex), SubbasisIndex), forall (x_mem : forall (k : FiniteIndex), subbasis (select k) x), forall (contained : forall (y : X), forall (all_mem : forall (k : FiniteIndex), subbasis (select k) y), subset y), @SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis subset x :=
  fun X => fun SubbasisIndex => fun subbasis => fun subset => fun x => fun FiniteIndex => fun select => fun x_mem => fun contained => fun (P : Prop) => fun (mk : forall (FiniteIndex : Sort f), forall (select : forall (k : FiniteIndex), SubbasisIndex), forall (x_mem : forall (k : FiniteIndex), subbasis (select k) x), forall (contained : forall (y : X), forall (all_mem : forall (k : FiniteIndex), subbasis (select k) y), subset y), P) => mk FiniteIndex select x_mem contained

theorem subbasis_refines_elim.{f,s,u} :
  forall (X : Sort u), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (x : X), forall (h : @SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis subset x), forall (P : Prop), forall (elim : forall (FiniteIndex : Sort f), forall (select : forall (k : FiniteIndex), SubbasisIndex), forall (x_mem : forall (k : FiniteIndex), subbasis (select k) x), forall (contained : forall (y : X), forall (all_mem : forall (k : FiniteIndex), subbasis (select k) y), subset y), P), P :=
  fun X => fun SubbasisIndex => fun subbasis => fun subset => fun x => fun h => fun P => fun elim => h P elim

theorem subbasis_refinement_trans.{f,s,u} :
  forall (X : Sort u), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (target : forall (x : X), Prop), forall (x : X), forall (h : @SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis subset x), forall (contained : forall (y : X), forall (hy : subset y), target y), @SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis target x :=
  fun X => fun SubbasisIndex => fun subbasis => fun subset => fun target => fun x => fun h => fun contained => h (@SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis target x) (fun (FiniteIndex : Sort f) => fun (select : forall (k : FiniteIndex), SubbasisIndex) => fun (x_mem : forall (k : FiniteIndex), subbasis (select k) x) => fun (sub_contained : forall (y : X), forall (all_mem : forall (k : FiniteIndex), subbasis (select k) y), subset y) => @subbasis_refines_intro.{f,s,u} X SubbasisIndex subbasis target x FiniteIndex select x_mem (fun (y : X) => fun (all_mem : forall (k : FiniteIndex), subbasis (select k) y) => contained y (sub_contained y all_mem)))


  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (choice_route : @SubbasisChoiceRoute.{b,f,s,u} X BasisIndex basis SubbasisIndex subbasis), @TopologyFinerThan.{u} X (@GeneratedTopology.{b,u} X BasisIndex basis) (@SubbasisGeneratedTopology.{f,s,u} X SubbasisIndex subbasis) :=

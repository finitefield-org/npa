theorem topological_basis_intro.{b,u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_open_law : forall (idx : BasisIndex), isOpen (basis idx)), forall (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x), forall (basis_intersection_refinement_law : forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x), @TopologicalBasis.{b,u} X isOpen BasisIndex basis :=
  fun X => fun isOpen => fun BasisIndex => fun basis => fun basis_open_law => fun basis_cover_law => fun basis_intersection_refinement_law => fun (P : Prop) => fun (mk : forall (basis_open_law : forall (idx : BasisIndex), isOpen (basis idx)), forall (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x), forall (basis_intersection_refinement_law : forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x), P) => mk basis_open_law basis_cover_law basis_intersection_refinement_law

theorem topological_basis_element_open.{b,u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_args : @TopologicalBasis.{b,u} X isOpen BasisIndex basis), forall (idx : BasisIndex), isOpen (basis idx) :=
  fun X => fun isOpen => fun BasisIndex => fun basis => fun basis_args => fun idx => basis_args (isOpen (basis idx)) (fun (basis_open_law : forall (idx : BasisIndex), isOpen (basis idx)) => fun (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x) => fun (basis_intersection_refinement_law : forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x) => basis_open_law idx)

theorem topological_basis_cover.{b,u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_args : @TopologicalBasis.{b,u} X isOpen BasisIndex basis), forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x :=
  fun X => fun isOpen => fun BasisIndex => fun basis => fun basis_args => fun x => basis_args (@BasisCoverAt.{b,u} X BasisIndex basis x) (fun (basis_open_law : forall (idx : BasisIndex), isOpen (basis idx)) => fun (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x) => fun (basis_intersection_refinement_law : forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x) => basis_cover_law x)

theorem topological_basis_intersection_refinement.{b,u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (basis_args : @TopologicalBasis.{b,u} X isOpen BasisIndex basis), forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x :=
  fun X => fun isOpen => fun BasisIndex => fun basis => fun basis_args => fun left => fun right => fun x => fun left_mem => fun right_mem => basis_args (@BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x) (fun (basis_open_law : forall (idx : BasisIndex), isOpen (basis idx)) => fun (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x) => fun (basis_intersection_refinement_law : forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x) => basis_intersection_refinement_law left right x left_mem right_mem)

theorem generated_basis_element_open.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (idx : BasisIndex), @GeneratedTopology.{b,u} X BasisIndex basis (basis idx) :=

def BasisCoverAt.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (x : X), Prop :=
  fun X => fun BasisIndex => fun basis => fun x => forall (P : Prop), forall (mk : forall (idx : BasisIndex), forall (member : basis idx x), P), P

def BasisRefinesAt.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (x : X), Prop :=
  fun X => fun BasisIndex => fun basis => fun subset => fun x => forall (P : Prop), forall (mk : forall (idx : BasisIndex), forall (member : basis idx x), forall (contained : forall (y : X), forall (hy : basis idx y), subset y), P), P

def BasisOpenSet.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), Prop :=
  fun X => fun BasisIndex => fun basis => fun subset => forall (x : X), forall (member : subset x), @BasisRefinesAt.{b,u} X BasisIndex basis subset x

def GeneratedTopology.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), Prop :=
  fun X => fun BasisIndex => fun basis => fun subset => @BasisOpenSet.{b,u} X BasisIndex basis subset

def TopologicalBasis.{b,u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), Prop :=
  fun X => fun isOpen => fun BasisIndex => fun basis => forall (P : Prop), forall (mk : forall (basis_open_law : forall (idx : BasisIndex), isOpen (basis idx)), forall (basis_cover_law : forall (x : X), @BasisCoverAt.{b,u} X BasisIndex basis x), forall (basis_intersection_refinement_law : forall (left : BasisIndex), forall (right : BasisIndex), forall (x : X), forall (left_mem : basis left x), forall (right_mem : basis right x), @BasisRefinesAt.{b,u} X BasisIndex basis (@SetIntersection.{u} X (basis left) (basis right)) x), P), P

def TopologyFinerThan.{u} :
  forall (X : Sort u), forall (strong : forall (subset : forall (x : X), Prop), Prop), forall (weak : forall (subset : forall (x : X), Prop), Prop), Prop :=
  fun X => fun strong => fun weak => forall (subset : forall (x : X), Prop), forall (open_law : weak subset), strong subset

def SubbasisRefinesAt.{f,s,u} :
  forall (X : Sort u), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (x : X), Prop :=
  fun X => fun SubbasisIndex => fun subbasis => fun subset => fun x => forall (P : Prop), forall (mk : forall (FiniteIndex : Sort f), forall (select : forall (k : FiniteIndex), SubbasisIndex), forall (x_mem : forall (k : FiniteIndex), subbasis (select k) x), forall (contained : forall (y : X), forall (all_mem : forall (k : FiniteIndex), subbasis (select k) y), subset y), P), P

def SubbasisGeneratedOpen.{f,s,u} :
  forall (X : Sort u), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), Prop :=
  fun X => fun SubbasisIndex => fun subbasis => fun subset => forall (x : X), forall (member : subset x), @SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis subset x

def SubbasisGeneratedTopology.{f,s,u} :
  forall (X : Sort u), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), Prop :=
  fun X => fun SubbasisIndex => fun subbasis => fun subset => @SubbasisGeneratedOpen.{f,s,u} X SubbasisIndex subbasis subset

def SubbasisChoiceRoute.{b,f,s,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (SubbasisIndex : Sort s), forall (subbasis : forall (idx : SubbasisIndex), forall (x : X), Prop), Prop :=
  fun X => fun BasisIndex => fun basis => fun SubbasisIndex => fun subbasis => forall (subset : forall (x : X), Prop), forall (x : X), forall (sub_refines : @SubbasisRefinesAt.{f,s,u} X SubbasisIndex subbasis subset x), @BasisRefinesAt.{b,u} X BasisIndex basis subset x

theorem basis_cover_intro.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (x : X), forall (idx : BasisIndex), forall (member : basis idx x), @BasisCoverAt.{b,u} X BasisIndex basis x :=
  fun X => fun BasisIndex => fun basis => fun x => fun idx => fun member => fun (P : Prop) => fun (mk : forall (idx : BasisIndex), forall (member : basis idx x), P) => mk idx member

theorem basis_cover_elim.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (x : X), forall (h : @BasisCoverAt.{b,u} X BasisIndex basis x), forall (P : Prop), forall (elim : forall (idx : BasisIndex), forall (member : basis idx x), P), P :=
  fun X => fun BasisIndex => fun basis => fun x => fun h => fun P => fun elim => h P elim

theorem basis_refines_intro.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (x : X), forall (idx : BasisIndex), forall (member : basis idx x), forall (contained : forall (y : X), forall (hy : basis idx y), subset y), @BasisRefinesAt.{b,u} X BasisIndex basis subset x :=
  fun X => fun BasisIndex => fun basis => fun subset => fun x => fun idx => fun member => fun contained => fun (P : Prop) => fun (mk : forall (idx : BasisIndex), forall (member : basis idx x), forall (contained : forall (y : X), forall (hy : basis idx y), subset y), P) => mk idx member contained

theorem basis_refines_elim.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (x : X), forall (h : @BasisRefinesAt.{b,u} X BasisIndex basis subset x), forall (P : Prop), forall (elim : forall (idx : BasisIndex), forall (member : basis idx x), forall (contained : forall (y : X), forall (hy : basis idx y), subset y), P), P :=
  fun X => fun BasisIndex => fun basis => fun subset => fun x => fun h => fun P => fun elim => h P elim

theorem basis_refinement_trans.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (target : forall (x : X), Prop), forall (x : X), forall (h : @BasisRefinesAt.{b,u} X BasisIndex basis subset x), forall (contained : forall (y : X), forall (hy : subset y), target y), @BasisRefinesAt.{b,u} X BasisIndex basis target x :=
  fun X => fun BasisIndex => fun basis => fun subset => fun target => fun x => fun h => fun contained => h (@BasisRefinesAt.{b,u} X BasisIndex basis target x) (fun (idx : BasisIndex) => fun (member : basis idx x) => fun (sub_contained : forall (y : X), forall (hy : basis idx y), subset y) => @basis_refines_intro.{b,u} X BasisIndex basis target x idx member (fun (y : X) => fun (hy : basis idx y) => contained y (sub_contained y hy)))

theorem basis_cover_refines_universal.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (x : X), forall (cover : @BasisCoverAt.{b,u} X BasisIndex basis x), @BasisRefinesAt.{b,u} X BasisIndex basis (@UniversalSet.{u} X) x :=
  fun X => fun BasisIndex => fun basis => fun x => fun cover => cover (@BasisRefinesAt.{b,u} X BasisIndex basis (@UniversalSet.{u} X) x) (fun (idx : BasisIndex) => fun (member : basis idx x) => @basis_refines_intro.{b,u} X BasisIndex basis (@UniversalSet.{u} X) x idx member (fun (y : X) => fun (hy : basis idx y) => @universal_set_member.{u} X y))

theorem basis_open_set_intro.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (refines : forall (x : X), forall (member : subset x), @BasisRefinesAt.{b,u} X BasisIndex basis subset x), @BasisOpenSet.{b,u} X BasisIndex basis subset :=
  fun X => fun BasisIndex => fun basis => fun subset => fun refines => refines

theorem basis_open_set_refines.{b,u} :
  forall (X : Sort u), forall (BasisIndex : Sort b), forall (basis : forall (idx : BasisIndex), forall (x : X), Prop), forall (subset : forall (x : X), Prop), forall (open_set : @BasisOpenSet.{b,u} X BasisIndex basis subset), forall (x : X), forall (member : subset x), @BasisRefinesAt.{b,u} X BasisIndex basis subset x :=

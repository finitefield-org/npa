  fun X => fun CoverIndex => fun family => fun SubcoverIndex => fun select => fun sub_idx => fun x => family (select sub_idx) x

def SubspaceCarrierImage.{u,v} :
  forall (X : Sort u), forall (Sub : Sort v), forall (embed : forall (point : Sub), X), forall (x : X), Prop :=
  fun X => fun Sub => fun embed => fun x => forall (Ppoint : Prop), forall (choose : forall (point : Sub), forall (point_eq : @Eq.{u} X (embed point) x), Ppoint), Ppoint


  forall (X : Sort u), forall (R : Sort v), forall (dist : forall (a : X), forall (b : X), R), forall (lt : forall (a : R), forall (b : R), Prop), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), Prop :=

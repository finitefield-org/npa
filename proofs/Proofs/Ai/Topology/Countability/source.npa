def CountableIndex.{i} :
  forall (Index : Sort i), forall (CountableEvidence : Prop), Prop :=
  fun Index => fun CountableEvidence => forall (P : Prop), forall (mk : forall (countable_law : CountableEvidence), P), P

def IndexedPointSet.{i,u} :
  forall (X : Sort u), forall (Index : Sort i), forall (point : forall (idx : Index), X), forall (x : X), Prop :=
  fun X => fun Index => fun point => fun x => forall (P : Prop), forall (mk : forall (idx : Index), forall (point_eq : @Eq.{u} X (point idx) x), P), P

def SubcoverFamily.{c,s,u} :

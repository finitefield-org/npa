  fun X => fun left_base => fun right_base => fun isOpen => fun LeftGroup => fun left_one => fun left_mul => fun left_inv => fun RightGroup => fun right_one => fun right_mul => fun right_inv => fun forward => fun backward => fun PathEvidence => fun route => fun loop => route (@Eq.{g} LeftGroup (backward (forward loop)) loop) (fun (path_between_basepoints : PathEvidence) => fun (left_group : @GroupLawArgs.{g} LeftGroup left_one left_mul left_inv) => fun (right_group : @GroupLawArgs.{g} RightGroup right_one right_mul right_inv) => fun (forward_hom : @GroupHomLawArgs.{g,g} LeftGroup left_one left_mul left_inv RightGroup right_one right_mul right_inv forward) => fun (backward_hom : @GroupHomLawArgs.{g,g} RightGroup right_one right_mul right_inv LeftGroup left_one left_mul left_inv backward) => fun (left_inverse : forall (loop : LeftGroup), @Eq.{g} LeftGroup (backward (forward loop)) loop) => fun (right_inverse : forall (loop : RightGroup), @Eq.{g} RightGroup (forward (backward loop)) loop) => left_inverse loop)

theorem basepoint_change_right_inverse.{g,u} :
  forall (X : Sort u), forall (left_base : X), forall (right_base : X), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (LeftGroup : Sort g), forall (left_one : LeftGroup), forall (left_mul : forall (a : LeftGroup), forall (b : LeftGroup), LeftGroup), forall (left_inv : forall (a : LeftGroup), LeftGroup), forall (RightGroup : Sort g), forall (right_one : RightGroup), forall (right_mul : forall (a : RightGroup), forall (b : RightGroup), RightGroup), forall (right_inv : forall (a : RightGroup), RightGroup), forall (forward : forall (loop : LeftGroup), RightGroup), forall (backward : forall (loop : RightGroup), LeftGroup), forall (PathEvidence : Prop), forall (route : @BasepointChangeIsomorphismRoute.{g,u} X left_base right_base isOpen LeftGroup left_one left_mul left_inv RightGroup right_one right_mul right_inv forward backward PathEvidence), forall (loop : RightGroup), @Eq.{g} RightGroup (forward (backward loop)) loop :=

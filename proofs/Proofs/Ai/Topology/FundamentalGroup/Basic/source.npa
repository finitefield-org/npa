theorem homotopy_equivalence_fundamental_group_route_intro.{g,h,i,p,t,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (baseX : X), forall (baseY : Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (f : forall (x : X), Y), forall (gmap : forall (y : Y), X), forall (GX : Sort g), forall (oneX : GX), forall (mulX : forall (a : GX), forall (b : GX), GX), forall (invX : forall (a : GX), GX), forall (GY : Sort h), forall (oneY : GY), forall (mulY : forall (a : GY), forall (b : GY), GY), forall (invY : forall (a : GY), GY), forall (induced : forall (loop : GX), GY), forall (IsomorphismEvidence : Prop), forall (homotopy_equivalence : @HomotopyEquivalence.{i,p,t,u,v} X Y f gmap sourceOpen targetOpen), forall (basepoint_law : @Eq.{v} Y (f baseX) baseY), forall (source_group : @GroupLawArgs.{g} GX oneX mulX invX), forall (target_group : @GroupLawArgs.{h} GY oneY mulY invY), forall (induced_hom : @GroupHomLawArgs.{g,h} GX oneX mulX invX GY oneY mulY invY induced), forall (isomorphism_law : IsomorphismEvidence), @HomotopyEquivalenceFundamentalGroupRoute.{g,h,i,p,t,u,v} X Y baseX baseY sourceOpen targetOpen f gmap GX oneX mulX invX GY oneY mulY invY induced IsomorphismEvidence :=
  fun X => fun Y => fun baseX => fun baseY => fun sourceOpen => fun targetOpen => fun f => fun gmap => fun GX => fun oneX => fun mulX => fun invX => fun GY => fun oneY => fun mulY => fun invY => fun induced => fun IsomorphismEvidence => fun homotopy_equivalence => fun basepoint_law => fun source_group => fun target_group => fun induced_hom => fun isomorphism_law => fun (P : Prop) => fun (mk : forall (homotopy_equivalence : @HomotopyEquivalence.{i,p,t,u,v} X Y f gmap sourceOpen targetOpen), forall (basepoint_law : @Eq.{v} Y (f baseX) baseY), forall (source_group : @GroupLawArgs.{g} GX oneX mulX invX), forall (target_group : @GroupLawArgs.{h} GY oneY mulY invY), forall (induced_hom : @GroupHomLawArgs.{g,h} GX oneX mulX invX GY oneY mulY invY induced), forall (isomorphism_law : IsomorphismEvidence), P) => mk homotopy_equivalence basepoint_law source_group target_group induced_hom isomorphism_law


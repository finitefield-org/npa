theorem open_cover_intro.{i,u} :
  forall (X : Sort u), forall (Index : Sort i), forall (family : forall (idx : Index), forall (x : X), Prop), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (all_open : forall (idx : Index), isOpen (family idx)), forall (covers : forall (x : X), @IndexedUnion.{i,u} X Index family x), @OpenCover.{i,u} X Index family isOpen :=

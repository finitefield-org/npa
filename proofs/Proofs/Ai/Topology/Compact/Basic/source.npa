  fun X => fun Y => fun f => fun bijective => bijective (@InjectiveMap.{u,v} X Y f) (fun (injective : @InjectiveMap.{u,v} X Y f) => fun (surjective : @SurjectiveMap.{u,v} X Y f) => injective)

theorem bijective_map_surjective.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (bijective : @BijectiveMap.{u,v} X Y f), @SurjectiveMap.{u,v} X Y f :=
  fun X => fun Y => fun f => fun bijective => bijective (@SurjectiveMap.{u,v} X Y f) (fun (injective : @InjectiveMap.{u,v} X Y f) => fun (surjective : @SurjectiveMap.{u,v} X Y f) => surjective)

theorem bijection_inverse_data_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))), forall (left_from : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset (backward (forward x))), subset x), forall (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))), forall (right_from : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset (forward (backward y))), subset y), @BijectionInverseData.{u,v} X Y forward :=
  fun X => fun Y => fun forward => fun backward => fun left_to => fun left_from => fun right_to => fun right_from => fun (P : Prop) => fun (mk : forall (backward : forall (y : Y), X), forall (left_to : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset x), subset (backward (forward x))), forall (left_from : forall (subset : forall (x : X), Prop), forall (x : X), forall (member : subset (backward (forward x))), subset x), forall (right_to : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset y), subset (forward (backward y))), forall (right_from : forall (subset : forall (y : Y), Prop), forall (y : Y), forall (member : subset (forward (backward y))), subset y), P) => mk backward left_to left_from right_to right_from

theorem compactness_invariant_transfer_intro.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (forward_law : @Homeomorphic.{u,v} X Y sourceOpen targetOpen -> @CompactSpace.{i,u} X sourceOpen -> @CompactSpace.{i,v} Y targetOpen), forall (backward_law : @Homeomorphic.{u,v} X Y sourceOpen targetOpen -> @CompactSpace.{i,v} Y targetOpen -> @CompactSpace.{i,u} X sourceOpen), @CompactnessInvariantTransfer.{i,u,v} X Y sourceOpen targetOpen :=
  fun X => fun Y => fun sourceOpen => fun targetOpen => fun forward_law => fun backward_law => @invariant_transfer_intro.{u,v} X Y sourceOpen targetOpen (@CompactSpace.{i,u} X sourceOpen) (@CompactSpace.{i,v} Y targetOpen) forward_law backward_law

theorem compactness_preserved_by_homeomorphic_space.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (transfer : @CompactnessInvariantTransfer.{i,u,v} X Y sourceOpen targetOpen), forall (homeomorphic : @Homeomorphic.{u,v} X Y sourceOpen targetOpen), forall (compact_source : @CompactSpace.{i,u} X sourceOpen), @CompactSpace.{i,v} Y targetOpen :=
  fun X => fun Y => fun sourceOpen => fun targetOpen => fun transfer => fun homeomorphic => fun compact_source => @invariant_transfer_forward.{u,v} X Y sourceOpen targetOpen (@CompactSpace.{i,u} X sourceOpen) (@CompactSpace.{i,v} Y targetOpen) transfer homeomorphic compact_source

theorem compactness_reflected_by_homeomorphic_space.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (transfer : @CompactnessInvariantTransfer.{i,u,v} X Y sourceOpen targetOpen), forall (homeomorphic : @Homeomorphic.{u,v} X Y sourceOpen targetOpen), forall (compact_target : @CompactSpace.{i,v} Y targetOpen), @CompactSpace.{i,u} X sourceOpen :=
  fun X => fun Y => fun sourceOpen => fun targetOpen => fun transfer => fun homeomorphic => fun compact_target => @invariant_transfer_backward.{u,v} X Y sourceOpen targetOpen (@CompactSpace.{i,u} X sourceOpen) (@CompactSpace.{i,v} Y targetOpen) transfer homeomorphic compact_target

theorem compact_hausdorff_continuous_bijection_homeomorphic.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (route : @CompactHausdorffBijectionHomeomorphismRoute.{i,u,v} X Y f sourceOpen targetOpen), forall (compact_source : @CompactSpace.{i,u} X sourceOpen), forall (hausdorff_target : @HausdorffSpace.{v} Y targetOpen), forall (continuous : @ContinuousMap.{u,v} X Y f sourceOpen targetOpen), forall (bijective : @BijectiveMap.{u,v} X Y f), forall (inverse_data : @BijectionInverseData.{u,v} X Y f), @Homeomorphic.{u,v} X Y sourceOpen targetOpen :=
  fun X => fun Y => fun f => fun sourceOpen => fun targetOpen => fun route => fun compact_source => fun hausdorff_target => fun continuous => fun bijective => fun inverse_data => route compact_source hausdorff_target continuous bijective inverse_data

theorem tube_lemma_route_intro.{p,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (Product : Sort p), forall (sourceOpen : forall (subset : forall (x : X), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Y), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (FiniteProductTopologyEvidence : Prop), forall (TubeLemmaEvidence : Prop), forall (finite_product_dependency : FiniteProductTopologyEvidence), forall (tube_law : FiniteProductTopologyEvidence -> TubeLemmaEvidence), @TubeLemmaRoute.{p,u,v} X Y Product sourceOpen targetOpen productOpen FiniteProductTopologyEvidence TubeLemmaEvidence :=

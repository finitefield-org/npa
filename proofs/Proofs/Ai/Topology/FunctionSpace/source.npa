def FunctionSpaceTopologyData.{f,u,v} :
  forall (Domain : Sort u), forall (Codomain : Sort v), forall (FunctionSpace : Sort f), forall (eval_fn : forall (fn : FunctionSpace), forall (x : Domain), Codomain), forall (sourceOpen : forall (subset : forall (x : Domain), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Codomain), Prop), Prop), forall (functionOpen : forall (subset : forall (fn : FunctionSpace), Prop), Prop), forall (CompactOpenLaw : Prop), forall (EvaluationContinuityLaw : Prop), Prop :=
  fun Domain => fun Codomain => fun FunctionSpace => fun eval_fn => fun sourceOpen => fun targetOpen => fun functionOpen => fun CompactOpenLaw => fun EvaluationContinuityLaw => forall (P : Prop), forall (mk : forall (compact_open_law : CompactOpenLaw), forall (evaluation_continuity_law : EvaluationContinuityLaw), P), P

def EquicontinuousFunctionFamily.{f,u,v} :
  forall (Domain : Sort u), forall (Codomain : Sort v), forall (FunctionSpace : Sort f), forall (eval_fn : forall (fn : FunctionSpace), forall (x : Domain), Codomain), forall (family : forall (fn : FunctionSpace), Prop), forall (EquicontinuityLaw : Prop), Prop :=
  fun Domain => fun Codomain => fun FunctionSpace => fun eval_fn => fun family => fun EquicontinuityLaw => forall (P : Prop), forall (mk : forall (equicontinuity_law : EquicontinuityLaw), P), P

def FunctionFamilyCompactnessData.{f} :
  forall (FunctionSpace : Sort f), forall (family : forall (fn : FunctionSpace), Prop), forall (FunctionSpaceTopologyLaw : Prop), forall (CompactFamilyLaw : Prop), Prop :=
  fun FunctionSpace => fun family => fun FunctionSpaceTopologyLaw => fun CompactFamilyLaw => forall (P : Prop), forall (mk : forall (function_space_topology_law : FunctionSpaceTopologyLaw), forall (compact_family_law : CompactFamilyLaw), P), P

def ArzelaAscoliEvidence.{f,u,v} :
  forall (Domain : Sort u), forall (Codomain : Sort v), forall (FunctionSpace : Sort f), forall (eval_fn : forall (fn : FunctionSpace), forall (x : Domain), Codomain), forall (family : forall (fn : FunctionSpace), Prop), forall (CompactDomainLaw : Prop), forall (EquicontinuityLaw : Prop), forall (PointwiseRelativeCompactnessLaw : Prop), forall (FunctionSpaceTopologyLaw : Prop), forall (ArzelaAscoliConclusion : Prop), Prop :=
  fun Domain => fun Codomain => fun FunctionSpace => fun eval_fn => fun family => fun CompactDomainLaw => fun EquicontinuityLaw => fun PointwiseRelativeCompactnessLaw => fun FunctionSpaceTopologyLaw => fun ArzelaAscoliConclusion => forall (P : Prop), forall (mk : forall (compact_domain_law : CompactDomainLaw), forall (equicontinuity_law : EquicontinuityLaw), forall (pointwise_relative_compactness_law : PointwiseRelativeCompactnessLaw), forall (function_space_topology_law : FunctionSpaceTopologyLaw), forall (arzela_ascoli_route : CompactDomainLaw -> EquicontinuityLaw -> PointwiseRelativeCompactnessLaw -> FunctionSpaceTopologyLaw -> ArzelaAscoliConclusion), P), P

theorem function_space_topology_data_intro.{f,u,v} :
  forall (Domain : Sort u), forall (Codomain : Sort v), forall (FunctionSpace : Sort f), forall (eval_fn : forall (fn : FunctionSpace), forall (x : Domain), Codomain), forall (sourceOpen : forall (subset : forall (x : Domain), Prop), Prop), forall (targetOpen : forall (subset : forall (y : Codomain), Prop), Prop), forall (functionOpen : forall (subset : forall (fn : FunctionSpace), Prop), Prop), forall (CompactOpenLaw : Prop), forall (EvaluationContinuityLaw : Prop), forall (compact_open_law : CompactOpenLaw), forall (evaluation_continuity_law : EvaluationContinuityLaw), @FunctionSpaceTopologyData.{f,u,v} Domain Codomain FunctionSpace eval_fn sourceOpen targetOpen functionOpen CompactOpenLaw EvaluationContinuityLaw :=
  fun Domain => fun Codomain => fun FunctionSpace => fun eval_fn => fun sourceOpen => fun targetOpen => fun functionOpen => fun CompactOpenLaw => fun EvaluationContinuityLaw => fun compact_open_law => fun evaluation_continuity_law => fun (P : Prop) => fun (mk : forall (compact_open_law : CompactOpenLaw), forall (evaluation_continuity_law : EvaluationContinuityLaw), P) => mk compact_open_law evaluation_continuity_law

theorem equicontinuous_function_family_intro.{f,u,v} :
  forall (Domain : Sort u), forall (Codomain : Sort v), forall (FunctionSpace : Sort f), forall (eval_fn : forall (fn : FunctionSpace), forall (x : Domain), Codomain), forall (family : forall (fn : FunctionSpace), Prop), forall (EquicontinuityLaw : Prop), forall (equicontinuity_law : EquicontinuityLaw), @EquicontinuousFunctionFamily.{f,u,v} Domain Codomain FunctionSpace eval_fn family EquicontinuityLaw :=

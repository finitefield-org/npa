  forall (Index : Sort i), forall (X : Sort u), forall (family : forall (idx : Index), forall (x : X), Prop), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (route : @ConnectedUnionRoute.{i,u} Index X family isOpen), @ConnectedSubset.{u} X isOpen (@IndexedUnion.{i,u} X Index family) :=
  fun Index => fun X => fun family => fun isOpen => fun route => route (@ConnectedSubset.{u} X isOpen (@IndexedUnion.{i,u} X Index family)) (fun (all_connected : forall (idx : Index), @ConnectedSubset.{u} X isOpen (family idx)) => fun (common_point_law : forall (left : Index), forall (right : Index), forall (Pcommon : Prop), forall (choose : forall (x : X), forall (left_mem : family left x), forall (right_mem : family right x), Pcommon), Pcommon) => fun (union_connected_law : (forall (idx : Index), @ConnectedSubset.{u} X isOpen (family idx)) -> (forall (left : Index), forall (right : Index), forall (Pcommon : Prop), forall (choose : forall (x : X), forall (left_mem : family left x), forall (right_mem : family right x), Pcommon), Pcommon) -> @ConnectedSubset.{u} X isOpen (@IndexedUnion.{i,u} X Index family)) => union_connected_law all_connected common_point_law)

theorem product_connected_route_intro.{l,p,r} :
  forall (Left : Sort l), forall (Right : Sort r), forall (Product : Sort p), forall (fst : forall (point : Product), Left), forall (snd : forall (point : Product), Right), forall (leftOpen : forall (subset : forall (left : Left), Prop), Prop), forall (rightOpen : forall (subset : forall (right : Right), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (product_topology : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen), forall (product_connected_law : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen -> @ConnectedSpace.{l} Left leftOpen -> @ConnectedSpace.{r} Right rightOpen -> @ConnectedSpace.{p} Product productOpen), @ProductConnectedRoute.{l,p,r} Left Right Product fst snd leftOpen rightOpen productOpen :=
  fun Left => fun Right => fun Product => fun fst => fun snd => fun leftOpen => fun rightOpen => fun productOpen => fun product_topology => fun product_connected_law => fun (P : Prop) => fun (mk : forall (product_topology : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen), forall (product_connected_law : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen -> @ConnectedSpace.{l} Left leftOpen -> @ConnectedSpace.{r} Right rightOpen -> @ConnectedSpace.{p} Product productOpen), P) => mk product_topology product_connected_law

theorem product_connected_route_topology.{l,p,r} :
  forall (Left : Sort l), forall (Right : Sort r), forall (Product : Sort p), forall (fst : forall (point : Product), Left), forall (snd : forall (point : Product), Right), forall (leftOpen : forall (subset : forall (left : Left), Prop), Prop), forall (rightOpen : forall (subset : forall (right : Right), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (route : @ProductConnectedRoute.{l,p,r} Left Right Product fst snd leftOpen rightOpen productOpen), @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen :=
  fun Left => fun Right => fun Product => fun fst => fun snd => fun leftOpen => fun rightOpen => fun productOpen => fun route => route (@ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen) (fun (product_topology : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen) => fun (product_connected_law : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen -> @ConnectedSpace.{l} Left leftOpen -> @ConnectedSpace.{r} Right rightOpen -> @ConnectedSpace.{p} Product productOpen) => product_topology)

theorem product_connected.{l,p,r} :
  forall (Left : Sort l), forall (Right : Sort r), forall (Product : Sort p), forall (fst : forall (point : Product), Left), forall (snd : forall (point : Product), Right), forall (leftOpen : forall (subset : forall (left : Left), Prop), Prop), forall (rightOpen : forall (subset : forall (right : Right), Prop), Prop), forall (productOpen : forall (subset : forall (point : Product), Prop), Prop), forall (route : @ProductConnectedRoute.{l,p,r} Left Right Product fst snd leftOpen rightOpen productOpen), forall (left_connected : @ConnectedSpace.{l} Left leftOpen), forall (right_connected : @ConnectedSpace.{r} Right rightOpen), @ConnectedSpace.{p} Product productOpen :=
  fun Left => fun Right => fun Product => fun fst => fun snd => fun leftOpen => fun rightOpen => fun productOpen => fun route => fun left_connected => fun right_connected => route (@ConnectedSpace.{p} Product productOpen) (fun (product_topology : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen) => fun (product_connected_law : @ProductInitialHook.{l,p,r} Left Right Product fst snd productOpen leftOpen rightOpen -> @ConnectedSpace.{l} Left leftOpen -> @ConnectedSpace.{r} Right rightOpen -> @ConnectedSpace.{p} Product productOpen) => product_connected_law product_topology left_connected right_connected)

theorem connected_component_intro.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (component : forall (x : X), Prop), forall (component_connected : @ConnectedSubset.{u} X isOpen component), forall (maximal_law : forall (candidate : forall (x : X), Prop), forall (candidate_connected : @ConnectedSubset.{u} X isOpen candidate), forall (overlaps : forall (Poverlap : Prop), forall (choose : forall (x : X), forall (candidate_mem : candidate x), forall (component_mem : component x), Poverlap), Poverlap), forall (x : X), forall (candidate_mem : candidate x), component x), @ConnectedComponent.{u} X isOpen component :=
  fun X => fun isOpen => fun component => fun component_connected => fun maximal_law => fun (P : Prop) => fun (mk : forall (component_connected : @ConnectedSubset.{u} X isOpen component), forall (maximal_law : forall (candidate : forall (x : X), Prop), forall (candidate_connected : @ConnectedSubset.{u} X isOpen candidate), forall (overlaps : forall (Poverlap : Prop), forall (choose : forall (x : X), forall (candidate_mem : candidate x), forall (component_mem : component x), Poverlap), Poverlap), forall (x : X), forall (candidate_mem : candidate x), component x), P) => mk component_connected maximal_law


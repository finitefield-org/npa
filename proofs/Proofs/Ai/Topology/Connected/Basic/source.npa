theorem connected_component_closed.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (component : forall (x : X), Prop), forall (route : @ConnectedComponentClosedRoute.{u} X isOpen component), @ClosedSet.{u} X isOpen component :=

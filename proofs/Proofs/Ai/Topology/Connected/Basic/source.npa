  fun X => fun isOpen => fun singleton_component_law => singleton_component_law

theorem totally_disconnected_components_singleton.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (totally_disconnected : @TotallyDisconnectedSpace.{u} X isOpen), forall (component : forall (x : X), Prop), forall (component_data : @ConnectedComponent.{u} X isOpen component), forall (left : X), forall (right : X), forall (left_mem : component left), forall (right_mem : component right), @Eq.{u} X left right :=
  fun X => fun isOpen => fun totally_disconnected => fun component => fun component_data => fun left => fun right => fun left_mem => fun right_mem => totally_disconnected component component_data left right left_mem right_mem

theorem local_connected_space_intro.{u} :
  forall (X : Sort u), forall (isOpen : forall (subset : forall (x : X), Prop), Prop), forall (local_law : forall (x : X), forall (neighborhood : forall (y : X), Prop), forall (neighborhood_law : @TopologicalNeighborhood.{u} X isOpen x neighborhood), forall (P : Prop), forall (choose : forall (local_domain : forall (y : X), Prop), forall (local_neighborhood : @TopologicalNeighborhood.{u} X isOpen x local_domain), forall (contained : forall (y : X), forall (local_mem : local_domain y), neighborhood y), forall (local_connected : @ConnectedSubset.{u} X isOpen local_domain), P), P), @LocalConnectedSpace.{u} X isOpen :=
  fun X => fun isOpen => fun local_law => local_law


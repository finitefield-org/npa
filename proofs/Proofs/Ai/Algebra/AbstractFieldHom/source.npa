def FieldHomLawArgs.{u,v} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (invR : forall (a : R), R), forall (S : Sort v), forall (zeroS : S), forall (oneS : S), forall (addS : forall (a : S), forall (b : S), S), forall (negS : forall (a : S), S), forall (subS : forall (a : S), forall (b : S), S), forall (mulS : forall (a : S), forall (b : S), S), forall (invS : forall (a : S), S), forall (f : forall (a : R), S), Prop :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun invR => fun S => fun zeroS => fun oneS => fun addS => fun negS => fun subS => fun mulS => fun invS => fun f => forall (P : Prop), forall (mk : forall (ring_hom_law : @RingHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR S zeroS oneS addS negS subS mulS f), forall (hom_inv_nonzero_law : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Eq.{v} S (f (invR a)) (invS (f a))), forall (hom_div_law : forall (a : R), forall (b : R), forall (hb : @Nonzero.{u} R zeroR b), @Eq.{v} S (f (@div.{u} R mulR invR a b)) (@div.{v} S mulS invS (f a) (f b))), forall (hom_preserves_nonzero_law : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Nonzero.{v} S zeroS (f a)), P), P

theorem field_hom_as_ring_hom.{u,v} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (invR : forall (a : R), R), forall (S : Sort v), forall (zeroS : S), forall (oneS : S), forall (addS : forall (a : S), forall (b : S), S), forall (negS : forall (a : S), S), forall (subS : forall (a : S), forall (b : S), S), forall (mulS : forall (a : S), forall (b : S), S), forall (invS : forall (a : S), S), forall (f : forall (a : R), S), forall (field_hom_args : @FieldHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR invR S zeroS oneS addS negS subS mulS invS f), @RingHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR S zeroS oneS addS negS subS mulS f :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun invR => fun S => fun zeroS => fun oneS => fun addS => fun negS => fun subS => fun mulS => fun invS => fun f => fun field_hom_args => field_hom_args (@RingHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR S zeroS oneS addS negS subS mulS f) (fun (ring_hom_arg : @RingHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR S zeroS oneS addS negS subS mulS f) => fun (hom_inv_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Eq.{v} S (f (invR a)) (invS (f a))) => fun (hom_div_arg : forall (a : R), forall (b : R), forall (hb : @Nonzero.{u} R zeroR b), @Eq.{v} S (f (@div.{u} R mulR invR a b)) (@div.{v} S mulS invS (f a) (f b))) => fun (hom_preserves_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Nonzero.{v} S zeroS (f a)) => ring_hom_arg)

theorem field_hom_inv_of_nonzero.{u,v} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (invR : forall (a : R), R), forall (S : Sort v), forall (zeroS : S), forall (oneS : S), forall (addS : forall (a : S), forall (b : S), S), forall (negS : forall (a : S), S), forall (subS : forall (a : S), forall (b : S), S), forall (mulS : forall (a : S), forall (b : S), S), forall (invS : forall (a : S), S), forall (f : forall (a : R), S), forall (field_hom_args : @FieldHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR invR S zeroS oneS addS negS subS mulS invS f), forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Eq.{v} S (f (invR a)) (invS (f a)) :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun invR => fun S => fun zeroS => fun oneS => fun addS => fun negS => fun subS => fun mulS => fun invS => fun f => fun field_hom_args => fun a => fun ha => field_hom_args (@Eq.{v} S (f (invR a)) (invS (f a))) (fun (ring_hom_arg : @RingHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR S zeroS oneS addS negS subS mulS f) => fun (hom_inv_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Eq.{v} S (f (invR a)) (invS (f a))) => fun (hom_div_arg : forall (a : R), forall (b : R), forall (hb : @Nonzero.{u} R zeroR b), @Eq.{v} S (f (@div.{u} R mulR invR a b)) (@div.{v} S mulS invS (f a) (f b))) => fun (hom_preserves_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Nonzero.{v} S zeroS (f a)) => hom_inv_nonzero_arg a ha)

theorem field_hom_div.{u,v} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (invR : forall (a : R), R), forall (S : Sort v), forall (zeroS : S), forall (oneS : S), forall (addS : forall (a : S), forall (b : S), S), forall (negS : forall (a : S), S), forall (subS : forall (a : S), forall (b : S), S), forall (mulS : forall (a : S), forall (b : S), S), forall (invS : forall (a : S), S), forall (f : forall (a : R), S), forall (field_hom_args : @FieldHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR invR S zeroS oneS addS negS subS mulS invS f), forall (a : R), forall (b : R), forall (hb : @Nonzero.{u} R zeroR b), @Eq.{v} S (f (@div.{u} R mulR invR a b)) (@div.{v} S mulS invS (f a) (f b)) :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun invR => fun S => fun zeroS => fun oneS => fun addS => fun negS => fun subS => fun mulS => fun invS => fun f => fun field_hom_args => fun a => fun b => fun hb => field_hom_args (@Eq.{v} S (f (@div.{u} R mulR invR a b)) (@div.{v} S mulS invS (f a) (f b))) (fun (ring_hom_arg : @RingHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR S zeroS oneS addS negS subS mulS f) => fun (hom_inv_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Eq.{v} S (f (invR a)) (invS (f a))) => fun (hom_div_arg : forall (a : R), forall (b : R), forall (hb : @Nonzero.{u} R zeroR b), @Eq.{v} S (f (@div.{u} R mulR invR a b)) (@div.{v} S mulS invS (f a) (f b))) => fun (hom_preserves_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Nonzero.{v} S zeroS (f a)) => hom_div_arg a b hb)

theorem field_hom_preserves_nonzero.{u,v} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (invR : forall (a : R), R), forall (S : Sort v), forall (zeroS : S), forall (oneS : S), forall (addS : forall (a : S), forall (b : S), S), forall (negS : forall (a : S), S), forall (subS : forall (a : S), forall (b : S), S), forall (mulS : forall (a : S), forall (b : S), S), forall (invS : forall (a : S), S), forall (f : forall (a : R), S), forall (field_hom_args : @FieldHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR invR S zeroS oneS addS negS subS mulS invS f), forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Nonzero.{v} S zeroS (f a) :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun invR => fun S => fun zeroS => fun oneS => fun addS => fun negS => fun subS => fun mulS => fun invS => fun f => fun field_hom_args => fun a => fun ha => field_hom_args (@Nonzero.{v} S zeroS (f a)) (fun (ring_hom_arg : @RingHomLawArgs.{u,v} R zeroR oneR addR negR subR mulR S zeroS oneS addS negS subS mulS f) => fun (hom_inv_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Eq.{v} S (f (invR a)) (invS (f a))) => fun (hom_div_arg : forall (a : R), forall (b : R), forall (hb : @Nonzero.{u} R zeroR b), @Eq.{v} S (f (@div.{u} R mulR invR a b)) (@div.{v} S mulS invS (f a) (f b))) => fun (hom_preserves_nonzero_arg : forall (a : R), forall (ha : @Nonzero.{u} R zeroR a), @Nonzero.{v} S zeroS (f a)) => hom_preserves_nonzero_arg a ha)

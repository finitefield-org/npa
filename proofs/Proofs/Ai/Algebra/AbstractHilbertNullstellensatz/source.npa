  forall (K : Sort u), forall (zeroK : K), forall (oneK : K), forall (addK : forall (a : K), forall (b : K), K), forall (negK : forall (a : K), K), forall (subK : forall (a : K), forall (b : K), K), forall (mulK : forall (a : K), forall (b : K), K), forall (Poly : Sort p), forall (zeroP : Poly), forall (oneP : Poly), forall (addP : forall (a : Poly), forall (b : Poly), Poly), forall (negP : forall (a : Poly), Poly), forall (subP : forall (a : Poly), forall (b : Poly), Poly), forall (mulP : forall (a : Poly), forall (b : Poly), Poly), forall (Point : Sort a), forall (eval : forall (f : Poly), forall (x : Point), K), forall (PowerWitness : Sort n), forall (power_of : forall (f : Poly), forall (w : PowerWitness), Poly), forall (positive_power : forall (w : PowerWitness), Prop), forall (eval_laws : @PolynomialEvaluationLawArgs.{a,g,p,u} K zeroK oneK addK negK subK mulK Poly zeroP oneP addP negP subP mulP Point eval), Prop :=
  fun K => fun zeroK => fun oneK => fun addK => fun negK => fun subK => fun mulK => fun Poly => fun zeroP => fun oneP => fun addP => fun negP => fun subP => fun mulP => fun Point => fun eval => fun PowerWitness => fun power_of => fun positive_power => fun eval_laws => forall (Q : Prop), forall (mk : forall (proper_ideal_has_zero : forall (I : forall (f : Poly), Prop), forall (ideal_laws : @IdealLawArgs.{p} Poly zeroP addP negP mulP I), forall (proper : @ProperIdeal.{p} Poly oneP I), @HasCommonZero.{a,p,u} K zeroK Poly Point eval I), forall (radical_vanishes : forall (I : forall (f : Poly), Prop), forall (ideal_laws : @IdealLawArgs.{p} Poly zeroP addP negP mulP I), forall (f : Poly), forall (hrad : @RadicalMember.{n,p} Poly PowerWitness power_of positive_power I f), @VanishingIdeal.{a,p,u} K zeroK Poly Point eval I f), forall (vanishing_is_radical : forall (I : forall (f : Poly), Prop), forall (ideal_laws : @IdealLawArgs.{p} Poly zeroP addP negP mulP I), forall (f : Poly), forall (hvanish : @VanishingIdeal.{a,p,u} K zeroK Poly Point eval I f), @RadicalMember.{n,p} Poly PowerWitness power_of positive_power I f), Q), Q

def HilbertNullstellensatzTheorem.{a,g,n,p,u} :
  forall (K : Sort u), forall (zeroK : K), forall (oneK : K), forall (addK : forall (a : K), forall (b : K), K), forall (negK : forall (a : K), K), forall (subK : forall (a : K), forall (b : K), K), forall (mulK : forall (a : K), forall (b : K), K), forall (Poly : Sort p), forall (zeroP : Poly), forall (oneP : Poly), forall (addP : forall (a : Poly), forall (b : Poly), Poly), forall (negP : forall (a : Poly), Poly), forall (subP : forall (a : Poly), forall (b : Poly), Poly), forall (mulP : forall (a : Poly), forall (b : Poly), Poly), forall (Point : Sort a), forall (eval : forall (f : Poly), forall (x : Point), K), forall (PowerWitness : Sort n), forall (power_of : forall (f : Poly), forall (w : PowerWitness), Poly), forall (positive_power : forall (w : PowerWitness), Prop), forall (eval_laws : @PolynomialEvaluationLawArgs.{a,g,p,u} K zeroK oneK addK negK subK mulK Poly zeroP oneP addP negP subP mulP Point eval), forall (construction : @NullstellensatzConstructionArgs.{a,g,n,p,u} K zeroK oneK addK negK subK mulK Poly zeroP oneP addP negP subP mulP Point eval PowerWitness power_of positive_power eval_laws), Prop :=
  fun K => fun zeroK => fun oneK => fun addK => fun negK => fun subK => fun mulK => fun Poly => fun zeroP => fun oneP => fun addP => fun negP => fun subP => fun mulP => fun Point => fun eval => fun PowerWitness => fun power_of => fun positive_power => fun eval_laws => fun construction => forall (Q : Prop), forall (mk : forall (field_laws : @AlgebraicallyClosedFieldArgs.{u} K zeroK oneK addK negK subK mulK), forall (polynomial_noetherian : @NoetherianRingArgs.{g,p} Poly zeroP oneP addP negP subP mulP), forall (weak : @WeakNullstellensatz.{a,p,u} K zeroK Poly zeroP oneP addP negP mulP Point eval), forall (strong : @StrongNullstellensatz.{a,n,p,u} K zeroK Poly zeroP oneP addP negP mulP Point eval PowerWitness power_of positive_power), Q), Q

theorem ideal_ext_eq_intro.{p} :
  forall (Poly : Sort p), forall (I : forall (f : Poly), Prop), forall (J : forall (f : Poly), Prop), forall (left : forall (f : Poly), forall (h : I f), J f), forall (right : forall (f : Poly), forall (h : J f), I f), @IdealExtEq.{p} Poly I J :=
  fun Poly => fun I => fun J => fun left => fun right => fun (Q : Prop) => fun (mk : forall (left_arg : forall (f : Poly), forall (h : I f), J f), forall (right_arg : forall (f : Poly), forall (h : J f), I f), Q) => mk left right

theorem radical_member_intro.{n,p} :
  forall (Poly : Sort p), forall (PowerWitness : Sort n), forall (power_of : forall (f : Poly), forall (w : PowerWitness), Poly), forall (positive_power : forall (w : PowerWitness), Prop), forall (I : forall (f : Poly), Prop), forall (f : Poly), forall (w : PowerWitness), forall (positive : positive_power w), forall (hpow : I (power_of f w)), @RadicalMember.{n,p} Poly PowerWitness power_of positive_power I f :=
  fun Poly => fun PowerWitness => fun power_of => fun positive_power => fun I => fun f => fun w => fun positive => fun hpow => fun (Q : Prop) => fun (mk : forall (w_arg : PowerWitness), forall (positive_arg : positive_power w_arg), forall (hpow_arg : I (power_of f w_arg)), Q) => mk w positive hpow


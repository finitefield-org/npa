theorem hilbert_basis_ideal_finitely_generated.{g,p,u} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (P : Sort p), forall (zeroP : P), forall (oneP : P), forall (addP : forall (a : P), forall (b : P), P), forall (negP : forall (a : P), P), forall (subP : forall (a : P), forall (b : P), P), forall (mulP : forall (a : P), forall (b : P), P), forall (const : forall (a : R), P), forall (variable : P), forall (extension_laws : @PolynomialExtensionLawArgs.{p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable), forall (base_noetherian : @NoetherianRingArgs.{g,u} R zeroR oneR addR negR subR mulR), forall (construction : @HilbertBasisConstructionArgs.{g,p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws base_noetherian), forall (J : forall (x : P), Prop), forall (ideal_laws : @IdealLawArgs.{p} P zeroP addP negP mulP J), @FinitelyGeneratedIdeal.{g,p} P J :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun P => fun zeroP => fun oneP => fun addP => fun negP => fun subP => fun mulP => fun const => fun variable => fun extension_laws => fun base_noetherian => fun construction => fun J => fun ideal_laws => construction (@FinitelyGeneratedIdeal.{g,p} P J) (fun (leading_coefficient_ideal : forall (J_arg : forall (x : P), Prop), forall (ideal_laws_arg : @IdealLawArgs.{p} P zeroP addP negP mulP J_arg), forall (S : Prop), forall (mk_lc : forall (lcI : forall (x : R), Prop), forall (lc_ideal_laws : @IdealLawArgs.{u} R zeroR addR negR mulR lcI), S), S) => fun (lift_leading_generators : forall (J_arg : forall (x : P), Prop), forall (ideal_laws_arg : @IdealLawArgs.{p} P zeroP addP negP mulP J_arg), forall (lcI : forall (x : R), Prop), forall (lc_ideal_laws : @IdealLawArgs.{u} R zeroR addR negR mulR lcI), forall (lc_finitely_generated : @FinitelyGeneratedIdeal.{g,u} R lcI), @FinitelyGeneratedIdeal.{g,p} P J_arg) => leading_coefficient_ideal J ideal_laws (@FinitelyGeneratedIdeal.{g,p} P J) (fun (lcI : forall (x : R), Prop) => fun (lc_ideal_laws : @IdealLawArgs.{u} R zeroR addR negR mulR lcI) => lift_leading_generators J ideal_laws lcI lc_ideal_laws (@noetherian_ideal_finitely_generated.{g,u} R zeroR oneR addR negR subR mulR base_noetherian lcI lc_ideal_laws)))

theorem hilbert_basis_polynomial_noetherian.{g,p,u} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (P : Sort p), forall (zeroP : P), forall (oneP : P), forall (addP : forall (a : P), forall (b : P), P), forall (negP : forall (a : P), P), forall (subP : forall (a : P), forall (b : P), P), forall (mulP : forall (a : P), forall (b : P), P), forall (const : forall (a : R), P), forall (variable : P), forall (extension_laws : @PolynomialExtensionLawArgs.{p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable), forall (base_noetherian : @NoetherianRingArgs.{g,u} R zeroR oneR addR negR subR mulR), forall (construction : @HilbertBasisConstructionArgs.{g,p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws base_noetherian), @NoetherianRingArgs.{g,p} P zeroP oneP addP negP subP mulP :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun P => fun zeroP => fun oneP => fun addP => fun negP => fun subP => fun mulP => fun const => fun variable => fun extension_laws => fun base_noetherian => fun construction => @noetherian_ring_args_intro.{g,p} P zeroP oneP addP negP subP mulP (@polynomial_extension_ring_laws.{p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws) (fun (J : forall (x : P), Prop) => fun (ideal_laws : @IdealLawArgs.{p} P zeroP addP negP mulP J) => @hilbert_basis_ideal_finitely_generated.{g,p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws base_noetherian construction J ideal_laws)

theorem hilbert_basis_theorem.{g,p,u} :
  forall (R : Sort u), forall (zeroR : R), forall (oneR : R), forall (addR : forall (a : R), forall (b : R), R), forall (negR : forall (a : R), R), forall (subR : forall (a : R), forall (b : R), R), forall (mulR : forall (a : R), forall (b : R), R), forall (P : Sort p), forall (zeroP : P), forall (oneP : P), forall (addP : forall (a : P), forall (b : P), P), forall (negP : forall (a : P), P), forall (subP : forall (a : P), forall (b : P), P), forall (mulP : forall (a : P), forall (b : P), P), forall (const : forall (a : R), P), forall (variable : P), forall (extension_laws : @PolynomialExtensionLawArgs.{p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable), forall (base_noetherian : @NoetherianRingArgs.{g,u} R zeroR oneR addR negR subR mulR), forall (construction : @HilbertBasisConstructionArgs.{g,p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws base_noetherian), @HilbertBasisTheorem.{g,p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws base_noetherian construction :=
  fun R => fun zeroR => fun oneR => fun addR => fun negR => fun subR => fun mulR => fun P => fun zeroP => fun oneP => fun addP => fun negP => fun subP => fun mulP => fun const => fun variable => fun extension_laws => fun base_noetherian => fun construction => fun (Q : Prop) => fun (mk : forall (base_noetherian_out : @NoetherianRingArgs.{g,u} R zeroR oneR addR negR subR mulR), forall (polynomial_ring_laws : @RingLawArgs.{p} P zeroP oneP addP negP subP mulP), forall (polynomial_noetherian : @NoetherianRingArgs.{g,p} P zeroP oneP addP negP subP mulP), Q) => mk base_noetherian (@polynomial_extension_ring_laws.{p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws) (@hilbert_basis_polynomial_noetherian.{g,p,u} R zeroR oneR addR negR subR mulR P zeroP oneP addP negP subP mulP const variable extension_laws base_noetherian construction)

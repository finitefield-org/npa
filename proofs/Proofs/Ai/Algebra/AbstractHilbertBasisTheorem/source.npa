  fun R => fun zero => fun add => fun neg => fun mul => fun I => forall (Q : Prop), forall (mk : forall (zero_mem : I zero), forall (add_closed : forall (a : R), forall (b : R), forall (ha : I a), forall (hb : I b), I (add a b)), forall (neg_closed : forall (a : R), forall (ha : I a), I (neg a)), forall (mul_left_closed : forall (r : R), forall (a : R), forall (ha : I a), I (mul r a)), Q), Q


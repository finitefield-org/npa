  forall (R : Sort u), forall (one : R), forall (mul : forall (a : R), forall (b : R), R), forall (Factorization : Sort f), forall (factor_value : forall (fac : Factorization), R), forall (all_irreducible : forall (fac : Factorization), Prop), forall (x : R), forall (fac : Factorization), Prop :=
  fun R => fun one => fun mul => fun Factorization => fun factor_value => fun all_irreducible => fun x => fun fac => forall (Q : Prop), forall (mk : forall (represents : @Associate.{u} R one mul (factor_value fac) x), forall (factors_irreducible : all_irreducible fac), Q), Q


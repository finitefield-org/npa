import Std.Logic.Eq
import Proofs.Ai.Algebra.AbstractRing

def UfdFalse :
  Prop :=
  forall (P : Prop), P

def UfdNot :
  forall (P : Prop), Prop :=
  fun P => forall (p : P), UfdFalse

def UfdOr :
  forall (P : Prop), forall (Q : Prop), Prop :=
  fun P => fun Q => forall (R : Prop), forall (left : forall (p : P), R), forall (right : forall (q : Q), R), R

def Divides.{u} :
  forall (R : Sort u), forall (mul : forall (a : R), forall (b : R), R), forall (a : R), forall (b : R), Prop :=
  fun R => fun mul => fun a => fun b => forall (Q : Prop), forall (mk : forall (c : R), forall (h : @Eq.{u} R (mul a c) b), Q), Q

def Unit.{u} :
  forall (R : Sort u), forall (one : R), forall (mul : forall (a : R), forall (b : R), R), forall (x : R), Prop :=
  fun R => fun one => fun mul => fun x => forall (Q : Prop), forall (mk : forall (inv : R), forall (right_inv : @Eq.{u} R (mul x inv) one), forall (left_inv : @Eq.{u} R (mul inv x) one), Q), Q

def Associate.{u} :
  forall (R : Sort u), forall (one : R), forall (mul : forall (a : R), forall (b : R), R), forall (a : R), forall (b : R), Prop :=
  fun R => fun one => fun mul => fun a => fun b => forall (Q : Prop), forall (mk : forall (unit : R), forall (unit_is_unit : @Unit.{u} R one mul unit), forall (h : @Eq.{u} R (mul unit a) b), Q), Q

def Nonzero.{u} :
  forall (R : Sort u), forall (zero : R), forall (x : R), Prop :=
  fun R => fun zero => fun x => UfdNot (@Eq.{u} R x zero)

def Nonunit.{u} :
  forall (R : Sort u), forall (one : R), forall (mul : forall (a : R), forall (b : R), R), forall (x : R), Prop :=
  fun R => fun one => fun mul => fun x => UfdNot (@Unit.{u} R one mul x)

def PrimeElement.{u} :
  forall (R : Sort u), forall (zero : R), forall (one : R), forall (mul : forall (a : R), forall (b : R), R), forall (p : R), Prop :=
  fun R => fun zero => fun one => fun mul => fun p => forall (Q : Prop), forall (mk : forall (nonzero : @Nonzero.{u} R zero p), forall (nonunit : @Nonunit.{u} R one mul p), forall (divides_mul : forall (a : R), forall (b : R), forall (h : @Divides.{u} R mul p (mul a b)), UfdOr (@Divides.{u} R mul p a) (@Divides.{u} R mul p b)), Q), Q

def IrreducibleElement.{u} :
  forall (R : Sort u), forall (zero : R), forall (one : R), forall (mul : forall (a : R), forall (b : R), R), forall (p : R), Prop :=
  fun R => fun zero => fun one => fun mul => fun p => forall (Q : Prop), forall (mk : forall (nonzero : @Nonzero.{u} R zero p), forall (nonunit : @Nonunit.{u} R one mul p), forall (factor_unit_or : forall (a : R), forall (b : R), forall (h : @Eq.{u} R p (mul a b)), UfdOr (@Unit.{u} R one mul a) (@Unit.{u} R one mul b)), Q), Q

def IntegralDomainLawArgs.{u} :
  forall (R : Sort u), forall (zero : R), forall (one : R), forall (add : forall (a : R), forall (b : R), R), forall (neg : forall (a : R), R), forall (sub : forall (a : R), forall (b : R), R), forall (mul : forall (a : R), forall (b : R), R), Prop :=
  fun R => fun zero => fun one => fun add => fun neg => fun sub => fun mul => forall (Q : Prop), forall (mk : forall (ring_laws : @RingLawArgs.{u} R zero one add neg sub mul), forall (zero_ne_one : UfdNot (@Eq.{u} R zero one)), forall (no_zero_divisors : forall (a : R), forall (b : R), forall (h : @Eq.{u} R (mul a b) zero), UfdOr (@Eq.{u} R a zero) (@Eq.{u} R b zero)), Q), Q


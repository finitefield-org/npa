  forall (R : Sort u), forall (one : R), forall (mul : forall (a : R), forall (b : R), R), forall (Factorization : Sort f), forall (factor_value : forall (fac : Factorization), R), forall (all_irreducible : forall (fac : Factorization), Prop), forall (all_prime : forall (fac : Factorization), Prop), forall (x : R), forall (fac : Factorization), Prop :=

import Proofs.Ai.Algebra.AbstractRing

def FieldFalse :
  Prop :=
  forall (P : Prop), P

def FieldNot :
  forall (P : Prop), Prop :=
  fun P => forall (p : P), FieldFalse

def Nonzero.{u} :
  forall (Scalar : Sort u), forall (zero : Scalar), forall (a : Scalar), Prop :=
  fun Scalar => fun zero => fun a => FieldNot (@Eq.{u} Scalar a zero)

def div.{u} :
  forall (Scalar : Sort u), forall (mul : forall (a : Scalar), forall (b : Scalar), Scalar), forall (inv : forall (a : Scalar), Scalar), forall (a : Scalar), forall (b : Scalar), Scalar :=
  fun Scalar => fun mul => fun inv => fun a => fun b => mul a (inv b)

def FieldLawArgs.{u} :
  forall (Scalar : Sort u), forall (zero : Scalar), forall (one : Scalar), forall (add : forall (a : Scalar), forall (b : Scalar), Scalar), forall (neg : forall (a : Scalar), Scalar), forall (sub : forall (a : Scalar), forall (b : Scalar), Scalar), forall (mul : forall (a : Scalar), forall (b : Scalar), Scalar), forall (inv : forall (a : Scalar), Scalar), Prop :=
  fun Scalar => fun zero => fun one => fun add => fun neg => fun sub => fun mul => fun inv => forall (P : Prop), forall (mk : forall (ring_laws : @RingLawArgs.{u} Scalar zero one add neg sub mul), forall (zero_ne_one_law : @Nonzero.{u} Scalar zero one), forall (inv_mul_cancel_law : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul (inv a) a) one), forall (mul_inv_cancel_law : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul a (inv a)) one), P), P

theorem field_ring_laws.{u} :
  forall (Scalar : Sort u), forall (zero : Scalar), forall (one : Scalar), forall (add : forall (a : Scalar), forall (b : Scalar), Scalar), forall (neg : forall (a : Scalar), Scalar), forall (sub : forall (a : Scalar), forall (b : Scalar), Scalar), forall (mul : forall (a : Scalar), forall (b : Scalar), Scalar), forall (inv : forall (a : Scalar), Scalar), forall (field_args : @FieldLawArgs.{u} Scalar zero one add neg sub mul inv), @RingLawArgs.{u} Scalar zero one add neg sub mul :=
  fun Scalar => fun zero => fun one => fun add => fun neg => fun sub => fun mul => fun inv => fun field_args => field_args (@RingLawArgs.{u} Scalar zero one add neg sub mul) (fun (ring_laws_arg : @RingLawArgs.{u} Scalar zero one add neg sub mul) => fun (zero_ne_one_arg : @Nonzero.{u} Scalar zero one) => fun (inv_mul_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul (inv a) a) one) => fun (mul_inv_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul a (inv a)) one) => ring_laws_arg)

theorem field_zero_ne_one.{u} :
  forall (Scalar : Sort u), forall (zero : Scalar), forall (one : Scalar), forall (add : forall (a : Scalar), forall (b : Scalar), Scalar), forall (neg : forall (a : Scalar), Scalar), forall (sub : forall (a : Scalar), forall (b : Scalar), Scalar), forall (mul : forall (a : Scalar), forall (b : Scalar), Scalar), forall (inv : forall (a : Scalar), Scalar), forall (field_args : @FieldLawArgs.{u} Scalar zero one add neg sub mul inv), @Nonzero.{u} Scalar zero one :=
  fun Scalar => fun zero => fun one => fun add => fun neg => fun sub => fun mul => fun inv => fun field_args => field_args (@Nonzero.{u} Scalar zero one) (fun (ring_laws_arg : @RingLawArgs.{u} Scalar zero one add neg sub mul) => fun (zero_ne_one_arg : @Nonzero.{u} Scalar zero one) => fun (inv_mul_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul (inv a) a) one) => fun (mul_inv_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul a (inv a)) one) => zero_ne_one_arg)

theorem field_inv_mul_cancel.{u} :
  forall (Scalar : Sort u), forall (zero : Scalar), forall (one : Scalar), forall (add : forall (a : Scalar), forall (b : Scalar), Scalar), forall (neg : forall (a : Scalar), Scalar), forall (sub : forall (a : Scalar), forall (b : Scalar), Scalar), forall (mul : forall (a : Scalar), forall (b : Scalar), Scalar), forall (inv : forall (a : Scalar), Scalar), forall (field_args : @FieldLawArgs.{u} Scalar zero one add neg sub mul inv), forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul (inv a) a) one :=
  fun Scalar => fun zero => fun one => fun add => fun neg => fun sub => fun mul => fun inv => fun field_args => fun a => fun ha => field_args (@Eq.{u} Scalar (mul (inv a) a) one) (fun (ring_laws_arg : @RingLawArgs.{u} Scalar zero one add neg sub mul) => fun (zero_ne_one_arg : @Nonzero.{u} Scalar zero one) => fun (inv_mul_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul (inv a) a) one) => fun (mul_inv_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul a (inv a)) one) => inv_mul_cancel_arg a ha)

theorem field_mul_inv_cancel.{u} :
  forall (Scalar : Sort u), forall (zero : Scalar), forall (one : Scalar), forall (add : forall (a : Scalar), forall (b : Scalar), Scalar), forall (neg : forall (a : Scalar), Scalar), forall (sub : forall (a : Scalar), forall (b : Scalar), Scalar), forall (mul : forall (a : Scalar), forall (b : Scalar), Scalar), forall (inv : forall (a : Scalar), Scalar), forall (field_args : @FieldLawArgs.{u} Scalar zero one add neg sub mul inv), forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul a (inv a)) one :=
  fun Scalar => fun zero => fun one => fun add => fun neg => fun sub => fun mul => fun inv => fun field_args => fun a => fun ha => field_args (@Eq.{u} Scalar (mul a (inv a)) one) (fun (ring_laws_arg : @RingLawArgs.{u} Scalar zero one add neg sub mul) => fun (zero_ne_one_arg : @Nonzero.{u} Scalar zero one) => fun (inv_mul_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul (inv a) a) one) => fun (mul_inv_cancel_arg : forall (a : Scalar), forall (ha : @Nonzero.{u} Scalar zero a), @Eq.{u} Scalar (mul a (inv a)) one) => mul_inv_cancel_arg a ha)

theorem field_div_eq_mul_inv.{u} :
  forall (Scalar : Sort u), forall (mul : forall (a : Scalar), forall (b : Scalar), Scalar), forall (inv : forall (a : Scalar), Scalar), forall (a : Scalar), forall (b : Scalar), @Eq.{u} Scalar (@div.{u} Scalar mul inv a b) (mul a (inv b)) :=
  fun Scalar => fun mul => fun inv => fun a => fun b => @Eq.refl.{u} Scalar (mul a (inv b))


def PointAtInfinity.{p} :
  forall (Point : Sort p), forall (zero_point : Point), forall (point : Point), Prop :=
  fun Point => fun zero_point => fun point => @Eq.{p} Point point zero_point

def point_double.{p} :
  forall (Point : Sort p), forall (add_point : forall (left : Point), forall (right : Point), Point), forall (point : Point), Point :=
  fun Point => fun add_point => fun point => add_point point point

def PointAdditionExceptionalCase.{p} :
  forall (Point : Sort p), forall (neg_point : forall (point : Point), Point), forall (left : Point), forall (right : Point), Prop :=
  fun Point => fun neg_point => fun left => fun right => @Eq.{p} Point right (neg_point left)


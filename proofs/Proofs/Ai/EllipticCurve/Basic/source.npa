import Std.Logic.Eq
import Proofs.Ai.Algebra.AbstractRing
import Proofs.Ai.Algebra.AbstractField

def ec_square.{u} :
  forall (Scalar : Sort u), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (x : Scalar), Scalar :=
  fun Scalar => fun mul => fun x => mul x x

def ec_cube.{u} :
  forall (Scalar : Sort u), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (x : Scalar), Scalar :=
  fun Scalar => fun mul => fun x => mul (mul x x) x

def short_weierstrass_rhs.{u} :
  forall (Scalar : Sort u), forall (add : forall (left : Scalar), forall (right : Scalar), Scalar), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (x : Scalar), forall (a : Scalar), forall (b : Scalar), Scalar :=
  fun Scalar => fun add => fun mul => fun x => fun a => fun b => add (add (@ec_cube.{u} Scalar mul x) (mul a x)) b

def short_weierstrass_discriminant.{u} :
  forall (Scalar : Sort u), forall (add : forall (left : Scalar), forall (right : Scalar), Scalar), forall (neg : forall (value : Scalar), Scalar), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (four : Scalar), forall (twenty_seven : Scalar), forall (a : Scalar), forall (b : Scalar), Scalar :=
  fun Scalar => fun add => fun neg => fun mul => fun four => fun twenty_seven => fun a => fun b => neg (add (mul four (@ec_cube.{u} Scalar mul a)) (mul twenty_seven (@ec_square.{u} Scalar mul b)))

def ShortWeierstrassEquation.{u} :
  forall (Scalar : Sort u), forall (add : forall (left : Scalar), forall (right : Scalar), Scalar), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (x : Scalar), forall (y_square : Scalar), forall (a : Scalar), forall (b : Scalar), Prop :=
  fun Scalar => fun add => fun mul => fun x => fun y_square => fun a => fun b => @Eq.{u} Scalar y_square (@short_weierstrass_rhs.{u} Scalar add mul x a b)

def NonsingularShortWeierstrass.{u} :
  forall (Scalar : Sort u), forall (zero : Scalar), forall (add : forall (left : Scalar), forall (right : Scalar), Scalar), forall (neg : forall (value : Scalar), Scalar), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (four : Scalar), forall (twenty_seven : Scalar), forall (a : Scalar), forall (b : Scalar), Prop :=
  fun Scalar => fun zero => fun add => fun neg => fun mul => fun four => fun twenty_seven => fun a => fun b => @Nonzero.{u} Scalar zero (@short_weierstrass_discriminant.{u} Scalar add neg mul four twenty_seven a b)

def WeierstrassRouteIndependenceData :
  forall (EllipticCurveApi : Type), forall (SpecializedFreyRoute : Type), forall (FinalTheoremRoute : Type), forall (ReusableOutsideSpecializedRoutes : EllipticCurveApi -> SpecializedFreyRoute -> FinalTheoremRoute -> Prop), Prop :=
  fun EllipticCurveApi => fun SpecializedFreyRoute => fun FinalTheoremRoute => fun ReusableOutsideSpecializedRoutes => forall (Q : Prop), forall (mk : forall (reuse_law : forall (api : EllipticCurveApi), forall (frey_route : SpecializedFreyRoute), forall (final_route : FinalTheoremRoute), ReusableOutsideSpecializedRoutes api frey_route final_route), Q), Q


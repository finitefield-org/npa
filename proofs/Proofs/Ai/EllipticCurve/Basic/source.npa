  forall (Scalar : Sort u), forall (zero : Scalar), forall (one : Scalar), forall (add : forall (left : Scalar), forall (right : Scalar), Scalar), forall (neg : forall (value : Scalar), Scalar), forall (sub : forall (left : Scalar), forall (right : Scalar), Scalar), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (inv : forall (value : Scalar), Scalar), forall (four : Scalar), forall (twenty_seven : Scalar), forall (a : Scalar), forall (b : Scalar), forall (EllipticCurveApi : Type), forall (SpecializedFreyRoute : Type), forall (FinalTheoremRoute : Type), forall (ReusableOutsideSpecializedRoutes : EllipticCurveApi -> SpecializedFreyRoute -> FinalTheoremRoute -> Prop), Prop :=
  fun Scalar => fun zero => fun one => fun add => fun neg => fun sub => fun mul => fun inv => fun four => fun twenty_seven => fun a => fun b => fun EllipticCurveApi => fun SpecializedFreyRoute => fun FinalTheoremRoute => fun ReusableOutsideSpecializedRoutes => forall (Q : Prop), forall (mk : forall (field_laws : @FieldLawArgs.{u} Scalar zero one add neg sub mul inv), forall (discriminant_nonzero : @NonsingularShortWeierstrass.{u} Scalar zero add neg mul four twenty_seven a b), forall (route_independence : @WeierstrassRouteIndependenceData EllipticCurveApi SpecializedFreyRoute FinalTheoremRoute ReusableOutsideSpecializedRoutes), Q), Q

theorem short_weierstrass_equation_rhs_refl.{u} :
  forall (Scalar : Sort u), forall (add : forall (left : Scalar), forall (right : Scalar), Scalar), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (x : Scalar), forall (a : Scalar), forall (b : Scalar), @ShortWeierstrassEquation.{u} Scalar add mul x (@short_weierstrass_rhs.{u} Scalar add mul x a b) a b :=
  fun Scalar => fun add => fun mul => fun x => fun a => fun b => @Eq.refl.{u} Scalar (@short_weierstrass_rhs.{u} Scalar add mul x a b)

theorem short_weierstrass_discriminant_defeq.{u} :
  forall (Scalar : Sort u), forall (add : forall (left : Scalar), forall (right : Scalar), Scalar), forall (neg : forall (value : Scalar), Scalar), forall (mul : forall (left : Scalar), forall (right : Scalar), Scalar), forall (four : Scalar), forall (twenty_seven : Scalar), forall (a : Scalar), forall (b : Scalar), @Eq.{u} Scalar (@short_weierstrass_discriminant.{u} Scalar add neg mul four twenty_seven a b) (neg (add (mul four (@ec_cube.{u} Scalar mul a)) (mul twenty_seven (@ec_square.{u} Scalar mul b)))) :=
  fun Scalar => fun add => fun neg => fun mul => fun four => fun twenty_seven => fun a => fun b => @Eq.refl.{u} Scalar (@short_weierstrass_discriminant.{u} Scalar add neg mul four twenty_seven a b)


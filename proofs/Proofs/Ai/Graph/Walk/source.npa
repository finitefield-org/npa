  fun Vertex => fun StepIndex => fun Walk => fun edge => fun EdgeSymmetryEvidence => fun LoopPolicyEvidence => fun DirectedGraphSeparationEvidence => fun NoParallelEdgeMultiplicityEvidence => fun graph_args => fun walkStart => fun walkEnd => fun walkVertexAt => fun WalkStepEvidence => fun WalkEndpointEvidence => fun WalkLengthEvidence => fun WalkValidEvidence => fun walk_args => fun TrailEvidence => fun PathEvidence => fun CycleEvidence => fun NoRepeatedEdgeEvidence => fun NoRepeatedVertexEvidence => fun CycleClosedEvidence => fun PathExtractionEvidence => fun trail_path_args => fun walk => fun derive_cycle_closed => trail_path_args (CycleClosedEvidence walk) (fun (walk_law : @WalkDataPackage.{s,v,w} Vertex StepIndex Walk edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence graph_args walkStart walkEnd walkVertexAt WalkStepEvidence WalkEndpointEvidence WalkLengthEvidence WalkValidEvidence) => fun (trail_law : forall (walk : Walk), TrailEvidence walk) => fun (path_law : forall (walk : Walk), PathEvidence walk) => fun (cycle_law : forall (walk : Walk), CycleEvidence walk) => fun (no_repeated_edge_law : forall (walk : Walk), NoRepeatedEdgeEvidence walk) => fun (no_repeated_vertex_law : forall (walk : Walk), NoRepeatedVertexEvidence walk) => fun (cycle_closed_law : forall (walk : Walk), CycleClosedEvidence walk) => fun (path_extraction_law : forall (walk : Walk), PathExtractionEvidence walk) => derive_cycle_closed (cycle_law walk) (no_repeated_edge_law walk))


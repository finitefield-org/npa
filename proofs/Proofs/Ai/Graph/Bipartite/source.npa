  forall (Vertex : Sort v), forall (edge : forall (left : Vertex), forall (right : Vertex), Prop), forall (EdgeSymmetryEvidence : Prop), forall (LoopPolicyEvidence : Prop), forall (DirectedGraphSeparationEvidence : Prop), forall (NoParallelEdgeMultiplicityEvidence : Prop), forall (graph_args : @SimpleGraphLawPackage.{v} Vertex edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence), forall (LeftPart : forall (vertex : Vertex), Prop), forall (RightPart : forall (vertex : Vertex), Prop), forall (LeftRightDisjointEvidence : Prop), forall (VertexPartitionEvidence : Prop), forall (EdgeCrossesPartsEvidence : Prop), forall (NoBipartitionLeakEvidence : Prop), forall (bipartite_args : @BipartiteGraphPackage.{v} Vertex edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence graph_args LeftPart RightPart LeftRightDisjointEvidence VertexPartitionEvidence EdgeCrossesPartsEvidence NoBipartitionLeakEvidence), forall (derive_crossing : forall (graph_law : @SimpleGraphLawPackage.{v} Vertex edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence), forall (left_right_disjoint_law : LeftRightDisjointEvidence), forall (vertex_partition_law : VertexPartitionEvidence), EdgeCrossesPartsEvidence), EdgeCrossesPartsEvidence :=
  fun Vertex => fun edge => fun EdgeSymmetryEvidence => fun LoopPolicyEvidence => fun DirectedGraphSeparationEvidence => fun NoParallelEdgeMultiplicityEvidence => fun graph_args => fun LeftPart => fun RightPart => fun LeftRightDisjointEvidence => fun VertexPartitionEvidence => fun EdgeCrossesPartsEvidence => fun NoBipartitionLeakEvidence => fun bipartite_args => fun derive_crossing => bipartite_args (EdgeCrossesPartsEvidence) (fun (graph_law : @SimpleGraphLawPackage.{v} Vertex edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence) => fun (left_right_disjoint_law : LeftRightDisjointEvidence) => fun (vertex_partition_law : VertexPartitionEvidence) => fun (edge_crosses_parts_law : EdgeCrossesPartsEvidence) => fun (no_bipartition_leak_law : NoBipartitionLeakEvidence) => derive_crossing graph_law left_right_disjoint_law vertex_partition_law)


import Proofs.Ai.Graph.Basic

def BipartiteGraphPackage.{v} :
  forall (Vertex : Sort v), forall (edge : forall (left : Vertex), forall (right : Vertex), Prop), forall (EdgeSymmetryEvidence : Prop), forall (LoopPolicyEvidence : Prop), forall (DirectedGraphSeparationEvidence : Prop), forall (NoParallelEdgeMultiplicityEvidence : Prop), forall (graph_args : @SimpleGraphLawPackage.{v} Vertex edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence), forall (LeftPart : forall (vertex : Vertex), Prop), forall (RightPart : forall (vertex : Vertex), Prop), forall (LeftRightDisjointEvidence : Prop), forall (VertexPartitionEvidence : Prop), forall (EdgeCrossesPartsEvidence : Prop), forall (NoBipartitionLeakEvidence : Prop), Prop :=
  fun Vertex => fun edge => fun EdgeSymmetryEvidence => fun LoopPolicyEvidence => fun DirectedGraphSeparationEvidence => fun NoParallelEdgeMultiplicityEvidence => fun graph_args => fun LeftPart => fun RightPart => fun LeftRightDisjointEvidence => fun VertexPartitionEvidence => fun EdgeCrossesPartsEvidence => fun NoBipartitionLeakEvidence => forall (P : Prop), forall (mk : forall (graph_law : @SimpleGraphLawPackage.{v} Vertex edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence), forall (left_right_disjoint_law : LeftRightDisjointEvidence), forall (vertex_partition_law : VertexPartitionEvidence), forall (edge_crosses_parts_law : EdgeCrossesPartsEvidence), forall (no_bipartition_leak_law : NoBipartitionLeakEvidence), P), P


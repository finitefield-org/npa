op), forall (OwnComponentEvidence : forall (vertex : Vertex), Prop), forall (ReachabilityComponentEquivalenceEvidence : Prop), forall (ComponentPartitionEvidence : Prop), forall (ComponentConnectedEvidence : Prop), forall (component_args : @ConnectedComponentPartitionPackage.{c,s,v,w} Vertex StepIndex Walk edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence graph_args walkStart walkEnd walkVertexAt WalkStepEvidence WalkEndpointEvidence WalkLengthEvidence WalkValidEvidence walk_args Component Reachable ReachabilityWitnessEvidence NoHiddenTransitiveClosureEvidence reachability_args componentOf ComponentMember OwnComponentEvidence ReachabilityComponentEquivalenceEvidence ComponentPartitionEvidence ComponentConnectedEvidence), forall (derive_partition : forall (own_component_law : forall (vertex : Vertex), OwnComponentEvidence vertex), forall (reachability_component_equivalence_law : ReachabilityComponentEquivalenceEvidence), ComponentPartitionEvidence), ComponentPartitionEvidence :=
  fun Vertex => fun StepIndex => fun Walk => fun edge => fun EdgeSymmetryEvidence => fun LoopPolicyEvidence => fun DirectedGraphSeparationEvidence => fun NoParallelEdgeMultiplicityEvidence => fun graph_args => fun walkStart => fun walkEnd => fun walkVertexAt => fun WalkStepEvidence => fun WalkEndpointEvidence => fun WalkLengthEvidence => fun WalkValidEvidence => fun walk_args => fun Component => fun Reachable => fun ReachabilityWitnessEvidence => fun NoHiddenTransitiveClosureEvidence => fun reachability_args => fun componentOf => fun ComponentMember => fun OwnComponentEvidence => fun ReachabilityComponentEquivalenceEvidence => fun ComponentPartitionEvidence => fun ComponentConnectedEvidence => fun component_args => fun derive_partition => component_args ComponentPartitionEvidence (fun (reachability_law : @ReachabilityPackage.{s,v,w} Vertex StepIndex Walk edge EdgeSymmetryEvidence LoopPolicyEvidence DirectedGraphSeparationEvidence NoParallelEdgeMultiplicityEvidence graph_args walkStart walkEnd walkVertexAt WalkStepEvidence WalkEndpointEvidence WalkLengthEvidence WalkValidEvidence walk_args Reachable ReachabilityWitnessEvidence NoHiddenTransitiveClosureEvidence) => fun (own_component_law : forall (vertex : Vertex), OwnComponentEvidence vertex) => fun (reachability_component_equivalence_law : ReachabilityComponentEquivalenceEvidence) => fun (component_partition_law : ComponentPartitionEvidence) => fun (component_connected_law : ComponentConnectedEvidence) => derive_partition own_component_law reachability_component_equivalence_law)

  fun ObjC => fun HomC => fun idC => fun compC => fun categoryC_args => fun DeltaObj => fun DeltaHom => fun delta_id => fun delta_comp => fun delta_category_args => fun simplex_args => fun NerveSimplex => fun nerve_restrict => fun nerve_simplicial_set_law => fun (P : Prop) => fun (mk : forall (nerve_simplicial_set_arg : @SimplicialSetLawArgs.{u,v,w} DeltaObj DeltaHom delta_id delta_comp delta_category_args simplex_args NerveSimplex nerve_restrict), P) => mk nerve_simplicial_set_law


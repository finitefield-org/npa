def HilbertSpaceData.{h,s} :
  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (InnerProductLaw : Prop), forall (NormFromInnerProductLaw : Prop), forall (CompleteInnerProductLaw : Prop), Prop :=
  fun Hilbert => fun Scalar => fun InnerProductLaw => fun NormFromInnerProductLaw => fun CompleteInnerProductLaw => forall (P : Prop), forall (mk : forall (inner_product_law : InnerProductLaw), forall (norm_from_inner_product_law : NormFromInnerProductLaw), forall (complete_inner_product_law : CompleteInnerProductLaw), P), P

def HilbertProjectionEvidence.{h,s} :
  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (ClosedConvexSet : forall (x : Hilbert), Prop), forall (ProjectionPoint : Hilbert), forall (TargetPoint : Hilbert), forall (HilbertSpaceEvidence : Prop), forall (ClosedLaw : Prop), forall (ConvexLaw : Prop), forall (BestApproximationLaw : Prop), forall (OrthogonalityLaw : Prop), forall (ProjectionConclusion : Prop), Prop :=
  fun Hilbert => fun Scalar => fun ClosedConvexSet => fun ProjectionPoint => fun TargetPoint => fun HilbertSpaceEvidence => fun ClosedLaw => fun ConvexLaw => fun BestApproximationLaw => fun OrthogonalityLaw => fun ProjectionConclusion => forall (P : Prop), forall (mk : forall (hilbert_space_law : HilbertSpaceEvidence), forall (closed_law : ClosedLaw), forall (convex_law : ConvexLaw), forall (best_approximation_law : BestApproximationLaw), forall (orthogonality_law : OrthogonalityLaw), forall (projection_route : HilbertSpaceEvidence -> ClosedLaw -> ConvexLaw -> BestApproximationLaw -> OrthogonalityLaw -> ProjectionConclusion), P), P

def RieszFrechetRepresentationEvidence.{f,h,s} :
  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (Functional : Sort f), forall (functional : Functional), forall (representingVector : Hilbert), forall (HilbertSpaceEvidence : Prop), forall (ContinuousLinearFunctionalEvidence : Prop), forall (RepresentationLaw : Prop), forall (UniquenessLaw : Prop), forall (RieszFrechetConclusion : Prop), Prop :=
  fun Hilbert => fun Scalar => fun Functional => fun functional => fun representingVector => fun HilbertSpaceEvidence => fun ContinuousLinearFunctionalEvidence => fun RepresentationLaw => fun UniquenessLaw => fun RieszFrechetConclusion => forall (P : Prop), forall (mk : forall (hilbert_space_law : HilbertSpaceEvidence), forall (continuous_linear_functional_law : ContinuousLinearFunctionalEvidence), forall (representation_law : RepresentationLaw), forall (uniqueness_law : UniquenessLaw), forall (riesz_frechet_route : HilbertSpaceEvidence -> ContinuousLinearFunctionalEvidence -> RepresentationLaw -> UniquenessLaw -> RieszFrechetConclusion), P), P

def OrthogonalDecompositionEvidence.{h,s} :
  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (Subspace : forall (x : Hilbert), Prop), forall (HilbertSpaceEvidence : Prop), forall (ClosedSubspaceLaw : Prop), forall (ProjectionLaw : Prop), forall (OrthogonalComplementLaw : Prop), forall (DirectSumLaw : Prop), forall (OrthogonalDecompositionConclusion : Prop), Prop :=
  fun Hilbert => fun Scalar => fun Subspace => fun HilbertSpaceEvidence => fun ClosedSubspaceLaw => fun ProjectionLaw => fun OrthogonalComplementLaw => fun DirectSumLaw => fun OrthogonalDecompositionConclusion => forall (P : Prop), forall (mk : forall (hilbert_space_law : HilbertSpaceEvidence), forall (closed_subspace_law : ClosedSubspaceLaw), forall (projection_law : ProjectionLaw), forall (orthogonal_complement_law : OrthogonalComplementLaw), forall (direct_sum_law : DirectSumLaw), forall (orthogonal_decomposition_route : HilbertSpaceEvidence -> ClosedSubspaceLaw -> ProjectionLaw -> OrthogonalComplementLaw -> DirectSumLaw -> OrthogonalDecompositionConclusion), P), P

theorem hilbert_space_data_intro.{h,s} :
  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (InnerProductLaw : Prop), forall (NormFromInnerProductLaw : Prop), forall (CompleteInnerProductLaw : Prop), forall (inner_product_law : InnerProductLaw), forall (norm_from_inner_product_law : NormFromInnerProductLaw), forall (complete_inner_product_law : CompleteInnerProductLaw), @HilbertSpaceData.{h,s} Hilbert Scalar InnerProductLaw NormFromInnerProductLaw CompleteInnerProductLaw :=
  fun Hilbert => fun Scalar => fun InnerProductLaw => fun NormFromInnerProductLaw => fun CompleteInnerProductLaw => fun inner_product_law => fun norm_from_inner_product_law => fun complete_inner_product_law => fun (P : Prop) => fun (mk : forall (inner_product_law : InnerProductLaw), forall (norm_from_inner_product_law : NormFromInnerProductLaw), forall (complete_inner_product_law : CompleteInnerProductLaw), P) => mk inner_product_law norm_from_inner_product_law complete_inner_product_law

theorem hilbert_projection_theorem.{h,s} :
  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (ClosedConvexSet : forall (x : Hilbert), Prop), forall (ProjectionPoint : Hilbert), forall (TargetPoint : Hilbert), forall (HilbertSpaceEvidence : Prop), forall (ClosedLaw : Prop), forall (ConvexLaw : Prop), forall (BestApproximationLaw : Prop), forall (OrthogonalityLaw : Prop), forall (ProjectionConclusion : Prop), forall (evidence : @HilbertProjectionEvidence.{h,s} Hilbert Scalar ClosedConvexSet ProjectionPoint TargetPoint HilbertSpaceEvidence ClosedLaw ConvexLaw BestApproximationLaw OrthogonalityLaw ProjectionConclusion), ProjectionConclusion :=
  fun Hilbert => fun Scalar => fun ClosedConvexSet => fun ProjectionPoint => fun TargetPoint => fun HilbertSpaceEvidence => fun ClosedLaw => fun ConvexLaw => fun BestApproximationLaw => fun OrthogonalityLaw => fun ProjectionConclusion => fun evidence => evidence ProjectionConclusion (fun (hilbert_space_law : HilbertSpaceEvidence) => fun (closed_law : ClosedLaw) => fun (convex_law : ConvexLaw) => fun (best_approximation_law : BestApproximationLaw) => fun (orthogonality_law : OrthogonalityLaw) => fun (projection_route : HilbertSpaceEvidence -> ClosedLaw -> ConvexLaw -> BestApproximationLaw -> OrthogonalityLaw -> ProjectionConclusion) => projection_route hilbert_space_law closed_law convex_law best_approximation_law orthogonality_law)


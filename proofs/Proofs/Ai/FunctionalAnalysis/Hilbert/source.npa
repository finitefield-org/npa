  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (Functional : Sort f), forall (functional : Functional), forall (representingVector : Hilbert), forall (HilbertSpaceEvidence : Prop), forall (ContinuousLinearFunctionalEvidence : Prop), forall (RepresentationLaw : Prop), forall (UniquenessLaw : Prop), forall (RieszFrechetConclusion : Prop), forall (evidence : @RieszFrechetRepresentationEvidence.{f,h,s} Hilbert Scalar Functional functional representingVector HilbertSpaceEvidence ContinuousLinearFunctionalEvidence RepresentationLaw UniquenessLaw RieszFrechetConclusion), RieszFrechetConclusion :=
  fun Hilbert => fun Scalar => fun Functional => fun functional => fun representingVector => fun HilbertSpaceEvidence => fun ContinuousLinearFunctionalEvidence => fun RepresentationLaw => fun UniquenessLaw => fun RieszFrechetConclusion => fun evidence => evidence RieszFrechetConclusion (fun (hilbert_space_law : HilbertSpaceEvidence) => fun (continuous_linear_functional_law : ContinuousLinearFunctionalEvidence) => fun (representation_law : RepresentationLaw) => fun (uniqueness_law : UniquenessLaw) => fun (riesz_frechet_route : HilbertSpaceEvidence -> ContinuousLinearFunctionalEvidence -> RepresentationLaw -> UniquenessLaw -> RieszFrechetConclusion) => riesz_frechet_route hilbert_space_law continuous_linear_functional_law representation_law uniqueness_law)

theorem hilbert_space_orthogonal_decomposition_theorem.{h,s} :
  forall (Hilbert : Sort h), forall (Scalar : Sort s), forall (Subspace : forall (x : Hilbert), Prop), forall (HilbertSpaceEvidence : Prop), forall (ClosedSubspaceLaw : Prop), forall (ProjectionLaw : Prop), forall (OrthogonalComplementLaw : Prop), forall (DirectSumLaw : Prop), forall (OrthogonalDecompositionConclusion : Prop), forall (evidence : @OrthogonalDecompositionEvidence.{h,s} Hilbert Scalar Subspace HilbertSpaceEvidence ClosedSubspaceLaw ProjectionLaw OrthogonalComplementLaw DirectSumLaw OrthogonalDecompositionConclusion), OrthogonalDecompositionConclusion :=
  fun Hilbert => fun Scalar => fun Subspace => fun HilbertSpaceEvidence => fun ClosedSubspaceLaw => fun ProjectionLaw => fun OrthogonalComplementLaw => fun DirectSumLaw => fun OrthogonalDecompositionConclusion => fun evidence => evidence OrthogonalDecompositionConclusion (fun (hilbert_space_law : HilbertSpaceEvidence) => fun (closed_subspace_law : ClosedSubspaceLaw) => fun (projection_law : ProjectionLaw) => fun (orthogonal_complement_law : OrthogonalComplementLaw) => fun (direct_sum_law : DirectSumLaw) => fun (orthogonal_decomposition_route : HilbertSpaceEvidence -> ClosedSubspaceLaw -> ProjectionLaw -> OrthogonalComplementLaw -> DirectSumLaw -> OrthogonalDecompositionConclusion) => orthogonal_decomposition_route hilbert_space_law closed_subspace_law projection_law orthogonal_complement_law direct_sum_law)

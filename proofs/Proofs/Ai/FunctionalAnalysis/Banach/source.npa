def HahnBanachExtensionEvidence.{f,s,v} :
  forall (Space : Sort s), forall (Scalar : Sort v), forall (Functional : Sort f), forall (VectorSpaceLaw : Prop), forall (NormedSpaceLaw : Prop), forall (CompleteMetricLaw : Prop), forall (ScalarOrderNormLaw : Prop), forall (SubspaceLaw : Prop), forall (SublinearBoundLaw : Prop), forall (FunctionalLinearLaw : forall (phi : Functional), Prop), forall (FunctionalBoundedLaw : forall (phi : Functional), Prop), forall (restrictionFunctional : Functional), forall (extensionFunctional : Functional), forall (HahnBanachConclusion : Prop), Prop :=

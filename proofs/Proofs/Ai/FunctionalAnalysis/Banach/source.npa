def UniformBoundednessEvidence.{i,o,s} :
  forall (Space : Sort s), forall (Operator : Sort o), forall (Index : Sort i), forall (BanachSpaceEvidence : Prop), forall (BaireCategoryEvidence : Prop), forall (operatorAt : forall (idx : Index), Operator), forall (OperatorLinearLaw : forall (op : Operator), Prop), forall (PointwiseBoundedLaw : forall (x : Space), Prop), forall (UniformOperatorBoundedLaw : Prop), Prop :=
  fun Space => fun Operator => fun Index => fun BanachSpaceEvidence => fun BaireCategoryEvidence => fun operatorAt => fun OperatorLinearLaw => fun PointwiseBoundedLaw => fun UniformOperatorBoundedLaw => forall (P : Prop), forall (mk : forall (banach_space_law : BanachSpaceEvidence), forall (baire_category_law : BaireCategoryEvidence), forall (operator_linear_law : forall (idx : Index), OperatorLinearLaw (operatorAt idx)), forall (pointwise_bounded_law : forall (x : Space), PointwiseBoundedLaw x), forall (uniform_boundedness_route : BaireCategoryEvidence -> BanachSpaceEvidence -> (forall (idx : Index), OperatorLinearLaw (operatorAt idx)) -> (forall (x : Space), PointwiseBoundedLaw x) -> UniformOperatorBoundedLaw), P), P

def OpenMappingEvidence.{o,s,t} :
  forall (Domain : Sort s), forall (Codomain : Sort t), forall (Operator : Sort o), forall (DomainBanachEvidence : Prop), forall (CodomainBanachEvidence : Prop), forall (BaireCategoryEvidence : Prop), forall (operator : Operator), forall (LinearLaw : forall (op : Operator), Prop), forall (BoundedLaw : forall (op : Operator), Prop), forall (SurjectiveLaw : forall (op : Operator), Prop), forall (OpenMapConclusion : Prop), Prop :=

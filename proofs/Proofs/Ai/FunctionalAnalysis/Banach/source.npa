def BanachSpaceData.{s} :
  forall (Space : Sort s), forall (VectorSpaceLaw : Prop), forall (NormedSpaceLaw : Prop), forall (CompleteMetricLaw : Prop), Prop :=
  fun Space => fun VectorSpaceLaw => fun NormedSpaceLaw => fun CompleteMetricLaw => forall (P : Prop), forall (mk : forall (vector_space_law : VectorSpaceLaw), forall (normed_space_law : NormedSpaceLaw), forall (complete_metric_law : CompleteMetricLaw), P), P


  forall (Space : Sort s), forall (Operator : Sort o), forall (Index : Sort i), forall (BanachSpaceEvidence : Prop), forall (BaireCategoryEvidence : Prop), forall (operatorAt : forall (idx : Index), Operator), forall (OperatorLinearLaw : forall (op : Operator), Prop), forall (PointwiseBoundedLaw : forall (x : Space), Prop), forall (UniformOperatorBoundedLaw : Prop), forall (evidence : @UniformBoundednessEvidence.{i,o,s} Space Operator Index BanachSpaceEvidence BaireCategoryEvidence operatorAt OperatorLinearLaw PointwiseBoundedLaw UniformOperatorBoundedLaw), UniformOperatorBoundedLaw :=

def InjectivePredicate.{u,v} :
  forall (Source : Sort u), forall (Target : Sort v), forall (map : forall (x : Source), Target), forall (SourceEquivalent : forall (x : Source), forall (y : Source), Prop), forall (TargetEquivalent : forall (x : Target), forall (y : Target), Prop), Prop :=
  fun Source => fun Target => fun map => fun SourceEquivalent => fun TargetEquivalent => forall (x : Source), forall (y : Source), forall (image_eq : TargetEquivalent (map x) (map y)), SourceEquivalent x y

def SurjectivePredicate.{u,v} :
  forall (Source : Sort u), forall (Target : Sort v), forall (map : forall (x : Source), Target), forall (TargetMember : forall (y : Target), Prop), forall (HasPreimage : forall (y : Target), Prop), Prop :=
  fun Source => fun Target => fun map => fun TargetMember => fun HasPreimage => forall (y : Target), forall (target_member : TargetMember y), HasPreimage y

def BijectionPredicate.{u,v} :
  forall (Source : Sort u), forall (Target : Sort v), forall (map : forall (x : Source), Target), forall (SourceEquivalent : forall (x : Source), forall (y : Source), Prop), forall (TargetEquivalent : forall (x : Target), forall (y : Target), Prop), forall (TargetMember : forall (y : Target), Prop), forall (HasPreimage : forall (y : Target), Prop), Prop :=
  fun Source => fun Target => fun map => fun SourceEquivalent => fun TargetEquivalent => fun TargetMember => fun HasPreimage => forall (P : Prop), forall (mk : forall (injective_law : @InjectivePredicate.{u,v} Source Target map SourceEquivalent TargetEquivalent), forall (surjective_law : @SurjectivePredicate.{u,v} Source Target map TargetMember HasPreimage), P), P


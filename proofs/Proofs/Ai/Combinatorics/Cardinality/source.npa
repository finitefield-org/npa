theorem injective_statement.{u,v} :
  forall (Source : Sort u), forall (Target : Sort v), forall (map : forall (x : Source), Target), forall (SourceEquivalent : forall (x : Source), forall (y : Source), Prop), forall (TargetEquivalent : forall (x : Target), forall (y : Target), Prop), forall (injective_args : @InjectivePredicate.{u,v} Source Target map SourceEquivalent TargetEquivalent), forall (x : Source), forall (y : Source), forall (image_eq : TargetEquivalent (map x) (map y)), SourceEquivalent x y :=

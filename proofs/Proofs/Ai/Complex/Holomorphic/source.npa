theorem holomorphic_function_data_intro :
  forall (ComplexNumberStructureEvidence : Prop), forall (OpenDomainLaw : Prop), forall (ComplexDerivativeLaw : Prop), forall (ComplexContinuityLaw : Prop), forall (HolomorphicFunctionEvidence : Prop), forall (route : ComplexNumberStructureEvidence -> OpenDomainLaw -> ComplexDerivativeLaw -> ComplexContinuityLaw -> HolomorphicFunctionEvidence), forall (ha : ComplexNumberStructureEvidence), forall (hb : OpenDomainLaw), forall (hc : ComplexDerivativeLaw), forall (hd : ComplexContinuityLaw), HolomorphicFunctionEvidence :=
  fun A => fun B => fun C => fun D => fun Conclusion => fun route => fun ha => fun hb => fun hc => fun hd => route ha hb hc hd


theorem enumerable_data.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (enumerable : @EnumerableSetPredicate.{u} X subset), forall (P : Prop), forall (use_data : forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), P), P :=
  fun X => fun subset => fun enumerable => fun P => fun use_data => enumerable P use_data

theorem countable_intro.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), @CountableSetPredicate.{u} X subset :=
  fun X => fun subset => fun relation => fun cover => fun sound => fun (P : Prop) => fun (mk : forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), P) => mk relation cover sound

theorem countable_data.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (countable : @CountableSetPredicate.{u} X subset), forall (P : Prop), forall (use_data : forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), P), P :=
  fun X => fun subset => fun countable => fun P => fun use_data => countable P use_data

theorem countable_cover_statement.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), forall (x : X), forall (member : subset x), forall (P : Prop), forall (use_index : forall (n : Nat), forall (rel_member : relation n x), P), P :=
  fun X => fun subset => fun relation => fun cover => fun sound => fun x => fun member => fun P => fun use_index => cover x member P use_index

theorem countable_sound_statement.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), forall (n : Nat), forall (x : X), forall (rel_member : relation n x), subset x :=

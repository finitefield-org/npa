theorem at_most_countable_intro.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), @AtMostCountableSetPredicate.{u} X subset :=
  fun X => fun subset => fun relation => fun cover => fun (P : Prop) => fun (mk : forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), P) => mk relation cover

theorem countable_to_at_most_countable.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (countable : @CountableSetPredicate.{u} X subset), @AtMostCountableSetPredicate.{u} X subset :=
  fun X => fun subset => fun countable => countable (@AtMostCountableSetPredicate.{u} X subset) (fun (relation : forall (n : Nat), forall (x : X), Prop) => fun (cover : @EnumerationCovers.{u} X subset relation) => fun (sound : @EnumerationSound.{u} X subset relation) => @at_most_countable_intro.{u} X subset relation cover)

theorem enumerable_to_countable.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (enumerable : @EnumerableSetPredicate.{u} X subset), @CountableSetPredicate.{u} X subset :=
  fun X => fun subset => fun enumerable => enumerable (@CountableSetPredicate.{u} X subset) (fun (relation : forall (n : Nat), forall (x : X), Prop) => fun (cover : @EnumerationCovers.{u} X subset relation) => fun (sound : @EnumerationSound.{u} X subset relation) => @countable_intro.{u} X subset relation cover sound)

theorem countable_to_enumerable.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (countable : @CountableSetPredicate.{u} X subset), @EnumerableSetPredicate.{u} X subset :=

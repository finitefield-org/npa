  forall (X : Sort u), forall (Index : Sort i), forall (index_subset : forall (idx : Index), Prop), forall (family : forall (idx : Index), forall (x : X), Prop), forall (pair : forall (left : Nat), forall (right : Nat), Nat), forall (index_relation : forall (n : Nat), forall (idx : Index), Prop), forall (index_cover : @EnumerationCovers.{i} Index index_subset index_relation), forall (index_sound : @EnumerationSound.{i} Index index_subset index_relation), forall (choice : @CountableChoiceForIndexedFamily.{i,u} X Index index_subset family), @CountableSetPredicate.{u} X (@IndexedSubfamilyUnionPredicate.{i,u} X Index index_subset family) :=

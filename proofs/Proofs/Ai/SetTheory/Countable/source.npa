theorem countable_choice_for_indexed_family_data.{i,u} :
  forall (X : Sort u), forall (Index : Sort i), forall (index_subset : forall (idx : Index), Prop), forall (family : forall (idx : Index), forall (x : X), Prop), forall (choice : @CountableChoiceForIndexedFamily.{i,u} X Index index_subset family), forall (P : Prop), forall (use_data : forall (family_relation : forall (idx : Index), forall (n : Nat), forall (x : X), Prop), forall (family_cover : forall (idx : Index), forall (index_member : index_subset idx), @EnumerationCovers.{u} X (family idx) (family_relation idx)), forall (family_sound : forall (idx : Index), forall (index_member : index_subset idx), @EnumerationSound.{u} X (family idx) (family_relation idx)), P), P :=
  fun X => fun Index => fun index_subset => fun family => fun choice => fun P => fun use_data => choice P use_data


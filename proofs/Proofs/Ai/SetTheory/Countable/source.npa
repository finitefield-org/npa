  fun X => fun subset => forall (P : Prop), forall (mk : forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), P), P

def CountablyInfiniteSetPredicate.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), Prop :=
  fun X => fun subset => forall (P : Prop), forall (mk : forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), forall (no_duplicate : @EnumerationNoDuplicate.{u} X relation), P), P

def IndexedSubfamilyUnionPredicate.{i,u} :
  forall (X : Sort u), forall (Index : Sort i), forall (index_subset : forall (idx : Index), Prop), forall (family : forall (idx : Index), forall (x : X), Prop), forall (x : X), Prop :=
  fun X => fun Index => fun index_subset => fun family => fun x => forall (P : Prop), forall (mk : forall (idx : Index), forall (index_member : index_subset idx), forall (member : family idx x), P), P

def FlattenedIndexedUnionRelation.{i,u} :
  forall (X : Sort u), forall (Index : Sort i), forall (index_subset : forall (idx : Index), Prop), forall (family : forall (idx : Index), forall (x : X), Prop), forall (pair : forall (left : Nat), forall (right : Nat), Nat), forall (index_relation : forall (n : Nat), forall (idx : Index), Prop), forall (family_relation : forall (idx : Index), forall (n : Nat), forall (x : X), Prop), forall (n : Nat), forall (x : X), Prop :=
  fun X => fun Index => fun index_subset => fun family => fun pair => fun index_relation => fun family_relation => fun n => fun x => forall (P : Prop), forall (mk : forall (idx : Index), forall (index_member : index_subset idx), forall (left : Nat), forall (index_rel : index_relation left idx), forall (right : Nat), forall (family_rel : family_relation idx right x), forall (pair_eq : @Eq.{1} Nat (pair left right) n), P), P

def CountableChoiceForIndexedFamily.{i,u} :
  forall (X : Sort u), forall (Index : Sort i), forall (index_subset : forall (idx : Index), Prop), forall (family : forall (idx : Index), forall (x : X), Prop), Prop :=
  fun X => fun Index => fun index_subset => fun family => forall (P : Prop), forall (mk : forall (family_relation : forall (idx : Index), forall (n : Nat), forall (x : X), Prop), forall (family_cover : forall (idx : Index), forall (index_member : index_subset idx), @EnumerationCovers.{u} X (family idx) (family_relation idx)), forall (family_sound : forall (idx : Index), forall (index_member : index_subset idx), @EnumerationSound.{u} X (family idx) (family_relation idx)), P), P

theorem enumeration_covers_apply.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (x : X), forall (member : subset x), forall (P : Prop), forall (use_index : forall (n : Nat), forall (rel_member : relation n x), P), P :=
  fun X => fun subset => fun relation => fun cover => fun x => fun member => fun P => fun use_index => cover x member P use_index

theorem enumeration_sound_apply.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (relation : forall (n : Nat), forall (x : X), Prop), forall (sound : @EnumerationSound.{u} X subset relation), forall (n : Nat), forall (x : X), forall (rel_member : relation n x), subset x :=
  fun X => fun subset => fun relation => fun sound => fun n => fun x => fun rel_member => sound n x rel_member

theorem enumerable_intro.{u} :
  forall (X : Sort u), forall (subset : forall (x : X), Prop), forall (relation : forall (n : Nat), forall (x : X), Prop), forall (cover : @EnumerationCovers.{u} X subset relation), forall (sound : @EnumerationSound.{u} X subset relation), @EnumerableSetPredicate.{u} X subset :=

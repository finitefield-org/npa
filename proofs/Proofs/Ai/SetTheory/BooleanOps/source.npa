theorem set_de_morgan_union_extensional.{u} :
  forall (X : Sort u), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), @SetExtensionalEquality.{u} X (@SetComplementPredicate.{u} X (@SetUnionPredicate.{u} X left right)) (@SetIntersectionPredicate.{u} X (@SetComplementPredicate.{u} X left) (@SetComplementPredicate.{u} X right)) :=
  fun X => fun left => fun right => @set_extensional_equality_intro.{u} X (@SetComplementPredicate.{u} X (@SetUnionPredicate.{u} X left right)) (@SetIntersectionPredicate.{u} X (@SetComplementPredicate.{u} X left) (@SetComplementPredicate.{u} X right)) (fun (x : X) => fun (not_union : @SetComplementPredicate.{u} X (@SetUnionPredicate.{u} X left right) x) => @set_intersection_intro.{u} X (@SetComplementPredicate.{u} X left) (@SetComplementPredicate.{u} X right) x (fun (left_member : left x) => not_union (@set_union_intro_left.{u} X left right x left_member)) (fun (right_member : right x) => not_union (@set_union_intro_right.{u} X left right x right_member))) (fun (x : X) => fun (both_not : @SetIntersectionPredicate.{u} X (@SetComplementPredicate.{u} X left) (@SetComplementPredicate.{u} X right) x) => fun (union_member : @SetUnionPredicate.{u} X left right x) => @set_union_elim.{u} X left right x union_member False (@set_intersection_left.{u} X (@SetComplementPredicate.{u} X left) (@SetComplementPredicate.{u} X right) x both_not) (@set_intersection_right.{u} X (@SetComplementPredicate.{u} X left) (@SetComplementPredicate.{u} X right) x both_not))

theorem set_de_morgan_intersection_extensional_classical.{u} :
  forall (ExcludedMiddle : forall (P : Prop), Or P (Not P)), forall (X : Sort u), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), @SetExtensionalEquality.{u} X (@SetComplementPredicate.{u} X (@SetIntersectionPredicate.{u} X left right)) (@SetUnionPredicate.{u} X (@SetComplementPredicate.{u} X left) (@SetComplementPredicate.{u} X right)) :=

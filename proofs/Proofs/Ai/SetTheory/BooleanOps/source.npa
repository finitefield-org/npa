theorem set_union_monotone.{u} :
  forall (X : Sort u), forall (left_a : forall (x : X), Prop), forall (right_a : forall (x : X), Prop), forall (left_b : forall (x : X), Prop), forall (right_b : forall (x : X), Prop), forall (left_subset : @Subset.{u} X left_a right_a), forall (right_subset : @Subset.{u} X left_b right_b), @Subset.{u} X (@SetUnionPredicate.{u} X left_a left_b) (@SetUnionPredicate.{u} X right_a right_b) :=
  fun X => fun left_a => fun right_a => fun left_b => fun right_b => fun left_subset => fun right_subset => fun (x : X) => fun (member : @SetUnionPredicate.{u} X left_a left_b x) => @set_union_elim.{u} X left_a left_b x member (@SetUnionPredicate.{u} X right_a right_b x) (fun (left_member : left_a x) => @set_union_intro_left.{u} X right_a right_b x (left_subset x left_member)) (fun (right_member : left_b x) => @set_union_intro_right.{u} X right_a right_b x (right_subset x right_member))

theorem set_intersection_monotone.{u} :
  forall (X : Sort u), forall (left_a : forall (x : X), Prop), forall (right_a : forall (x : X), Prop), forall (left_b : forall (x : X), Prop), forall (right_b : forall (x : X), Prop), forall (left_subset : @Subset.{u} X left_a right_a), forall (right_subset : @Subset.{u} X left_b right_b), @Subset.{u} X (@SetIntersectionPredicate.{u} X left_a left_b) (@SetIntersectionPredicate.{u} X right_a right_b) :=
  fun X => fun left_a => fun right_a => fun left_b => fun right_b => fun left_subset => fun right_subset => fun (x : X) => fun (member : @SetIntersectionPredicate.{u} X left_a left_b x) => @set_intersection_intro.{u} X right_a right_b x (left_subset x (@set_intersection_left.{u} X left_a left_b x member)) (right_subset x (@set_intersection_right.{u} X left_a left_b x member))

import Std.Logic.Eq
import Proofs.Ai.EqReasoning
import Proofs.Ai.Logic.Iff
import Proofs.Ai.SetTheory.Basic
import Proofs.Ai.SetTheory.BooleanOps
import Proofs.Ai.SetTheory.Family
import Proofs.Ai.SetTheory.Relation
import Proofs.Ai.SetTheory.Function

def ImagePredicate.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (source : forall (x : X), Prop), forall (y : Y), Prop :=
  fun X => fun Y => fun f => fun source => fun y => forall (P : Prop), forall (mk : forall (x : X), forall (source_member : source x), forall (image_eq : @Eq.{v} Y (f x) y), P), P

def PreimagePredicate.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (target : forall (y : Y), Prop), forall (x : X), Prop :=
  fun X => fun Y => fun f => fun target => fun x => target (f x)

def FamilyImagePredicate.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (Index : Sort i), forall (f : forall (x : X), Y), forall (family : forall (idx : Index), forall (x : X), Prop), forall (idx : Index), forall (y : Y), Prop :=
  fun X => fun Y => fun Index => fun f => fun family => fun idx => @ImagePredicate.{u,v} X Y f (family idx)

def FamilyPointwiseInhabited.{i,u} :
  forall (Index : Sort i), forall (X : Sort u), forall (family : forall (idx : Index), forall (x : X), Prop), Prop :=
  fun Index => fun X => fun family => forall (idx : Index), forall (P : Prop), forall (mk : forall (x : X), forall (member : family idx x), P), P

def ChoiceFunctionStatement.{i,u} :
  forall (Index : Sort i), forall (X : Sort u), forall (family : forall (idx : Index), forall (x : X), Prop), forall (choice : forall (idx : Index), X), Prop :=
  fun Index => fun X => fun family => fun choice => forall (idx : Index), family idx (choice idx)

def DependentProductStatement.{i,u} :
  forall (Index : Sort i), forall (Fiber : forall (idx : Index), Sort u), forall (family : forall (idx : Index), forall (value : Fiber idx), Prop), forall (choice : forall (idx : Index), Fiber idx), Prop :=
  fun Index => fun Fiber => fun family => fun choice => forall (idx : Index), family idx (choice idx)

theorem image_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (source : forall (x : X), Prop), forall (x : X), forall (y : Y), forall (source_member : source x), forall (image_eq : @Eq.{v} Y (f x) y), @ImagePredicate.{u,v} X Y f source y :=
  fun X => fun Y => fun f => fun source => fun x => fun y => fun source_member => fun image_eq => fun (P : Prop) => fun (mk : forall (x : X), forall (source_member : source x), forall (image_eq : @Eq.{v} Y (f x) y), P) => mk x source_member image_eq

theorem image_elim.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (source : forall (x : X), Prop), forall (y : Y), forall (member : @ImagePredicate.{u,v} X Y f source y), forall (P : Prop), forall (elim : forall (x : X), forall (source_member : source x), forall (image_eq : @Eq.{v} Y (f x) y), P), P :=
  fun X => fun Y => fun f => fun source => fun y => fun member => fun P => fun elim => member P elim

theorem image_self_member.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (source : forall (x : X), Prop), forall (x : X), forall (source_member : source x), @ImagePredicate.{u,v} X Y f source (f x) :=
  fun X => fun Y => fun f => fun source => fun x => fun source_member => @image_intro.{u,v} X Y f source x (f x) source_member (@Eq.refl.{v} Y (f x))

theorem preimage_member_intro.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (target : forall (y : Y), Prop), forall (x : X), forall (member : target (f x)), @PreimagePredicate.{u,v} X Y f target x :=
  fun X => fun Y => fun f => fun target => fun x => fun member => member

theorem preimage_member_elim.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (target : forall (y : Y), Prop), forall (x : X), forall (member : @PreimagePredicate.{u,v} X Y f target x), target (f x) :=
  fun X => fun Y => fun f => fun target => fun x => fun member => member

theorem image_monotone.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (source : forall (x : X), Prop), forall (target : forall (x : X), Prop), forall (source_subset_target : @Subset.{u} X source target), @Subset.{v} Y (@ImagePredicate.{u,v} X Y f source) (@ImagePredicate.{u,v} X Y f target) :=
  fun X => fun Y => fun f => fun source => fun target => fun source_subset_target => fun (y : Y) => fun (member : @ImagePredicate.{u,v} X Y f source y) => @image_elim.{u,v} X Y f source y member (@ImagePredicate.{u,v} X Y f target y) (fun (x : X) => fun (source_member : source x) => fun (image_eq : @Eq.{v} Y (f x) y) => @image_intro.{u,v} X Y f target x y (source_subset_target x source_member) image_eq)

theorem preimage_monotone.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (source : forall (y : Y), Prop), forall (target : forall (y : Y), Prop), forall (source_subset_target : @Subset.{v} Y source target), @Subset.{u} X (@PreimagePredicate.{u,v} X Y f source) (@PreimagePredicate.{u,v} X Y f target) :=
  fun X => fun Y => fun f => fun source => fun target => fun source_subset_target => fun (x : X) => fun (member : @PreimagePredicate.{u,v} X Y f source x) => source_subset_target (f x) member

theorem preimage_union_extensional.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (left : forall (y : Y), Prop), forall (right : forall (y : Y), Prop), @SetExtensionalEquality.{u} X (@PreimagePredicate.{u,v} X Y f (@SetUnionPredicate.{v} Y left right)) (@SetUnionPredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right)) :=
  fun X => fun Y => fun f => fun left => fun right => @set_extensional_equality_intro.{u} X (@PreimagePredicate.{u,v} X Y f (@SetUnionPredicate.{v} Y left right)) (@SetUnionPredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right)) (fun (x : X) => fun (member : @PreimagePredicate.{u,v} X Y f (@SetUnionPredicate.{v} Y left right) x) => @set_union_elim.{v} Y left right (f x) member (@SetUnionPredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x) (fun (left_member : left (f x)) => @set_union_intro_left.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x left_member) (fun (right_member : right (f x)) => @set_union_intro_right.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x right_member)) (fun (x : X) => fun (member : @SetUnionPredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x) => @set_union_elim.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x member (@PreimagePredicate.{u,v} X Y f (@SetUnionPredicate.{v} Y left right) x) (fun (left_member : @PreimagePredicate.{u,v} X Y f left x) => @set_union_intro_left.{v} Y left right (f x) left_member) (fun (right_member : @PreimagePredicate.{u,v} X Y f right x) => @set_union_intro_right.{v} Y left right (f x) right_member))

theorem preimage_intersection_extensional.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (left : forall (y : Y), Prop), forall (right : forall (y : Y), Prop), @SetExtensionalEquality.{u} X (@PreimagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{v} Y left right)) (@SetIntersectionPredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right)) :=
  fun X => fun Y => fun f => fun left => fun right => @set_extensional_equality_intro.{u} X (@PreimagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{v} Y left right)) (@SetIntersectionPredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right)) (fun (x : X) => fun (member : @PreimagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{v} Y left right) x) => @set_intersection_intro.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x (@set_intersection_left.{v} Y left right (f x) member) (@set_intersection_right.{v} Y left right (f x) member)) (fun (x : X) => fun (member : @SetIntersectionPredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x) => @set_intersection_intro.{v} Y left right (f x) (@set_intersection_left.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x member) (@set_intersection_right.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x member))

theorem preimage_difference_extensional.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (left : forall (y : Y), Prop), forall (right : forall (y : Y), Prop), @SetExtensionalEquality.{u} X (@PreimagePredicate.{u,v} X Y f (@SetDifferencePredicate.{v} Y left right)) (@SetDifferencePredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right)) :=
  fun X => fun Y => fun f => fun left => fun right => @set_extensional_equality_intro.{u} X (@PreimagePredicate.{u,v} X Y f (@SetDifferencePredicate.{v} Y left right)) (@SetDifferencePredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right)) (fun (x : X) => fun (member : @PreimagePredicate.{u,v} X Y f (@SetDifferencePredicate.{v} Y left right) x) => @set_difference_intro.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x (@set_difference_left.{v} Y left right (f x) member) (@set_difference_not_right.{v} Y left right (f x) member)) (fun (x : X) => fun (member : @SetDifferencePredicate.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x) => @set_difference_intro.{v} Y left right (f x) (@set_difference_left.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x member) (@set_difference_not_right.{u} X (@PreimagePredicate.{u,v} X Y f left) (@PreimagePredicate.{u,v} X Y f right) x member))

theorem preimage_complement_extensional.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (target : forall (y : Y), Prop), @SetExtensionalEquality.{u} X (@PreimagePredicate.{u,v} X Y f (@SetComplementPredicate.{v} Y target)) (@SetComplementPredicate.{u} X (@PreimagePredicate.{u,v} X Y f target)) :=
  fun X => fun Y => fun f => fun target => @set_extensional_equality_intro.{u} X (@PreimagePredicate.{u,v} X Y f (@SetComplementPredicate.{v} Y target)) (@SetComplementPredicate.{u} X (@PreimagePredicate.{u,v} X Y f target)) (fun (x : X) => fun (member : @PreimagePredicate.{u,v} X Y f (@SetComplementPredicate.{v} Y target) x) => fun (target_member : @PreimagePredicate.{u,v} X Y f target x) => member target_member) (fun (x : X) => fun (member : @SetComplementPredicate.{u} X (@PreimagePredicate.{u,v} X Y f target) x) => fun (target_member : target (f x)) => member target_member)

theorem preimage_indexed_union_extensional.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (Index : Sort i), forall (f : forall (x : X), Y), forall (family : forall (idx : Index), forall (y : Y), Prop), @SetExtensionalEquality.{u} X (@PreimagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,v} Y Index family)) (@IndexedUnionPredicate.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx))) :=
  fun X => fun Y => fun Index => fun f => fun family => @set_extensional_equality_intro.{u} X (@PreimagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,v} Y Index family)) (@IndexedUnionPredicate.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx))) (fun (x : X) => fun (member : @PreimagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,v} Y Index family) x) => @indexed_union_elim.{i,v} Y Index family (f x) member (@IndexedUnionPredicate.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx)) x) (fun (idx : Index) => fun (family_member : family idx (f x)) => @indexed_union_intro.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx)) x idx family_member)) (fun (x : X) => fun (member : @IndexedUnionPredicate.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx)) x) => @indexed_union_elim.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx)) x member (@PreimagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,v} Y Index family) x) (fun (idx : Index) => fun (family_member : @PreimagePredicate.{u,v} X Y f (family idx) x) => @indexed_union_intro.{i,v} Y Index family (f x) idx family_member))

theorem preimage_indexed_intersection_extensional.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (Index : Sort i), forall (f : forall (x : X), Y), forall (family : forall (idx : Index), forall (y : Y), Prop), @SetExtensionalEquality.{u} X (@PreimagePredicate.{u,v} X Y f (@IndexedIntersectionPredicate.{i,v} Y Index family)) (@IndexedIntersectionPredicate.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx))) :=
  fun X => fun Y => fun Index => fun f => fun family => @set_extensional_equality_intro.{u} X (@PreimagePredicate.{u,v} X Y f (@IndexedIntersectionPredicate.{i,v} Y Index family)) (@IndexedIntersectionPredicate.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx))) (fun (x : X) => fun (member : @PreimagePredicate.{u,v} X Y f (@IndexedIntersectionPredicate.{i,v} Y Index family) x) => @indexed_intersection_intro.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx)) x (fun (idx : Index) => member idx)) (fun (x : X) => fun (member : @IndexedIntersectionPredicate.{i,u} X Index (fun (idx : Index) => @PreimagePredicate.{u,v} X Y f (family idx)) x) => @indexed_intersection_intro.{i,v} Y Index family (f x) (fun (idx : Index) => member idx))

theorem image_union_extensional.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), @SetExtensionalEquality.{v} Y (@ImagePredicate.{u,v} X Y f (@SetUnionPredicate.{u} X left right)) (@SetUnionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right)) :=
  fun X => fun Y => fun f => fun left => fun right => @set_extensional_equality_intro.{v} Y (@ImagePredicate.{u,v} X Y f (@SetUnionPredicate.{u} X left right)) (@SetUnionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right)) (fun (y : Y) => fun (member : @ImagePredicate.{u,v} X Y f (@SetUnionPredicate.{u} X left right) y) => @image_elim.{u,v} X Y f (@SetUnionPredicate.{u} X left right) y member (@SetUnionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y) (fun (x : X) => fun (union_member : @SetUnionPredicate.{u} X left right x) => fun (image_eq : @Eq.{v} Y (f x) y) => @set_union_elim.{u} X left right x union_member (@SetUnionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y) (fun (left_member : left x) => @set_union_intro_left.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y (@image_intro.{u,v} X Y f left x y left_member image_eq)) (fun (right_member : right x) => @set_union_intro_right.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y (@image_intro.{u,v} X Y f right x y right_member image_eq)))) (fun (y : Y) => fun (member : @SetUnionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y) => @set_union_elim.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y member (@ImagePredicate.{u,v} X Y f (@SetUnionPredicate.{u} X left right) y) (fun (left_image : @ImagePredicate.{u,v} X Y f left y) => @image_elim.{u,v} X Y f left y left_image (@ImagePredicate.{u,v} X Y f (@SetUnionPredicate.{u} X left right) y) (fun (x : X) => fun (left_member : left x) => fun (image_eq : @Eq.{v} Y (f x) y) => @image_intro.{u,v} X Y f (@SetUnionPredicate.{u} X left right) x y (@set_union_intro_left.{u} X left right x left_member) image_eq)) (fun (right_image : @ImagePredicate.{u,v} X Y f right y) => @image_elim.{u,v} X Y f right y right_image (@ImagePredicate.{u,v} X Y f (@SetUnionPredicate.{u} X left right) y) (fun (x : X) => fun (right_member : right x) => fun (image_eq : @Eq.{v} Y (f x) y) => @image_intro.{u,v} X Y f (@SetUnionPredicate.{u} X left right) x y (@set_union_intro_right.{u} X left right x right_member) image_eq)))

theorem image_intersection_subset.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), @Subset.{v} Y (@ImagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{u} X left right)) (@SetIntersectionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right)) :=
  fun X => fun Y => fun f => fun left => fun right => fun (y : Y) => fun (member : @ImagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{u} X left right) y) => @image_elim.{u,v} X Y f (@SetIntersectionPredicate.{u} X left right) y member (@SetIntersectionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y) (fun (x : X) => fun (both_member : @SetIntersectionPredicate.{u} X left right x) => fun (image_eq : @Eq.{v} Y (f x) y) => @set_intersection_intro.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y (@image_intro.{u,v} X Y f left x y (@set_intersection_left.{u} X left right x both_member) image_eq) (@image_intro.{u,v} X Y f right x y (@set_intersection_right.{u} X left right x both_member) image_eq))

theorem image_intersection_reverse_subset_with_injective.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), forall (injective : @InjectiveFunction.{u,v} X Y f), @Subset.{v} Y (@SetIntersectionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right)) (@ImagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{u} X left right)) :=
  fun X => fun Y => fun f => fun left => fun right => fun injective => fun (y : Y) => fun (member : @SetIntersectionPredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y) => @image_elim.{u,v} X Y f left y (@set_intersection_left.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y member) (@ImagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{u} X left right) y) (fun (x_left : X) => fun (left_member : left x_left) => fun (left_eq : @Eq.{v} Y (f x_left) y) => @image_elim.{u,v} X Y f right y (@set_intersection_right.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y member) (@ImagePredicate.{u,v} X Y f (@SetIntersectionPredicate.{u} X left right) y) (fun (x_right : X) => fun (right_member : right x_right) => fun (right_eq : @Eq.{v} Y (f x_right) y) => @image_intro.{u,v} X Y f (@SetIntersectionPredicate.{u} X left right) x_left y (@set_intersection_intro.{u} X left right x_left left_member (@eq_subst.{u} X right x_right x_left (@eq_symm.{u} X x_left x_right (injective x_left x_right (@eq_trans.{v} Y (f x_left) y (f x_right) left_eq (@eq_symm.{v} Y (f x_right) y right_eq)))) right_member)) left_eq))

theorem image_difference_subset_with_injective.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), forall (injective : @InjectiveFunction.{u,v} X Y f), @Subset.{v} Y (@ImagePredicate.{u,v} X Y f (@SetDifferencePredicate.{u} X left right)) (@SetDifferencePredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right)) :=
  fun X => fun Y => fun f => fun left => fun right => fun injective => fun (y : Y) => fun (member : @ImagePredicate.{u,v} X Y f (@SetDifferencePredicate.{u} X left right) y) => @image_elim.{u,v} X Y f (@SetDifferencePredicate.{u} X left right) y member (@SetDifferencePredicate.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y) (fun (x : X) => fun (difference_member : @SetDifferencePredicate.{u} X left right x) => fun (image_eq : @Eq.{v} Y (f x) y) => @set_difference_intro.{v} Y (@ImagePredicate.{u,v} X Y f left) (@ImagePredicate.{u,v} X Y f right) y (@image_intro.{u,v} X Y f left x y (@set_difference_left.{u} X left right x difference_member) image_eq) (fun (right_image : @ImagePredicate.{u,v} X Y f right y) => @image_elim.{u,v} X Y f right y right_image False (fun (x_right : X) => fun (right_member : right x_right) => fun (right_eq : @Eq.{v} Y (f x_right) y) => @set_difference_not_right.{u} X left right x difference_member (@eq_subst.{u} X right x_right x (injective x_right x (@eq_trans.{v} Y (f x_right) y (f x) right_eq (@eq_symm.{v} Y (f x) y image_eq))) right_member))))

theorem image_complement_subset_complement_with_injective.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (subset : forall (x : X), Prop), forall (injective : @InjectiveFunction.{u,v} X Y f), @Subset.{v} Y (@ImagePredicate.{u,v} X Y f (@SetComplementPredicate.{u} X subset)) (@SetComplementPredicate.{v} Y (@ImagePredicate.{u,v} X Y f subset)) :=
  fun X => fun Y => fun f => fun subset => fun injective => fun (y : Y) => fun (member : @ImagePredicate.{u,v} X Y f (@SetComplementPredicate.{u} X subset) y) => @image_elim.{u,v} X Y f (@SetComplementPredicate.{u} X subset) y member (@SetComplementPredicate.{v} Y (@ImagePredicate.{u,v} X Y f subset) y) (fun (x : X) => fun (not_member : @SetComplementPredicate.{u} X subset x) => fun (image_eq : @Eq.{v} Y (f x) y) => fun (subset_image : @ImagePredicate.{u,v} X Y f subset y) => @image_elim.{u,v} X Y f subset y subset_image False (fun (x_subset : X) => fun (subset_member : subset x_subset) => fun (subset_eq : @Eq.{v} Y (f x_subset) y) => not_member (@eq_subst.{u} X subset x_subset x (injective x_subset x (@eq_trans.{v} Y (f x_subset) y (f x) subset_eq (@eq_symm.{v} Y (f x) y image_eq))) subset_member)))

theorem complement_subset_image_complement_with_surjective.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (f : forall (x : X), Y), forall (subset : forall (x : X), Prop), forall (surjective : @SurjectiveFunction.{u,v} X Y f), @Subset.{v} Y (@SetComplementPredicate.{v} Y (@ImagePredicate.{u,v} X Y f subset)) (@ImagePredicate.{u,v} X Y f (@SetComplementPredicate.{u} X subset)) :=
  fun X => fun Y => fun f => fun subset => fun surjective => fun (y : Y) => fun (not_image : @SetComplementPredicate.{v} Y (@ImagePredicate.{u,v} X Y f subset) y) => surjective y (@ImagePredicate.{u,v} X Y f (@SetComplementPredicate.{u} X subset) y) (fun (x : X) => fun (image_eq : @Eq.{v} Y (f x) y) => @image_intro.{u,v} X Y f (@SetComplementPredicate.{u} X subset) x y (fun (subset_member : subset x) => not_image (@image_intro.{u,v} X Y f subset x y subset_member image_eq)) image_eq)

theorem image_indexed_union_extensional.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (Index : Sort i), forall (f : forall (x : X), Y), forall (family : forall (idx : Index), forall (x : X), Prop), @SetExtensionalEquality.{v} Y (@ImagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,u} X Index family)) (@IndexedUnionPredicate.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family)) :=
  fun X => fun Y => fun Index => fun f => fun family => @set_extensional_equality_intro.{v} Y (@ImagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,u} X Index family)) (@IndexedUnionPredicate.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family)) (fun (y : Y) => fun (member : @ImagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,u} X Index family) y) => @image_elim.{u,v} X Y f (@IndexedUnionPredicate.{i,u} X Index family) y member (@IndexedUnionPredicate.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family) y) (fun (x : X) => fun (union_member : @IndexedUnionPredicate.{i,u} X Index family x) => fun (image_eq : @Eq.{v} Y (f x) y) => @indexed_union_elim.{i,u} X Index family x union_member (@IndexedUnionPredicate.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family) y) (fun (idx : Index) => fun (family_member : family idx x) => @indexed_union_intro.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family) y idx (@image_intro.{u,v} X Y f (family idx) x y family_member image_eq)))) (fun (y : Y) => fun (member : @IndexedUnionPredicate.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family) y) => @indexed_union_elim.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family) y member (@ImagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,u} X Index family) y) (fun (idx : Index) => fun (family_image : @FamilyImagePredicate.{i,u,v} X Y Index f family idx y) => @image_elim.{u,v} X Y f (family idx) y family_image (@ImagePredicate.{u,v} X Y f (@IndexedUnionPredicate.{i,u} X Index family) y) (fun (x : X) => fun (family_member : family idx x) => fun (image_eq : @Eq.{v} Y (f x) y) => @image_intro.{u,v} X Y f (@IndexedUnionPredicate.{i,u} X Index family) x y (@indexed_union_intro.{i,u} X Index family x idx family_member) image_eq)))

theorem image_indexed_intersection_subset.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (Index : Sort i), forall (f : forall (x : X), Y), forall (family : forall (idx : Index), forall (x : X), Prop), @Subset.{v} Y (@ImagePredicate.{u,v} X Y f (@IndexedIntersectionPredicate.{i,u} X Index family)) (@IndexedIntersectionPredicate.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family)) :=
  fun X => fun Y => fun Index => fun f => fun family => fun (y : Y) => fun (member : @ImagePredicate.{u,v} X Y f (@IndexedIntersectionPredicate.{i,u} X Index family) y) => @image_elim.{u,v} X Y f (@IndexedIntersectionPredicate.{i,u} X Index family) y member (@IndexedIntersectionPredicate.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family) y) (fun (x : X) => fun (all_member : @IndexedIntersectionPredicate.{i,u} X Index family x) => fun (image_eq : @Eq.{v} Y (f x) y) => @indexed_intersection_intro.{i,v} Y Index (@FamilyImagePredicate.{i,u,v} X Y Index f family) y (fun (idx : Index) => @image_intro.{u,v} X Y f (family idx) x y (all_member idx) image_eq))

theorem family_image_monotone.{i,u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (Index : Sort i), forall (f : forall (x : X), Y), forall (left : forall (idx : Index), forall (x : X), Prop), forall (right : forall (idx : Index), forall (x : X), Prop), forall (pointwise_subset : forall (idx : Index), @Subset.{u} X (left idx) (right idx)), forall (idx : Index), @Subset.{v} Y (@FamilyImagePredicate.{i,u,v} X Y Index f left idx) (@FamilyImagePredicate.{i,u,v} X Y Index f right idx) :=
  fun X => fun Y => fun Index => fun f => fun left => fun right => fun pointwise_subset => fun idx => @image_monotone.{u,v} X Y f (left idx) (right idx) (pointwise_subset idx)

theorem choice_function_statement_apply.{i,u} :
  forall (Index : Sort i), forall (X : Sort u), forall (family : forall (idx : Index), forall (x : X), Prop), forall (choice : forall (idx : Index), X), forall (statement : @ChoiceFunctionStatement.{i,u} Index X family choice), forall (idx : Index), family idx (choice idx) :=
  fun Index => fun X => fun family => fun choice => fun statement => fun idx => statement idx

theorem dependent_product_statement_apply.{i,u} :
  forall (Index : Sort i), forall (Fiber : forall (idx : Index), Sort u), forall (family : forall (idx : Index), forall (value : Fiber idx), Prop), forall (choice : forall (idx : Index), Fiber idx), forall (statement : @DependentProductStatement.{i,u} Index Fiber family choice), forall (idx : Index), family idx (choice idx) :=
  fun Index => fun Fiber => fun family => fun choice => fun statement => fun idx => statement idx

theorem cardinal_bijection_to_cardinal_le.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,v} X Y source target forward backward), @CardinalLePredicate.{u,v} X Y source target :=

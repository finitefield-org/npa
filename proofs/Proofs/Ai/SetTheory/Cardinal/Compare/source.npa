  forall (X : Sort u), forall (Y : Sort u), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,u} X Y source target forward backward), forall (finite_source : @ConstructiveFiniteSetPredicate.{u} X source), @ConstructiveFiniteSetPredicate.{u} Y target :=

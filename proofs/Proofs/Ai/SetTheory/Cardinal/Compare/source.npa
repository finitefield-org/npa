theorem equipotent_constructive_finite_backward_same_universe.{u} :
  forall (X : Sort u), forall (Y : Sort u), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (equipotent : @EquipotentPredicate.{u,u} X Y source target), forall (finite_target : @ConstructiveFiniteSetPredicate.{u} Y target), @ConstructiveFiniteSetPredicate.{u} X source :=
  fun X => fun Y => fun source => fun target => fun equipotent => fun finite_target => @equipotent_constructive_finite_forward_same_universe.{u} Y X target source (@equipotent_symmetric.{u,u} X Y source target equipotent) finite_target

theorem cardinal_bijection_constructive_finite_backward_same_universe.{u} :
  forall (X : Sort u), forall (Y : Sort u), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,u} X Y source target forward backward), forall (finite_target : @ConstructiveFiniteSetPredicate.{u} Y target), @ConstructiveFiniteSetPredicate.{u} X source :=
  fun X => fun Y => fun source => fun target => fun forward => fun backward => fun witness => fun finite_target => @equipotent_constructive_finite_backward_same_universe.{u} X Y source target (@equipotent_intro.{u,u} X Y source target forward backward witness) finite_target

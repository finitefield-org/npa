theorem equipotent_to_cardinal_ge.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (equipotent : @EquipotentPredicate.{u,v} X Y source target), @CardinalGePredicate.{u,v} X Y source target :=

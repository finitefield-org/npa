theorem cardinal_bijection_forward_injective_on.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,v} X Y source target forward backward), @CardinalInjectiveOn.{u,v} X Y source forward :=
  fun X => fun Y => fun source => fun target => fun forward => fun backward => fun witness => fun (left : X) => fun (right : X) => fun (left_member : source left) => fun (right_member : source right) => fun (image_eq : @Eq.{v} Y (forward left) (forward right)) => @eq_trans.{u} X left (backward (forward left)) right (@eq_symm.{u} X (backward (forward left)) left (@cardinal_bijection_left_inverse.{u,v} X Y source target forward backward witness left left_member)) (@eq_trans.{u} X (backward (forward left)) (backward (forward right)) right (@eq_congr_arg.{v,u} Y X backward (forward left) (forward right) image_eq) (@cardinal_bijection_left_inverse.{u,v} X Y source target forward backward witness right right_member))

theorem cardinal_bijection_forward_surjective_on.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,v} X Y source target forward backward), @CardinalSurjectiveOn.{u,v} X Y source target forward :=
  fun X => fun Y => fun source => fun target => fun forward => fun backward => fun witness => fun (y : Y) => fun (target_member : target y) => fun (P : Prop) => fun (mk : forall (x : X), forall (source_member : source x), forall (image_eq : @Eq.{v} Y (forward x) y), P) => mk (backward y) (@cardinal_bijection_backward_maps.{u,v} X Y source target forward backward witness y target_member) (@cardinal_bijection_right_inverse.{u,v} X Y source target forward backward witness y target_member)

theorem cardinal_bijection_injection_witness.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,v} X Y source target forward backward), @CardinalInjectionWitness.{u,v} X Y source target forward :=
  fun X => fun Y => fun source => fun target => fun forward => fun backward => fun witness => @cardinal_injection_witness_intro.{u,v} X Y source target forward (@cardinal_bijection_forward_maps.{u,v} X Y source target forward backward witness) (@cardinal_bijection_forward_injective_on.{u,v} X Y source target forward backward witness)

theorem cardinal_bijection_surjection_witness.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,v} X Y source target forward backward), @CardinalSurjectionWitness.{u,v} X Y source target forward :=

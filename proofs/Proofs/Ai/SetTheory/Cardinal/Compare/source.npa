theorem cardinal_bijection_finite_by_nat_segment_forward.{u,v} :
  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,v} X Y source target forward backward), forall (finite_source : @FiniteByNatSegmentPredicate.{u} X source), @FiniteByNatSegmentPredicate.{v} Y target :=
  fun X => fun Y => fun source => fun target => fun forward => fun backward => fun witness => fun finite_source => finite_source (@FiniteByNatSegmentPredicate.{v} Y target) (fun (bound : Nat) => fun (segment : forall (n : Nat), Prop) => fun (initial_segment : @NatInitialSegmentPredicate bound segment) => fun (enumerate : forall (n : Nat), forall (segment_member : segment n), X) => fun (complete : @NatSegmentComplete.{u} X source segment enumerate) => fun (sound : @NatSegmentSound.{u} X source segment enumerate) => fun (no_duplicate : @NatSegmentNoDuplicate.{u} X segment enumerate) => @finite_by_nat_segment_intro.{v} Y target bound segment initial_segment (fun (n : Nat) => fun (segment_member : segment n) => forward (enumerate n segment_member)) (fun (y : Y) => fun (target_member : target y) => fun (P : Prop) => fun (use_index : forall (n : Nat), forall (segment_member : segment n), forall (image_eq : @Eq.{v} Y (forward (enumerate n segment_member)) y), P) => complete (backward y) (@cardinal_bijection_backward_maps.{u,v} X Y source target forward backward witness y target_member) P (fun (n : Nat) => fun (segment_member : segment n) => fun (source_eq : @Eq.{u} X (enumerate n segment_member) (backward y)) => use_index n segment_member (@eq_trans.{v} Y (forward (enumerate n segment_member)) (forward (backward y)) y (@eq_congr_arg.{u,v} X Y forward (enumerate n segment_member) (backward y) source_eq) (@cardinal_bijection_right_inverse.{u,v} X Y source target forward backward witness y target_member)))) (fun (n : Nat) => fun (segment_member : segment n) => @cardinal_bijection_forward_maps.{u,v} X Y source target forward backward witness (enumerate n segment_member) (sound n segment_member)) (fun (left : Nat) => fun (right : Nat) => fun (left_member : segment left) => fun (right_member : segment right) => fun (image_eq : @Eq.{v} Y (forward (enumerate left left_member)) (forward (enumerate right right_member))) => no_duplicate left right left_member right_member (@cardinal_bijection_forward_injective_on.{u,v} X Y source target forward backward witness (enumerate left left_member) (enumerate right right_member) (sound left left_member) (sound right right_member) image_eq)))


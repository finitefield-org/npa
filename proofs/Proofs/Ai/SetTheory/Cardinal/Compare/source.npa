  forall (X : Sort u), forall (Y : Sort v), forall (source : forall (x : X), Prop), forall (target : forall (y : Y), Prop), forall (forward : forall (x : X), Y), forall (backward : forall (y : Y), X), forall (witness : @CardinalBijectionWitness.{u,v} X Y source target forward backward), forall (at_most_source : @AtMostCountableSetPredicate.{u} X source), @AtMostCountableSetPredicate.{v} Y target :=
  fun X => fun Y => fun source => fun target => fun forward => fun backward => fun witness => fun at_most_source => at_most_source (@AtMostCountableSetPredicate.{v} Y target) (fun (relation : forall (n : Nat), forall (x : X), Prop) => fun (cover : @EnumerationCovers.{u} X source relation) => @at_most_countable_intro.{v} Y target (fun (n : Nat) => fun (y : Y) => forall (P : Prop), forall (mk : forall (x : X), forall (source_member : source x), forall (rel_member : relation n x), forall (image_eq : @Eq.{v} Y (forward x) y), P), P) (fun (y : Y) => fun (target_member : target y) => fun (P : Prop) => fun (use_index : forall (n : Nat), forall (rel_member : forall (P : Prop), forall (mk : forall (x : X), forall (source_member : source x), forall (rel_member : relation n x), forall (image_eq : @Eq.{v} Y (forward x) y), P), P), P) => cover (backward y) (@cardinal_bijection_backward_maps.{u,v} X Y source target forward backward witness y target_member) P (fun (n : Nat) => fun (rel_member : relation n (backward y)) => use_index n (fun (Q : Prop) => fun (mk : forall (x : X), forall (source_member : source x), forall (rel_member : relation n x), forall (image_eq : @Eq.{v} Y (forward x) y), Q) => mk (backward y) (@cardinal_bijection_backward_maps.{u,v} X Y source target forward backward witness y target_member) rel_member (@cardinal_bijection_right_inverse.{u,v} X Y source target forward backward witness y target_member)))))


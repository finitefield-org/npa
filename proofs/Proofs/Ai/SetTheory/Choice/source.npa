def ChoiceFunctionPredicate.{i,u} :
  forall (Index : Sort i), forall (X : Sort u), forall (index_subset : forall (idx : Index), Prop), forall (family : forall (idx : Index), forall (x : X), Prop), forall (choice : forall (idx : Index), X), Prop :=
  fun Index => fun X => fun index_subset => fun family => fun choice => forall (idx : Index), forall (index_member : index_subset idx), family idx (choice idx)

def ChoicePrinciplePackage :
  forall (ChoiceFunctionLaw : Prop), forall (DependentChoiceLaw : Prop), forall (WellOrderingTheoremLaw : Prop), forall (ZornLemmaLaw : Prop), forall (HausdorffMaximalPrincipleLaw : Prop), Prop :=
  fun ChoiceFunctionLaw => fun DependentChoiceLaw => fun WellOrderingTheoremLaw => fun ZornLemmaLaw => fun HausdorffMaximalPrincipleLaw => forall (P : Prop), forall (mk : forall (choice_function_law : ChoiceFunctionLaw), forall (dependent_choice_law : DependentChoiceLaw), forall (well_ordering_theorem_law : WellOrderingTheoremLaw), forall (zorn_lemma_law : ZornLemmaLaw), forall (hausdorff_maximal_principle_law : HausdorffMaximalPrincipleLaw), P), P

def DependentChoiceInterface.{u} :
  forall (X : Sort u), forall (step_relation : forall (x : X), forall (y : X), Prop), forall (start : X), forall (DependentChoiceLaw : Prop), Prop :=
  fun X => fun step_relation => fun start => fun DependentChoiceLaw => forall (P : Prop), forall (mk : forall (dependent_choice_law : DependentChoiceLaw), forall (sequence_exists : forall (Q : Prop), forall (use_sequence : forall (sequence : forall (n : Nat), X), forall (start_eq : @Eq.{u} X (sequence Nat.zero) start), forall (step_sound : forall (n : Nat), step_relation (sequence n) (sequence (Nat.succ n))), Q), Q), P), P

def WellOrderingTheoremInterface.{u} :
  forall (X : Sort u), forall (base : forall (x : X), Prop), forall (relation : forall (x : X), forall (y : X), Prop), forall (WellOrderingTheoremLaw : Prop), Prop :=
  fun X => fun base => fun relation => fun WellOrderingTheoremLaw => forall (P : Prop), forall (mk : forall (well_ordering_theorem_law : WellOrderingTheoremLaw), forall (linear_order : @LinearOrderPredicate.{u} X relation), forall (well_founded : @WellFoundedPredicate.{u} X relation), forall (base_reflexive : forall (x : X), forall (member : base x), relation x x), P), P

def ChoiceEquivalenceRoute :
  forall (ChoiceFunctionLaw : Prop), forall (DependentChoiceLaw : Prop), forall (WellOrderingTheoremLaw : Prop), forall (ZornLemmaLaw : Prop), forall (HausdorffMaximalPrincipleLaw : Prop), Prop :=
  fun ChoiceFunctionLaw => fun DependentChoiceLaw => fun WellOrderingTheoremLaw => fun ZornLemmaLaw => fun HausdorffMaximalPrincipleLaw => forall (P : Prop), forall (mk : forall (package : @ChoicePrinciplePackage ChoiceFunctionLaw DependentChoiceLaw WellOrderingTheoremLaw ZornLemmaLaw HausdorffMaximalPrincipleLaw), forall (choice_to_well_ordering : ChoiceFunctionLaw -> WellOrderingTheoremLaw), forall (well_ordering_to_zorn : WellOrderingTheoremLaw -> ZornLemmaLaw), forall (zorn_to_hausdorff : ZornLemmaLaw -> HausdorffMaximalPrincipleLaw), forall (choice_to_dependent_choice : ChoiceFunctionLaw -> DependentChoiceLaw), P), P

theorem choice_function_predicate_apply.{i,u} :
  forall (Index : Sort i), forall (X : Sort u), forall (index_subset : forall (idx : Index), Prop), forall (family : forall (idx : Index), forall (x : X), Prop), forall (choice : forall (idx : Index), X), forall (predicate : @ChoiceFunctionPredicate.{i,u} Index X index_subset family choice), forall (idx : Index), forall (index_member : index_subset idx), family idx (choice idx) :=
  fun Index => fun X => fun index_subset => fun family => fun choice => fun predicate => fun idx => fun index_member => predicate idx index_member


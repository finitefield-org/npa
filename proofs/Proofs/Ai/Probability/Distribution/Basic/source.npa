def FiniteDistributionPackage.{p,u,v} :
  forall (X : Sort u), forall (Value : Sort v), forall (event : forall (subset : forall (x : X), Prop), Prop), forall (value_event : forall (target : forall (value : Value), Prop), Prop), forall (ProbabilityValue : Sort p), forall (zero : ProbabilityValue), forall (one : ProbabilityValue), forall (add : forall (left : ProbabilityValue), forall (right : ProbabilityValue), ProbabilityValue), forall (le : forall (left : ProbabilityValue), forall (right : ProbabilityValue), Prop), forall (probability : forall (subset : forall (x : X), Prop), ProbabilityValue), forall (random_variable : forall (x : X), Value), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), Prop :=
  fun X => fun Value => fun event => fun value_event => fun ProbabilityValue => fun zero => fun one => fun add => fun le => fun probability => fun random_variable => fun distribution => forall (P : Prop), forall (mk : forall (probability_law : @FiniteProbabilityLawPackage.{p,u} X event ProbabilityValue zero one add le probability), forall (random_variable_law : @FiniteRandomVariable.{u,v} X Value event value_event random_variable), forall (pushforward_law : forall (target : forall (value : Value), Prop), forall (target_event : value_event target), @Eq.{p} ProbabilityValue (distribution target) (probability (@RandomVariablePreimage.{u,v} X Value random_variable target))), P), P

def DiscreteProbabilityMassPackage.{p,v} :
  forall (Value : Sort v), forall (ProbabilityValue : Sort p), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (mass : forall (value : Value), ProbabilityValue), forall (FiniteSupportEvidence : Prop), forall (MassSumEvidence : Prop), Prop :=
  fun Value => fun ProbabilityValue => fun distribution => fun mass => fun FiniteSupportEvidence => fun MassSumEvidence => forall (P : Prop), forall (mk : forall (finite_support_law : FiniteSupportEvidence), forall (mass_sum_law : MassSumEvidence), forall (singleton_law : forall (value : Value), @Eq.{p} ProbabilityValue (distribution (fun (candidate : Value) => @Eq.{v} Value candidate value)) (mass value)), P), P

def NamedDistributionPackage.{n,p,v} :
  forall (DistributionName : Sort n), forall (Value : Sort v), forall (ProbabilityValue : Sort p), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (name : DistributionName), forall (NamedDistributionEvidence : Prop), forall (ParameterEvidence : Prop), forall (SupportEvidence : Prop), Prop :=
  fun DistributionName => fun Value => fun ProbabilityValue => fun distribution => fun name => fun NamedDistributionEvidence => fun ParameterEvidence => fun SupportEvidence => forall (P : Prop), forall (mk : forall (named_distribution_law : NamedDistributionEvidence), forall (parameter_law : ParameterEvidence), forall (support_law : SupportEvidence), P), P

theorem finite_distribution_package_intro.{p,u,v} :
  forall (X : Sort u), forall (Value : Sort v), forall (event : forall (subset : forall (x : X), Prop), Prop), forall (value_event : forall (target : forall (value : Value), Prop), Prop), forall (ProbabilityValue : Sort p), forall (zero : ProbabilityValue), forall (one : ProbabilityValue), forall (add : forall (left : ProbabilityValue), forall (right : ProbabilityValue), ProbabilityValue), forall (le : forall (left : ProbabilityValue), forall (right : ProbabilityValue), Prop), forall (probability : forall (subset : forall (x : X), Prop), ProbabilityValue), forall (random_variable : forall (x : X), Value), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (probability_law : @FiniteProbabilityLawPackage.{p,u} X event ProbabilityValue zero one add le probability), forall (random_variable_law : @FiniteRandomVariable.{u,v} X Value event value_event random_variable), forall (pushforward_law : forall (target : forall (value : Value), Prop), forall (target_event : value_event target), @Eq.{p} ProbabilityValue (distribution target) (probability (@RandomVariablePreimage.{u,v} X Value random_variable target))), @FiniteDistributionPackage.{p,u,v} X Value event value_event ProbabilityValue zero one add le probability random_variable distribution :=
  fun X => fun Value => fun event => fun value_event => fun ProbabilityValue => fun zero => fun one => fun add => fun le => fun probability => fun random_variable => fun distribution => fun probability_law => fun random_variable_law => fun pushforward_law => fun (P : Prop) => fun (mk : forall (probability_law : @FiniteProbabilityLawPackage.{p,u} X event ProbabilityValue zero one add le probability), forall (random_variable_law : @FiniteRandomVariable.{u,v} X Value event value_event random_variable), forall (pushforward_law : forall (target : forall (value : Value), Prop), forall (target_event : value_event target), @Eq.{p} ProbabilityValue (distribution target) (probability (@RandomVariablePreimage.{u,v} X Value random_variable target))), P) => mk probability_law random_variable_law pushforward_law

theorem finite_distribution_random_variable_law.{p,u,v} :
  forall (X : Sort u), forall (Value : Sort v), forall (event : forall (subset : forall (x : X), Prop), Prop), forall (value_event : forall (target : forall (value : Value), Prop), Prop), forall (ProbabilityValue : Sort p), forall (zero : ProbabilityValue), forall (one : ProbabilityValue), forall (add : forall (left : ProbabilityValue), forall (right : ProbabilityValue), ProbabilityValue), forall (le : forall (left : ProbabilityValue), forall (right : ProbabilityValue), Prop), forall (probability : forall (subset : forall (x : X), Prop), ProbabilityValue), forall (random_variable : forall (x : X), Value), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (pkg : @FiniteDistributionPackage.{p,u,v} X Value event value_event ProbabilityValue zero one add le probability random_variable distribution), @FiniteRandomVariable.{u,v} X Value event value_event random_variable :=
  fun X => fun Value => fun event => fun value_event => fun ProbabilityValue => fun zero => fun one => fun add => fun le => fun probability => fun random_variable => fun distribution => fun pkg => pkg (@FiniteRandomVariable.{u,v} X Value event value_event random_variable) (fun (probability_law : @FiniteProbabilityLawPackage.{p,u} X event ProbabilityValue zero one add le probability) => fun (random_variable_law : @FiniteRandomVariable.{u,v} X Value event value_event random_variable) => fun (pushforward_law : forall (target : forall (value : Value), Prop), forall (target_event : value_event target), @Eq.{p} ProbabilityValue (distribution target) (probability (@RandomVariablePreimage.{u,v} X Value random_variable target))) => random_variable_law)

theorem finite_distribution_pushforward.{p,u,v} :
  forall (X : Sort u), forall (Value : Sort v), forall (event : forall (subset : forall (x : X), Prop), Prop), forall (value_event : forall (target : forall (value : Value), Prop), Prop), forall (ProbabilityValue : Sort p), forall (zero : ProbabilityValue), forall (one : ProbabilityValue), forall (add : forall (left : ProbabilityValue), forall (right : ProbabilityValue), ProbabilityValue), forall (le : forall (left : ProbabilityValue), forall (right : ProbabilityValue), Prop), forall (probability : forall (subset : forall (x : X), Prop), ProbabilityValue), forall (random_variable : forall (x : X), Value), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (pkg : @FiniteDistributionPackage.{p,u,v} X Value event value_event ProbabilityValue zero one add le probability random_variable distribution), forall (target : forall (value : Value), Prop), forall (target_event : value_event target), @Eq.{p} ProbabilityValue (distribution target) (probability (@RandomVariablePreimage.{u,v} X Value random_variable target)) :=
  fun X => fun Value => fun event => fun value_event => fun ProbabilityValue => fun zero => fun one => fun add => fun le => fun probability => fun random_variable => fun distribution => fun pkg => fun target => fun target_event => pkg (@Eq.{p} ProbabilityValue (distribution target) (probability (@RandomVariablePreimage.{u,v} X Value random_variable target))) (fun (probability_law : @FiniteProbabilityLawPackage.{p,u} X event ProbabilityValue zero one add le probability) => fun (random_variable_law : @FiniteRandomVariable.{u,v} X Value event value_event random_variable) => fun (pushforward_law : forall (target_arg : forall (value : Value), Prop), forall (target_event_arg : value_event target_arg), @Eq.{p} ProbabilityValue (distribution target_arg) (probability (@RandomVariablePreimage.{u,v} X Value random_variable target_arg))) => pushforward_law target target_event)

theorem discrete_probability_mass_package_intro.{p,v} :
  forall (Value : Sort v), forall (ProbabilityValue : Sort p), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (mass : forall (value : Value), ProbabilityValue), forall (FiniteSupportEvidence : Prop), forall (MassSumEvidence : Prop), forall (finite_support_law : FiniteSupportEvidence), forall (mass_sum_law : MassSumEvidence), forall (singleton_law : forall (value : Value), @Eq.{p} ProbabilityValue (distribution (fun (candidate : Value) => @Eq.{v} Value candidate value)) (mass value)), @DiscreteProbabilityMassPackage.{p,v} Value ProbabilityValue distribution mass FiniteSupportEvidence MassSumEvidence :=
  fun Value => fun ProbabilityValue => fun distribution => fun mass => fun FiniteSupportEvidence => fun MassSumEvidence => fun finite_support_law => fun mass_sum_law => fun singleton_law => fun (P : Prop) => fun (mk : forall (finite_support_law : FiniteSupportEvidence), forall (mass_sum_law : MassSumEvidence), forall (singleton_law : forall (value : Value), @Eq.{p} ProbabilityValue (distribution (fun (candidate : Value) => @Eq.{v} Value candidate value)) (mass value)), P) => mk finite_support_law mass_sum_law singleton_law

theorem discrete_probability_mass_singleton.{p,v} :
  forall (Value : Sort v), forall (ProbabilityValue : Sort p), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (mass : forall (value : Value), ProbabilityValue), forall (FiniteSupportEvidence : Prop), forall (MassSumEvidence : Prop), forall (pkg : @DiscreteProbabilityMassPackage.{p,v} Value ProbabilityValue distribution mass FiniteSupportEvidence MassSumEvidence), forall (value : Value), @Eq.{p} ProbabilityValue (distribution (fun (candidate : Value) => @Eq.{v} Value candidate value)) (mass value) :=
  fun Value => fun ProbabilityValue => fun distribution => fun mass => fun FiniteSupportEvidence => fun MassSumEvidence => fun pkg => fun value => pkg (@Eq.{p} ProbabilityValue (distribution (fun (candidate : Value) => @Eq.{v} Value candidate value)) (mass value)) (fun (finite_support_law : FiniteSupportEvidence) => fun (mass_sum_law : MassSumEvidence) => fun (singleton_law : forall (value_arg : Value), @Eq.{p} ProbabilityValue (distribution (fun (candidate : Value) => @Eq.{v} Value candidate value_arg)) (mass value_arg)) => singleton_law value)

theorem named_distribution_package_intro.{n,p,v} :
  forall (DistributionName : Sort n), forall (Value : Sort v), forall (ProbabilityValue : Sort p), forall (distribution : forall (target : forall (value : Value), Prop), ProbabilityValue), forall (name : DistributionName), forall (NamedDistributionEvidence : Prop), forall (ParameterEvidence : Prop), forall (SupportEvidence : Prop), forall (named_distribution_law : NamedDistributionEvidence), forall (parameter_law : ParameterEvidence), forall (support_law : SupportEvidence), @NamedDistributionPackage.{n,p,v} DistributionName Value ProbabilityValue distribution name NamedDistributionEvidence ParameterEvidence SupportEvidence :=
  fun DistributionName => fun Value => fun ProbabilityValue => fun distribution => fun name => fun NamedDistributionEvidence => fun ParameterEvidence => fun SupportEvidence => fun named_distribution_law => fun parameter_law => fun support_law => fun (P : Prop) => fun (mk : forall (named_distribution_law : NamedDistributionEvidence), forall (parameter_law : ParameterEvidence), forall (support_law : SupportEvidence), P) => mk named_distribution_law parameter_law support_law

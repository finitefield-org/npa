theorem disjoint_events_symmetric.{u} :
  forall (X : Sort u), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), forall (disjoint : @DisjointEvents.{u} X left right), @DisjointEvents.{u} X right left :=

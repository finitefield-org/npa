  fun X => fun event => fun ProbabilityValue => fun zero => fun one => fun add => fun le => fun probability => fun law => fun left => fun right => fun left_event => fun right_event => fun disjoint => law (@Eq.{p} ProbabilityValue (probability (@SetUnionPredicate.{u} X left right)) (add (probability left) (probability right))) (fun (event_algebra : @FiniteEventAlgebra.{u} X event) => fun (empty_probability : @Eq.{p} ProbabilityValue (probability (@EmptySetPredicate.{u} X)) zero) => fun (universal_probability : @Eq.{p} ProbabilityValue (probability (@UniversalSetPredicate.{u} X)) one) => fun (nonnegative : forall (subset : forall (x : X), Prop), forall (event_member : event subset), le zero (probability subset)) => fun (complement_rule : forall (subset : forall (x : X), Prop), forall (event_member : event subset), @Eq.{p} ProbabilityValue (add (probability subset) (probability (@SetComplementPredicate.{u} X subset))) one) => fun (finite_additive_disjoint : forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), forall (left_event : event left), forall (right_event : event right), forall (disjoint : @DisjointEvents.{u} X left right), @Eq.{p} ProbabilityValue (probability (@SetUnionPredicate.{u} X left right)) (add (probability left) (probability right))) => finite_additive_disjoint left right left_event right_event disjoint)


def FiniteEventAlgebra.{u} :
  forall (X : Sort u), forall (event : forall (subset : forall (x : X), Prop), Prop), Prop :=
  fun X => fun event => forall (P : Prop), forall (mk : forall (empty_event : event (@EmptySetPredicate.{u} X)), forall (universal_event : event (@UniversalSetPredicate.{u} X)), forall (complement_closed : forall (subset : forall (x : X), Prop), forall (event_member : event subset), event (@SetComplementPredicate.{u} X subset)), forall (union_closed : forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), forall (left_event : event left), forall (right_event : event right), event (@SetUnionPredicate.{u} X left right)), forall (intersection_closed : forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), forall (left_event : event left), forall (right_event : event right), event (@SetIntersectionPredicate.{u} X left right)), P), P

def DisjointEvents.{u} :
  forall (X : Sort u), forall (left : forall (x : X), Prop), forall (right : forall (x : X), Prop), Prop :=
  fun X => fun left => fun right => forall (x : X), forall (left_member : left x), forall (right_member : right x), False


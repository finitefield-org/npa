import Std.Logic.Eq

def MatrixMulAssocLaw.{m} :
  forall (Matrix : Sort m), forall (mat_mul : forall (A : Matrix), forall (B : Matrix), Matrix), Prop :=
  fun Matrix => fun mat_mul => forall (A : Matrix), forall (B : Matrix), forall (C : Matrix), @Eq.{m} Matrix (mat_mul (mat_mul A B) C) (mat_mul A (mat_mul B C))

def MatrixLeftUnitLaw.{m} :
  forall (Matrix : Sort m), forall (mat_one : Matrix), forall (mat_mul : forall (A : Matrix), forall (B : Matrix), Matrix), Prop :=
  fun Matrix => fun mat_one => fun mat_mul => forall (A : Matrix), @Eq.{m} Matrix (mat_mul mat_one A) A

def MatrixRightUnitLaw.{m} :

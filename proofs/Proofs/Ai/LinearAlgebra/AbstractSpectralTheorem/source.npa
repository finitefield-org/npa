  fun Matrix => fun mat_one => fun mat_mul => forall (A : Matrix), @Eq.{m} Matrix (mat_mul A mat_one) A

def MatrixAdjointMulLaw.{m} :
  forall (Matrix : Sort m), forall (mat_mul : forall (A : Matrix), forall (B : Matrix), Matrix), forall (mat_adjoint : forall (A : Matrix), Matrix), Prop :=
  fun Matrix => fun mat_mul => fun mat_adjoint => forall (A : Matrix), forall (B : Matrix), @Eq.{m} Matrix (mat_adjoint (mat_mul A B)) (mat_mul (mat_adjoint B) (mat_adjoint A))

def MatrixAdjointInvolutiveLaw.{m} :

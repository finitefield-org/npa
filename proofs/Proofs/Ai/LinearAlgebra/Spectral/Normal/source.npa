import Std.Logic.Eq
import Proofs.Ai.LinearAlgebra.AbstractSpectralTheorem

theorem normal_finite_dimensional_unitarily_diagonalizable.{m} :
  forall (Matrix : Sort m), forall (mat_one : Matrix), forall (mat_mul : forall (A : Matrix), forall (B : Matrix), Matrix), forall (mat_adjoint : forall (A : Matrix), Matrix), forall (is_diagonal : forall (D : Matrix), Prop), forall (finite_dimensional : Prop), forall (complex_spectral_field : Prop), forall (matrix_laws : @MatrixStarAlgebraLawArgs.{m} Matrix mat_one mat_mul mat_adjoint), forall (construction : @SpectralConstructionArgs.{m} Matrix mat_one mat_mul mat_adjoint is_diagonal finite_dimensional complex_spectral_field matrix_laws), forall (A : Matrix), forall (normal : @NormalMatrix.{m} Matrix mat_mul mat_adjoint A), forall (S : Prop), forall (choose : forall (U : Matrix), forall (D : Matrix), forall (diag : @UnitaryDiagonalization.{m} Matrix mat_one mat_mul mat_adjoint is_diagonal A U D), S), S :=
  fun Matrix => fun mat_one => fun mat_mul => fun mat_adjoint => fun is_diagonal => fun finite_dimensional => fun complex_spectral_field => fun matrix_laws => fun construction => fun A => fun normal => fun S => fun choose => @finite_dimensional_normal_matrix_unitarily_diagonalizable.{m} Matrix mat_one mat_mul mat_adjoint is_diagonal finite_dimensional complex_spectral_field matrix_laws construction A normal S choose
